<UserControl x:Class="NetErp.UserControls.ItemDimensionEditor.Views.SerialsDimensionDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:dto="clr-namespace:NetErp.UserControls.ItemDimensionEditor.DTO"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             Width="{Binding DialogWidth}"
             Height="{Binding DialogHeight}"
             Background="#EEF1F5"
             PreviewKeyDown="OnPreviewKeyDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <busyIndicator:BusyMask IsBusy="{Binding IsValidating}"
                            IndicatorType="BouncingDot"
                            BusyContent="Validando seriales..."
                            BusyContentMargin="0,20,0,0">
    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="8,0,8,8">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding ItemHeader}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <!-- Inbound: capture + CSV -->
            <Grid Grid.Row="1" Margin="0,0,0,8"
                  Visibility="{Binding IsInbound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <dxe:ButtonEdit Grid.Column="0"
                                Text="{Binding CaptureInput, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                NullText="Escribe o escanea un serial y presiona ENTER..."
                                MinHeight="28"
                                CharacterCasing="Upper"
                                BorderBrush="#C8CED6"
                                AllowDefaultButton="False"
                                cal:Message.Attach="[Event KeyDown] = [Action OnCaptureKeyDown($eventArgs)]">
                    <h:FocusBehavior.IsFocused>
                        <Binding Path="CaptureFocus" Mode="TwoWay"/>
                    </h:FocusBehavior.IsFocused>
                    <dxe:ButtonEdit.Buttons>
                        <dxe:ButtonInfo IsLeft="True" GlyphKind="Plus" Margin="4,0,2,0"/>
                    </dxe:ButtonEdit.Buttons>
                </dxe:ButtonEdit>
                <Button Grid.Column="1" Margin="6,0,0,0"
                        cal:Message.Attach="AddFromCsvAsync"
                        Background="Transparent" BorderThickness="1" BorderBrush="#C8CED6"
                        Padding="8,4" Cursor="Hand"
                        ToolTip="Cargar seriales desde archivo CSV">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{dx:DXImage 'Images/Actions/Open_16x16.png'}" Width="16" Height="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Cargar CSV" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Outbound: capture only -->
            <dxe:ButtonEdit Grid.Row="1"
                            Text="{Binding CaptureInput, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                            NullText="Escribe o escanea un serial y presiona ENTER..."
                            MinHeight="28"
                            Margin="0,0,0,8"
                            CharacterCasing="Upper"
                            BorderBrush="#C8CED6"
                            AllowDefaultButton="False"
                            Visibility="{Binding IsOutbound, Converter={StaticResource BooleanToVisibilityConverter}}"
                            cal:Message.Attach="[Event KeyDown] = [Action OnCaptureKeyDown($eventArgs)]">
                <h:FocusBehavior.IsFocused>
                    <Binding Path="CaptureFocus" Mode="TwoWay"/>
                </h:FocusBehavior.IsFocused>
                <dxe:ButtonEdit.Buttons>
                    <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                </dxe:ButtonEdit.Buttons>
            </dxe:ButtonEdit>

            <!-- Inbound: search + grid -->
            <Grid Grid.Row="2" Visibility="{Binding IsInbound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <dxe:ButtonEdit Grid.Column="0"
                                    Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                    NullText="Buscar serial agregado..."
                                    MinHeight="26"
                                    CharacterCasing="Upper"
                                    BorderBrush="#C8CED6"
                                    AllowDefaultButton="False">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>
                    <Button Grid.Column="1" Margin="6,0,0,0"
                            cal:Message.Attach="RemoveSelected"
                            IsEnabled="{Binding HasSelected}"
                            Background="Transparent" BorderThickness="1" BorderBrush="#C8CED6"
                            Padding="8,4" Cursor="Hand"
                            ToolTip="Eliminar seleccionados">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{dx:DXImage 'Images/Actions/Trash_16x16.png'}" Width="16" Height="16" Margin="0,0,4,0"/>
                            <TextBlock Text="Eliminar seleccionados" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Margin="6,0,0,0"
                            cal:Message.Attach="RemoveConflicts"
                            IsEnabled="{Binding HasConflicts}"
                            Background="Transparent" BorderThickness="1" BorderBrush="#C8CED6"
                            Padding="8,4" Cursor="Hand"
                            ToolTip="Eliminar todos los seriales con conflicto">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{dx:DXImage 'Images/Actions/DeleteList_16x16.png'}" Width="16" Height="16" Margin="0,0,4,0"/>
                            <TextBlock Text="Eliminar conflictos" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding NewSerialsView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          CanUserReorderColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EAECEF"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          BorderBrush="#D9DDE3"
                          BorderThickness="1">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:SerialValidationStatus.AlreadyActive}">
                                    <Setter Property="Background" Value="#FFE8E6"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:SerialValidationStatus.PreselectedInDraft}">
                                    <Setter Property="Background" Value="#FFF3E0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:SerialValidationStatus.DuplicateInList}">
                                    <Setter Property="Background" Value="#FFF9C4"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:SerialValidationStatus.Available}">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D6E9F8"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Serial" Width="220" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SerialNumber}" FontFamily="Consolas" Padding="6,4" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Estado" Width="*" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center" Padding="6,4"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Detail}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#888888"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:SerialValidationStatus.Available}">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:SerialValidationStatus.AlreadyActive}">
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:SerialValidationStatus.PreselectedInDraft}">
                                                        <Setter Property="Foreground" Value="#EF6C00"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:SerialValidationStatus.DuplicateInList}">
                                                        <Setter Property="Foreground" Value="#F9A825"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="50" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            cal:Message.Attach="RemoveNewSerial($dataContext)"
                                            ToolTip="Eliminar serial">
                                        <Image Source="{dx:DXImage 'Images/Actions/Trash_16x16.png'}" Width="16" Height="16"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="40" CanUserResize="False">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center" IsThreeState="True"
                                              IsChecked="{Binding DataContext.AllSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                              ToolTip="Seleccionar todos"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Outbound: dual panels -->
            <Grid Grid.Row="2" Visibility="{Binding IsOutbound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#C8CED6" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Disponibles" FontWeight="SemiBold" Margin="6"/>
                        <dxg:GridControl x:Name="AvailableGrid"
                                         ItemsSource="{Binding AvailableRows}"
                                         AutoGenerateColumns="None"
                                         cal:Message.Attach="[Event MouseDoubleClick] = [Action MoveToSelected($source.SelectedItem)]">
                            <dxg:GridControl.View>
                                <dxg:TableView ShowGroupPanel="False" AllowEditing="False"
                                               AllowSorting="False" AllowColumnFiltering="False"
                                               AlternateRowBackground="Beige" AutoWidth="True"/>
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn Header="Serial" FieldName="SerialNumber" Width="*"/>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </DockPanel>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                    <Image Source="{dx:DXImage 'Images/Actions/Arrow_Right_16x16.png'}" Width="16" Height="16"/>
                    <Image Source="{dx:DXImage 'Images/Actions/Arrow_Left_16x16.png'}" Width="16" Height="16" Margin="0,6,0,0"/>
                </StackPanel>

                <Border Grid.Column="2" BorderBrush="#C8CED6" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Seleccionados" FontWeight="SemiBold" Margin="6"/>
                        <dxg:GridControl x:Name="SelectedGrid"
                                         ItemsSource="{Binding SelectedRows}"
                                         AutoGenerateColumns="None"
                                         cal:Message.Attach="[Event MouseDoubleClick] = [Action MoveToAvailable($source.SelectedItem)]">
                            <dxg:GridControl.View>
                                <dxg:TableView ShowGroupPanel="False" AllowEditing="False"
                                               AllowSorting="False" AllowColumnFiltering="False"
                                               AlternateRowBackground="Beige" AutoWidth="True"/>
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn Header="Serial" FieldName="SerialNumber" Width="*"/>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </DockPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button cal:Message.Attach="AcceptAsync"
                        IsEnabled="{Binding CanAccept}"
                        Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32"/>
                        <TextBlock Text="Aceptar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button cal:Message.Attach="CancelAsync"
                        Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32"/>
                        <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
    </busyIndicator:BusyMask>
</UserControl>
