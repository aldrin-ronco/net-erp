<UserControl x:Class="NetErp.UserControls.ItemDimensionEditor.Views.SizesDimensionDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             Width="{Binding DialogWidth}"
             Height="{Binding DialogHeight}"
             Background="#EEF1F5">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="8,0,8,8">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding ItemHeader}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <dxg:GridControl Grid.Row="1"
                             ItemsSource="{Binding Rows}"
                             AutoGenerateColumns="None">
                <dxg:GridControl.View>
                    <dxg:TableView ShowGroupPanel="False"
                                   AllowEditing="True"
                                   AllowSorting="False"
                                   AllowColumnFiltering="False"
                                   AlternateRowBackground="Beige"
                                   AutoWidth="True"
                                   NavigationStyle="Cell"
                                   AllowPerPixelScrolling="True"/>
                </dxg:GridControl.View>
                <dxg:GridControl.Columns>
                    <dxg:GridColumn Header="Talla" FieldName="SizeName" Width="*" ReadOnly="True"/>
                    <dxg:GridColumn Header="Disponible" FieldName="Available" Width="120" ReadOnly="True"
                                    HorizontalHeaderContentAlignment="Right"
                                    Visible="{Binding DataContext.IsOutbound, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <dxg:GridColumn Header="Cantidad" FieldName="Quantity" Width="120"
                                    HorizontalHeaderContentAlignment="Right">
                        <dxg:GridColumn.EditSettings>
                            <dxe:SpinEditSettings MinValue="0"
                                                  IsFloatValue="True"
                                                  MaskType="Numeric"
                                                  Mask="N2"
                                                  AllowNullInput="False"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                </dxg:GridControl.Columns>
            </dxg:GridControl>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button cal:Message.Attach="AcceptAsync"
                        IsEnabled="{Binding CanAccept}"
                        Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32"/>
                        <TextBlock Text="Aceptar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button cal:Message.Attach="CancelAsync" IsCancel="True"
                        Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32"/>
                        <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
