<UserControl x:Class="NetErp.UserControls.ItemDimensionEditor.Views.ItemDimensionEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:currency="clr-namespace:CurrencyTextBoxControl;assembly=CurrencyTextbox"
             mc:Ignorable="d"
             d:DesignHeight="160" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="KeyboardFocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="-2" StrokeThickness="2" Stroke="#1565C0" RadiusX="4" RadiusY="4" SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel KeyboardNavigation.TabNavigation="Local">
        <!-- Búsqueda: una sola línea -->
        <dxe:ButtonEdit x:Name="SearchTermBox"
                        TabIndex="1"
                        Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        NullText="Buscar por código, referencia o EAN; ENTER abre lista..."
                        ToolTip="ENTER busca por código/referencia/EAN exacto; sin match abre la lista"
                        MinHeight="28"
                        CharacterCasing="Upper"
                        BorderBrush="#C8CED6"
                        AllowDefaultButton="False"
                        IsEnabled="{Binding IsStorageReady}"
                        IsReadOnly="{Binding IsSearchReadOnly}"
                        cal:Message.Attach="[Event KeyDown] = [Action OnSearchKeyDown($eventArgs)]">
            <h:FocusBehavior.IsFocused>
                <Binding Path="SearchFieldFocus" Mode="TwoWay"/>
            </h:FocusBehavior.IsFocused>
            <dxe:ButtonEdit.Buttons>
                <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                <dxe:ButtonInfo IsLeft="False" GlyphKind="Cancel" Margin="2,0,4,0"
                                ToolTip="Limpiar búsqueda"
                                Visibility="{Binding HasSearchTerm, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Command="{Binding ClearSearchCommand}"/>
            </dxe:ButtonEdit.Buttons>
        </dxe:ButtonEdit>

        <!-- Panel info ítem (visible solo si hay match): code + reference + nombre + cantidad + UND + costo + dimensiones en una sola línea -->
        <Border Margin="0,8,0,0"
                Padding="10,8"
                Background="#F8FBFD"
                BorderBrush="#C8CED6"
                BorderThickness="1"
                CornerRadius="4"
                h:EnterKeyTraversal.IsEnabled="True"
                Visibility="{Binding HasSelectedItem, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Código" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding SelectedItemCode}" FontSize="13" FontWeight="SemiBold" Height="28" VerticalAlignment="Center" Padding="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="Referencia" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding SelectedItemReference}" FontSize="13" Height="28" VerticalAlignment="Center" Padding="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,16,0">
                    <TextBlock Text="Producto" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding SelectedItemName}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Height="28" VerticalAlignment="Center" Padding="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,12,0" MinWidth="120">
                    <TextBlock Text="Cantidad" FontSize="11" Foreground="Gray"/>
                    <dxe:SpinEdit TabIndex="2" Height="28" Padding="3" BorderBrush="#C8CED6"
                                  MinValue="0"
                                  EditValueType="{x:Type sys:Decimal}"
                                  IsFloatValue="True"
                                  MaskType="Numeric" Mask="{Binding QuantityMask}"
                                  AllowNullInput="False"
                                  IsReadOnly="{Binding QuantityIsReadOnly}"
                                  EditValue="{Binding TotalQuantity, Mode=OneWay}"
                                  Visibility="{Binding QuantityIsReadOnly, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <dxe:SpinEdit TabIndex="2" Height="28" Padding="3" BorderBrush="#C8CED6"
                                  MinValue="0"
                                  EditValueType="{x:Type sys:Decimal}"
                                  IsFloatValue="True"
                                  MaskType="Numeric" Mask="{Binding QuantityMask}"
                                  AllowNullInput="False"
                                  EditValue="{Binding BaseQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <h:FocusBehavior.IsFocused>
                            <Binding Path="QuantityFieldFocus" Mode="TwoWay"/>
                        </h:FocusBehavior.IsFocused>
                        <dxe:SpinEdit.Style>
                            <Style TargetType="dxe:SpinEdit">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QuantityIsReadOnly}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </dxe:SpinEdit.Style>
                    </dxe:SpinEdit>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,12,0">
                    <TextBlock Text="UND" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding SelectedItemMeasurementUnit}" FontSize="13" Height="28" VerticalAlignment="Center" Padding="0,6,0,0"/>
                </StackPanel>

                <ContentPresenter Grid.Column="5"
                                  Content="{Binding AdditionalContent, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                <ContentPresenter Grid.Column="6"
                                  Content="{Binding TrailingContent, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Grid>
        </Border>

        <!-- Panel imágenes del item seleccionado. Oculto si no hay imágenes o S3 no disponible. -->
        <Border Margin="0,8,0,0"
                Background="White" BorderBrush="#D9DDE3" BorderThickness="1" CornerRadius="6"
                Visibility="{Binding HasImagesToShow, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="6">
                <ItemsControl ItemsSource="{Binding CurrentImages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4" BorderBrush="#D9DDE3" BorderThickness="1" CornerRadius="4"
                                    Background="White" Width="120" Height="120">
                                <Image Source="{Binding SourceImage, UpdateSourceTrigger=PropertyChanged}"
                                       Stretch="Uniform" Margin="2"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </StackPanel>
</UserControl>
