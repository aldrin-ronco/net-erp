<UserControl x:Class="NetErp.UserControls.ItemDimensionEditor.Views.LotsDimensionDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:s="clr-namespace:NetErp.Helpers.Shortcuts"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             s:Shortcuts.Enabled="{DynamicResource DialogShortcuts}"
             Focusable="True"
             mc:Ignorable="d"
             Width="{Binding DialogWidth}"
             Height="{Binding DialogHeight}"
             Background="#EEF1F5"
             PreviewKeyDown="OnPreviewKeyDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <s:CommandList x:Key="DialogShortcuts">
            <x:Static Member="s:AppCommands.Save"/>
            <x:Static Member="s:AppCommands.Close"/>
        </s:CommandList>
        <Style x:Key="ActionButtonBorder" TargetType="Border">
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#1565C0"/>
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="8,0,8,8">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="{Binding ItemHeader}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <!-- Acción inline (solo entradas) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8"
                        Visibility="{Binding IsInbound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button cal:Message.Attach="AddRow"
                        Background="Transparent" BorderThickness="0" Padding="6,2" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{dx:DXImage 'Images/Actions/Add_16x16.png'}" Width="16" Height="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Agregar lote" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Grid entradas - WPF DataGrid -->
            <DataGrid Grid.Row="2"
                      x:Name="LotsGrid"
                      Loaded="OnGridLoaded"
                      PreviewKeyDown="OnGridPreviewKeyDown"
                      ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="False"
                      CanUserReorderColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EAECEF"
                      AlternatingRowBackground="#FAF9F2"
                      RowHeaderWidth="0"
                      SelectionUnit="CellOrRowHeader"
                      BorderBrush="#D9DDE3"
                      BorderThickness="1"
                      Visibility="{Binding IsInbound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="Black"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Quantity}" Value="0">
                                <Setter Property="Background" Value="#FFE0E0"/>
                            </DataTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="Background" Value="#D6E9F8"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Lote" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:TextEdit Text="{Binding LotNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                                              CharacterCasing="Upper"
                                              Padding="3"
                                              BorderBrush="Transparent"
                                              ShowBorder="False"
                                              VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Vencimiento" Width="180">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:DateEdit EditValue="{Binding ExpirationDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              AllowNullInput="True"
                                              NullText="Sin vencimiento"
                                              NullValueButtonPlacement="EditBox"
                                              MinValue="{x:Static sys:DateTime.Today}"
                                              MaskType="DateTime"
                                              Mask="d"
                                              Padding="3"
                                              BorderBrush="Transparent"
                                              ShowBorder="False"
                                              VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Cantidad" Width="140">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:TextEdit Tag="Quantity"
                                              MaskType="Numeric"
                                              Mask="{Binding DataContext.QuantityMask, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              MaskUseAsDisplayFormat="True"
                                              EditValue="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                                              Padding="3"
                                              BorderBrush="Transparent"
                                              ShowBorder="False"
                                              VerticalContentAlignment="Center"
                                              HorizontalContentAlignment="Right"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="40" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        IsTabStop="False"
                                        cal:Message.Attach="RemoveRow($dataContext)"
                                        ToolTip="Eliminar fila">
                                    <Image Source="{dx:DXImage 'Images/Actions/Trash_16x16.png'}" Width="16" Height="16"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Grid salidas - WPF DataGrid -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding AvailableRows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="False"
                      CanUserReorderColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EAECEF"
                      AlternatingRowBackground="#FAF9F2"
                      RowHeaderWidth="0"
                      SelectionUnit="CellOrRowHeader"
                      BorderBrush="#D9DDE3"
                      BorderThickness="1"
                      Visibility="{Binding IsOutbound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#D6E9F8"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Lote" Width="*" Binding="{Binding LotNumber}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Vencimiento" Width="180" Binding="{Binding ExpirationDate, StringFormat=d, TargetNullValue='Sin vencimiento'}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Disponible" Width="140" Binding="{Binding Available, StringFormat=N2}" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="A sacar" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Quantity, StringFormat=N2}" TextAlignment="Right" Padding="6,4"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <dxe:TextEdit MaskType="Numeric"
                                              Mask="N2"
                                              MaskUseAsDisplayFormat="True"
                                              EditValue="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                              VerticalContentAlignment="Center"
                                              HorizontalContentAlignment="Right"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Mensaje validación inbound -->
            <TextBlock Grid.Row="3" Text="{Binding ValidationMessage}" Foreground="#D32F2F" FontSize="12"
                       Margin="0,6,0,0" HorizontalAlignment="Left"
                       Visibility="{Binding IsInbound, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Botones -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Border Style="{StaticResource ActionButtonBorder}">
                    <Button cal:Message.Attach="AcceptAsync"
                            IsEnabled="{Binding CanAccept}"
                            ToolTip="Aceptar (Ctrl+S)"
                            FocusVisualStyle="{x:Null}"
                            Background="Transparent" BorderThickness="0" Padding="13,3" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center" Focusable="False">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" Focusable="False"/>
                            <TextBlock Text="Aceptar" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                        </StackPanel>
                    </Button>
                </Border>
                <Border Style="{StaticResource ActionButtonBorder}">
                    <Button cal:Message.Attach="CancelAsync"
                            ToolTip="Cancelar (Esc)"
                            FocusVisualStyle="{x:Null}"
                            Background="Transparent" BorderThickness="0" Padding="13,3" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center" Focusable="False">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" Focusable="False"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                        </StackPanel>
                    </Button>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
