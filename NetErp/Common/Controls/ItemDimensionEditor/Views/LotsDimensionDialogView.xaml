<UserControl x:Class="NetErp.UserControls.ItemDimensionEditor.Views.LotsDimensionDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             Width="{Binding DialogWidth}"
             Height="{Binding DialogHeight}"
             Background="#EEF1F5">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="8,0,8,8">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="{Binding ItemHeader}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <!-- Acción inline (solo entradas) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8"
                        Visibility="{Binding IsInbound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button cal:Message.Attach="AddRow"
                        Background="Transparent" BorderThickness="0" Padding="6,2" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{dx:DXImage 'Images/Actions/Add_16x16.png'}" Width="16" Height="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Agregar lote" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Grid entradas -->
            <dxg:GridControl Grid.Row="2"
                             ItemsSource="{Binding Rows}"
                             AutoGenerateColumns="None"
                             Visibility="{Binding IsInbound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <dxg:GridControl.View>
                    <dxg:TableView ShowGroupPanel="False"
                                   AllowEditing="True"
                                   AllowSorting="False"
                                   AllowColumnFiltering="False"
                                   AlternateRowBackground="Beige"
                                   AutoWidth="True"
                                   NavigationStyle="Cell"
                                   AllowPerPixelScrolling="True"/>
                </dxg:GridControl.View>
                <dxg:GridControl.Columns>
                    <dxg:GridColumn Header="Lote" FieldName="LotNumber" Width="*"/>
                    <dxg:GridColumn Header="Vencimiento" FieldName="ExpirationDate" Width="160">
                        <dxg:GridColumn.EditSettings>
                            <dxe:DateEditSettings AllowNullInput="True"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Cantidad" FieldName="Quantity" Width="120"
                                    HorizontalHeaderContentAlignment="Right">
                        <dxg:GridColumn.EditSettings>
                            <dxe:SpinEditSettings MinValue="0"
                                                  IsFloatValue="True"
                                                  MaskType="Numeric"
                                                  Mask="N2"
                                                  AllowNullInput="False"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Width="40">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        cal:Message.Attach="RemoveRow($dataContext)"
                                        ToolTip="Eliminar fila">
                                    <Image Source="{dx:DXImage 'Images/Actions/Trash_16x16.png'}" Width="16" Height="16"/>
                                </Button>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl.Columns>
            </dxg:GridControl>

            <!-- Grid salidas -->
            <dxg:GridControl Grid.Row="2"
                             ItemsSource="{Binding AvailableRows}"
                             AutoGenerateColumns="None"
                             Visibility="{Binding IsOutbound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <dxg:GridControl.View>
                    <dxg:TableView ShowGroupPanel="False"
                                   AllowEditing="True"
                                   AllowSorting="False"
                                   AllowColumnFiltering="False"
                                   AlternateRowBackground="Beige"
                                   AutoWidth="True"
                                   NavigationStyle="Cell"
                                   AllowPerPixelScrolling="True"/>
                </dxg:GridControl.View>
                <dxg:GridControl.Columns>
                    <dxg:GridColumn Header="Lote" FieldName="LotNumber" Width="*" ReadOnly="True"/>
                    <dxg:GridColumn Header="Vencimiento" FieldName="ExpirationDate" Width="160" ReadOnly="True"/>
                    <dxg:GridColumn Header="Disponible" FieldName="Available" Width="120" ReadOnly="True"
                                    HorizontalHeaderContentAlignment="Right"/>
                    <dxg:GridColumn Header="A sacar" FieldName="Quantity" Width="120"
                                    HorizontalHeaderContentAlignment="Right">
                        <dxg:GridColumn.EditSettings>
                            <dxe:SpinEditSettings MinValue="0"
                                                  IsFloatValue="True"
                                                  MaskType="Numeric"
                                                  Mask="N2"
                                                  AllowNullInput="False"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                </dxg:GridControl.Columns>
            </dxg:GridControl>

            <!-- Botones -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button cal:Message.Attach="AcceptAsync"
                        IsEnabled="{Binding CanAccept}"
                        Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32"/>
                        <TextBlock Text="Aceptar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button cal:Message.Attach="CancelAsync" IsCancel="True"
                        Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32"/>
                        <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
