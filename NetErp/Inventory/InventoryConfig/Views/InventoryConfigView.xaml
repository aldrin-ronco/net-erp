<UserControl x:Class="NetErp.Inventory.InventoryConfig.Views.InventoryConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#EEF1F5"
             FontFamily="Century Gothic">

    <UserControl.Resources>
        <Style x:Key="ActionButtonBorder" TargetType="Border">
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#1565C0"/>
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionButtonImage" TargetType="Image">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Foreground" Value="#2c3e50"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="Background" Value="#E5E9EE"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="ConfigCombo" TargetType="dxe:ComboBoxEdit">
            <Setter Property="Padding" Value="2"/>
            <Setter Property="BorderBrush" Value="#C8CED6"/>
            <Setter Property="IsTextEditable" Value="False"/>
            <Setter Property="ShowNullTextForEmptyValue" Value="True"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.15*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.15*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Panel central -->
        <Border Grid.Column="1"
                Grid.Row="1"
                Background="White"
                BorderBrush="#D9DDE3"
                BorderThickness="1"
                CornerRadius="12"
                Padding="32,24"
                MaxWidth="1100">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.1"
                                  ShadowDepth="8"
                                  BlurRadius="20"/>
            </Border.Effect>

            <busyIndicator:BusyMask x:Name="BusyIndicator"
                                    IsBusy="{Binding IsBusy}"
                                    IndicatorType="BouncingDot"
                                    BusyContent="Por favor espere..."
                                    BusyContentMargin="0,20,0,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,18">
                        <TextBlock Text="CONFIGURACIÓN DE INVENTARIO"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"
                                   Foreground="#2c3e50"/>
                        <TextBlock Text="Parámetros predeterminados de inventario y traslados"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="#6c757d"/>
                    </StackPanel>

                    <!-- Sección: Generales -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <TextBlock Text="GENERALES" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource SectionDivider}"/>

                        <StackPanel>
                            <TextBlock Text="Bodega de tránsito" Style="{StaticResource FieldLabel}"/>
                            <dxe:ComboBoxEdit Style="{StaticResource ConfigCombo}"
                                              ItemsSource="{Binding Storages}"
                                              EditValue="{Binding SelectedTransitStorage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMember="Name"
                                              IsEnabled="{Binding IsEditing}"
                                              NullText="Seleccione una bodega (opcional)"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Sección: Orígenes contables del documento -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                        <TextBlock Text="ORÍGENES CONTABLES DEL DOCUMENTO DE TRASLADO" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource SectionDivider}"/>

                        <StackPanel>
                            <TextBlock Text="Origen contable del documento de traslado" Style="{StaticResource FieldLabel}"/>
                            <dxe:ComboBoxEdit Style="{StaticResource ConfigCombo}"
                                              ItemsSource="{Binding AccountingSources}"
                                              EditValue="{Binding SelectedTransferDocAccountingSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMember="Name"
                                              IsEnabled="{Binding IsEditing}"
                                              NullText="Seleccione un origen contable (opcional)"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Sección: Movimientos de bodega -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,16">
                        <TextBlock Text="MOVIMIENTOS DE BODEGA Y TRÁNSITO" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource SectionDivider}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Fila 1 -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,10">
                                <TextBlock Text="Salida (bodega origen)" Style="{StaticResource FieldLabel}"/>
                                <dxe:ComboBoxEdit Style="{StaticResource ConfigCombo}"
                                                  ItemsSource="{Binding AccountingSources}"
                                                  EditValue="{Binding SelectedTransferSourceOutAccountingSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMember="Name"
                                                  IsEnabled="{Binding IsEditing}"
                                                  NullText="Seleccione un origen contable (opcional)"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,10">
                                <TextBlock Text="Entrada (bodega destino)" Style="{StaticResource FieldLabel}"/>
                                <dxe:ComboBoxEdit Style="{StaticResource ConfigCombo}"
                                                  ItemsSource="{Binding AccountingSources}"
                                                  EditValue="{Binding SelectedTransferDestinationInAccountingSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMember="Name"
                                                  IsEnabled="{Binding IsEditing}"
                                                  NullText="Seleccione un origen contable (opcional)"/>
                            </StackPanel>

                            <!-- Fila 2 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="Salida en tránsito" Style="{StaticResource FieldLabel}"/>
                                <dxe:ComboBoxEdit Style="{StaticResource ConfigCombo}"
                                                  ItemsSource="{Binding AccountingSources}"
                                                  EditValue="{Binding SelectedTransferTransitOutAccountingSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMember="Name"
                                                  IsEnabled="{Binding IsEditing}"
                                                  NullText="Seleccione un origen contable (opcional)"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="Entrada en tránsito" Style="{StaticResource FieldLabel}"/>
                                <dxe:ComboBoxEdit Style="{StaticResource ConfigCombo}"
                                                  ItemsSource="{Binding AccountingSources}"
                                                  EditValue="{Binding SelectedTransferTransitInAccountingSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMember="Name"
                                                  IsEnabled="{Binding IsEditing}"
                                                  NullText="Seleccione un origen contable (opcional)"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Botones -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <!-- Editar -->
                        <Border Style="{StaticResource ActionButtonBorder}">
                            <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"
                                    ToolTip="Editar la configuración"
                                    IsEnabled="{Binding CanEdit}"
                                    Command="{Binding EditCommand}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Source="{dx:DXImage 'Images/Edit/Edit_32x32.png'}" Width="32" Height="32"
                                           HorizontalAlignment="Center" Style="{StaticResource ActionButtonImage}"/>
                                    <TextBlock Text="Editar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <!-- Deshacer -->
                        <Border Style="{StaticResource ActionButtonBorder}">
                            <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"
                                    ToolTip="Deshacer cambios y salir del modo edición"
                                    IsEnabled="{Binding IsEditing}"
                                    Command="{Binding UndoCommand}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Source="{dx:DXImage 'Images/History/Undo_32x32.png'}" Width="32" Height="32"
                                           HorizontalAlignment="Center" Style="{StaticResource ActionButtonImage}"/>
                                    <TextBlock Text="Deshacer" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <!-- Guardar -->
                        <Border Style="{StaticResource ActionButtonBorder}">
                            <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"
                                    ToolTip="Guardar cambios"
                                    IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}"
                                    Command="{Binding SaveCommand}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32"
                                           HorizontalAlignment="Center" Style="{StaticResource ActionButtonImage}"/>
                                    <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </StackPanel>
                </Grid>
            </busyIndicator:BusyMask>
        </Border>
    </Grid>
</UserControl>
