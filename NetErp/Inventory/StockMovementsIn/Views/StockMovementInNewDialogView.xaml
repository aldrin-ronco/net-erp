<UserControl x:Class="NetErp.Inventory.StockMovementsIn.Views.StockMovementInNewDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:h="clr-namespace:NetErp.Helpers"
             mc:Ignorable="d"
             Width="{Binding DialogWidth}"
             Background="#EEF1F5">
    <UserControl.Resources>
        <Style x:Key="FocusComboBoxEdit" TargetType="dxe:ComboBoxEdit">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="KeyboardFocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="-2" StrokeThickness="2" Stroke="#1565C0" RadiusX="4" RadiusY="4" SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="13,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1565C0"/>
                                <Setter TargetName="Bd" Property="Background" Value="#EBF5FB"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F7FB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="8,0,8,8">
        <Grid Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Centro de costo" FontSize="13" Margin="0,0,0,3"/>
                <dxe:ComboBoxEdit Style="{StaticResource FocusComboBoxEdit}"
                                  TabIndex="1"
                                  ItemsSource="{Binding CostCenters}"
                                  SelectedItem="{Binding SelectedCostCenter, Mode=TwoWay}"
                                  DisplayMember="Name"
                                  IsTextEditable="False"
                                  Padding="2"
                                  BorderBrush="#C8CED6"
                                  h:FocusBehavior.IsFocused="True"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="Fuente contable" FontSize="13" Margin="0,0,0,3"/>
                <dxe:ComboBoxEdit Style="{StaticResource FocusComboBoxEdit}"
                                  TabIndex="2"
                                  ItemsSource="{Binding AccountingSources}"
                                  SelectedItem="{Binding SelectedAccountingSource, Mode=TwoWay}"
                                  DisplayMember="Name"
                                  IsTextEditable="False"
                                  Padding="2"
                                  BorderBrush="#C8CED6"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,8">
                <TextBlock Text="Bodega" FontSize="13" Margin="0,0,0,3"/>
                <dxe:ComboBoxEdit Style="{StaticResource FocusComboBoxEdit}"
                                  TabIndex="3"
                                  ItemsSource="{Binding Storages}"
                                  SelectedItem="{Binding SelectedStorage, Mode=TwoWay}"
                                  DisplayMember="Name"
                                  IsTextEditable="False"
                                  Padding="2"
                                  BorderBrush="#C8CED6"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,8">
                <TextBlock Text="Nota" FontSize="13" Margin="0,0,0,3"/>
                <dxe:TextEdit Style="{StaticResource FocusedHighlightStyle}"
                              TabIndex="4"
                              Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              TextWrapping="Wrap"
                              AcceptsReturn="True"
                              VerticalContentAlignment="Top"
                              HorizontalContentAlignment="Left"
                              VerticalScrollBarVisibility="Visible"
                              MinHeight="60"
                              Padding="3"
                              BorderBrush="#C8CED6"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                <Border Margin="4,0" CornerRadius="4" BorderThickness="2" Padding="0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#1565C0"/>
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Button x:Name="BtnSave" TabIndex="5" Padding="13,3"
                            FocusVisualStyle="{x:Null}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            cal:Message.Attach="SaveAsync" IsEnabled="{Binding CanSave}">
                        <StackPanel HorizontalAlignment="Center" Focusable="False">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" Focusable="False">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.7"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                        </StackPanel>
                    </Button>
                </Border>
                <Border Margin="4,0" CornerRadius="4" BorderThickness="2" Padding="0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#1565C0"/>
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Button x:Name="BtnCancel" TabIndex="6" Padding="13,3" IsCancel="True"
                            FocusVisualStyle="{x:Null}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            cal:Message.Attach="CancelAsync">
                        <StackPanel HorizontalAlignment="Center" Focusable="False">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" Focusable="False"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                        </StackPanel>
                    </Button>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
