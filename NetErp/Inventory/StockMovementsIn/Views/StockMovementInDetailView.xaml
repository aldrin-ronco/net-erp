<UserControl x:Class="NetErp.Inventory.StockMovementsIn.Views.StockMovementInDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:currency="clr-namespace:CurrencyTextBoxControl;assembly=CurrencyTextbox"
             xmlns:editor="clr-namespace:NetErp.UserControls.ItemDimensionEditor.Views"
             xmlns:dto="clr-namespace:NetErp.Inventory.StockMovementsIn.DTO"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <h:SimpleBooleanConverter x:Key="SimpleBooleanConverter" True="False" False="True"/>
    </UserControl.Resources>

    <busyIndicator:BusyMask IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="5">
            <Grid Margin="15,15,15,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header readonly -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="Centro de costo" FontSize="13" Foreground="Gray"/>
                        <TextBlock Text="{Binding CostCenterName}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4,0,4,0">
                        <TextBlock Text="Bodega" FontSize="13" Foreground="Gray"/>
                        <TextBlock Text="{Binding StorageName}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="4,0,4,0">
                        <TextBlock Text="Fuente contable" FontSize="13" Foreground="Gray"/>
                        <TextBlock Text="{Binding AccountingSourceName}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="4,0,4,0">
                        <TextBlock Text="Fecha y hora" FontSize="13" Foreground="Gray"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DocumentDate}" FontSize="13"/>
                            <TextBlock Text="  "/>
                            <TextBlock Text="{Binding DocumentTime}" FontSize="13" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Margin="4,0,0,0">
                        <TextBlock Text="Documento" FontSize="13" Foreground="Gray"/>
                        <TextBlock Text="{Binding DocumentDisplay}" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>


                <!-- UC ItemDimensionEditor: búsqueda + panel info + qty + dimensiones.
                     Caller (Detail) inyecta costo + botón Agregar via AdditionalContent. -->
                <ContentControl Grid.Row="1" Margin="0,0,0,8"
                                Visibility="{Binding IsDraft, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <editor:ItemDimensionEditorView DataContext="{Binding Editor}">
                        <editor:ItemDimensionEditorView.AdditionalContent>
                            <StackPanel MinWidth="140" Margin="0,0,8,0"
                                        DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}">
                                <TextBlock Text="Costo unitario" FontSize="13" Foreground="Gray"/>
                                <dxe:TextEdit TabIndex="3" Height="28"
                                              MaskType="Numeric"
                                              Mask="C2"
                                              MaskUseAsDisplayFormat="True"
                                              Padding="3"
                                              BorderBrush="#C8CED6"
                                              VerticalContentAlignment="Center"
                                              HorizontalContentAlignment="Right"
                                              EditValue="{Binding LineUnitCost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <h:FocusBehavior.IsFocused>
                                        <Binding Path="LineUnitCostFocus" Mode="TwoWay"/>
                                    </h:FocusBehavior.IsFocused>
                                </dxe:TextEdit>
                            </StackPanel>
                        </editor:ItemDimensionEditorView.AdditionalContent>
                        <editor:ItemDimensionEditorView.TrailingContent>
                            <StackPanel DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}">
                                <TextBlock Text=" " FontSize="11"/>
                                <Border CornerRadius="4" BorderThickness="2" Padding="0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#C8CED6"/>
                                            <Setter Property="Background" Value="White"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                    <Setter Property="BorderBrush" Value="#1565C0"/>
                                                    <Setter Property="Background" Value="#EBF5FB"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Button TabIndex="5" Height="28" Padding="10,0"
                                            ToolTip="Agregar línea al documento"
                                            FocusVisualStyle="{x:Null}"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            IsEnabled="{Binding CanTryCommitLine}"
                                            cal:Message.Attach="TryCommitLineAsync">
                                        <StackPanel Orientation="Horizontal" Focusable="False">
                                            <Image Source="{dx:DXImage 'Images/Actions/Add_16x16.png'}" Width="16" Height="16" Margin="0,0,6,0" Focusable="False">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="Agregar" VerticalAlignment="Center" Focusable="False"/>
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </StackPanel>
                        </editor:ItemDimensionEditorView.TrailingContent>
                    </editor:ItemDimensionEditorView>
                </ContentControl>

                <!-- Grid líneas WPF DataGrid — modelo edit nativo, sin pencil persistente -->
                <DataGrid x:Name="LinesGrid"
                          Grid.Row="2"
                          ItemsSource="{Binding Lines}"
                          SelectedItem="{Binding SelectedLine, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          CanUserReorderColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EAECEF"
                          AlternatingRowBackground="#FAF9F2"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          SelectionUnit="CellOrRowHeader"
                          BorderBrush="#D9DDE3"
                          BorderThickness="1"
                          ScrollViewer.CanContentScroll="False"
                          PreviewKeyDown="LinesGrid_PreviewKeyDown"
                          PreparingCellForEdit="LinesGrid_PreparingCellForEdit"
                          BeginningEdit="LinesGrid_BeginningEdit"
                          MouseDoubleClick="LinesGrid_MouseDoubleClick">
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:OperationStatus.Pending}">
                                    <Setter Property="Background" Value="#FFEED0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:OperationStatus.Retrying}">
                                    <Setter Property="Background" Value="#FFE4B5"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:OperationStatus.Saved}">
                                    <Setter Property="Background" Value="#E0FFE0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:OperationStatus.Failed}">
                                    <Setter Property="Background" Value="#FFE0E0"/>
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D6E9F8"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:OperationStatus.Pending}">
                                    <Setter Property="Background" Value="#FFEED0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:OperationStatus.Retrying}">
                                    <Setter Property="Background" Value="#FFE4B5"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:OperationStatus.Saved}">
                                    <Setter Property="Background" Value="#E0FFE0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static dto:OperationStatus.Failed}">
                                    <Setter Property="Background" Value="#FFE0E0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Resources>
                        <Style x:Key="ReadOnlyTextStyle" TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Top"/>
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                        <Style x:Key="HeaderLeftStyle" TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Width="90" Binding="{Binding Item.Code}" IsReadOnly="True" ElementStyle="{StaticResource ReadOnlyTextStyle}"/>
                        <DataGridTextColumn Header="Referencia" Width="120" Binding="{Binding Item.Reference}" IsReadOnly="True" ElementStyle="{StaticResource ReadOnlyTextStyle}"/>
                        <DataGridTemplateColumn Header="Nombre del ítem" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource HeaderLeftStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6,4" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Item.Name}" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                                        <!-- Tallas: tabla bullet | nombre | qty | UND -->
                                        <ItemsControl ItemsSource="{Binding SizeRows}" Margin="12,2,0,0"
                                                      Visibility="{Binding IsSize, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="•" FontSize="11" Foreground="#5F6B7A"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding SizeName}" FontSize="11" Foreground="#5F6B7A"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Quantity, StringFormat=N2}" TextAlignment="Right" FontSize="11" Foreground="#5F6B7A"/>
                                                        <TextBlock Grid.Column="3" Margin="6,0,0,0" FontSize="11" Foreground="#5F6B7A"
                                                                   Text="{Binding DataContext.Item.MeasurementUnit.Abbreviation, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Lotes: tabla bullet | lote | qty | UND | vence -->
                                        <ItemsControl ItemsSource="{Binding LotRows}" Margin="12,2,0,0"
                                                      Visibility="{Binding IsLot, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="•" FontSize="11" Foreground="#5F6B7A"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding LotNumber}" FontSize="11" Foreground="#5F6B7A" FontFamily="Consolas"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Quantity, StringFormat=N2}" TextAlignment="Right" FontSize="11" Foreground="#5F6B7A"/>
                                                        <TextBlock Grid.Column="3" Margin="6,0,0,0" FontSize="11" Foreground="#5F6B7A"
                                                                   Text="{Binding DataContext.Item.MeasurementUnit.Abbreviation, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                                                        <TextBlock Grid.Column="4" Margin="12,0,0,0" FontSize="11" Foreground="#5F6B7A"
                                                                   Text="{Binding ExpirationDate, StringFormat='vence yyyy-MM-dd', TargetNullValue='sin vencimiento'}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Seriales: tabla 4 columnas -->
                                        <ItemsControl ItemsSource="{Binding SerialRows}" Margin="12,2,0,0"
                                                      Visibility="{Binding IsSerial, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="5"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,8,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="•" FontSize="11" Foreground="#5F6B7A"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding SerialNumber}" FontFamily="Consolas" FontSize="11" Foreground="#5F6B7A" TextTrimming="CharacterEllipsis" ToolTip="{Binding SerialNumber}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn x:Name="QuantityColumn" Header="Cantidad" Width="108">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding QuantityDisplay}" TextAlignment="Right" Padding="3"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <dxe:TextEdit MaskType="Numeric"
                                                  Mask="{Binding QuantityMask}"
                                                  MaskUseAsDisplayFormat="True"
                                                  EditValue="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                  VerticalContentAlignment="Center"
                                                  HorizontalContentAlignment="Right"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="UND" Width="60" Binding="{Binding Item.MeasurementUnit.Abbreviation}" IsReadOnly="True" ElementStyle="{StaticResource ReadOnlyTextStyle}"/>
                        <DataGridTemplateColumn Header="Costo unitario" Width="126">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding UnitCost, StringFormat=C, TargetNullValue=0}" TextAlignment="Right" Padding="3"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <dxe:TextEdit MaskType="Numeric"
                                                  Mask="C2"
                                                  MaskUseAsDisplayFormat="True"
                                                  EditValue="{Binding UnitCost, Mode=TwoWay, UpdateSourceTrigger=LostFocus, TargetNullValue=0, FallbackValue=0}"
                                                  VerticalContentAlignment="Center"
                                                  HorizontalContentAlignment="Right"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Subtotal" Width="136" Binding="{Binding Subtotal, StringFormat=N2}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="3"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Nota: multi-line con scroll, auto-save al perder foco. Indicador status. -->
                <StackPanel Grid.Row="3" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Observación" FontSize="13" Foreground="Gray"/>
                        <Ellipse Width="8" Height="8" Margin="6,0,0,0"
                                 VerticalAlignment="Center"
                                 Fill="{Binding NoteStatusBrush}"/>
                    </StackPanel>
                    <dxe:TextEdit Style="{StaticResource FocusedHighlightStyle}"
                                  Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsReadOnly="{Binding IsDraft, Converter={StaticResource SimpleBooleanConverter}}"
                                  MaxLength="{Binding NoteMaxLength}"
                                  TextWrapping="Wrap"
                                  AcceptsReturn="True"
                                  VerticalContentAlignment="Top"
                                  HorizontalContentAlignment="Left"
                                  VerticalScrollBarVisibility="Visible"
                                  MinHeight="42"
                                  Padding="3" BorderBrush="#C8CED6"/>
                </StackPanel>

                <!-- Botones -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <Border Margin="4,0" CornerRadius="4" BorderThickness="2" Padding="0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="BorderBrush" Value="#1565C0"/>
                                        <Setter Property="Background" Value="#EBF5FB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button x:Name="BtnPost" cal:Message.Attach="PostAsync" IsEnabled="{Binding CanPost}"
                                ToolTip="Postear documento"
                                FocusVisualStyle="{x:Null}"
                                Background="Transparent" BorderThickness="0" Padding="13,3" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" Focusable="False">
                                <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" Focusable="False">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.7"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Postear" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                            </StackPanel>
                        </Button>
                    </Border>
                    <Border Margin="4,0" CornerRadius="4" BorderThickness="2" Padding="0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="BorderBrush" Value="#1565C0"/>
                                        <Setter Property="Background" Value="#EBF5FB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button x:Name="BtnClose" cal:Message.Attach="CloseAsync" IsCancel="True"
                                ToolTip="Cerrar y volver al listado"
                                FocusVisualStyle="{x:Null}"
                                Background="Transparent" BorderThickness="0" Padding="13,3" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" Focusable="False">
                                <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" Focusable="False"/>
                                <TextBlock Text="Cerrar" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
