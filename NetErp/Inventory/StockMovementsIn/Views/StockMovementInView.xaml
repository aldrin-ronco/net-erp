<UserControl x:Class="NetErp.Inventory.StockMovementsIn.Views.StockMovementInView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:s="clr-namespace:NetErp.Helpers.Shortcuts"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:uc="clr-namespace:NetErp.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="ShortcutBadge" TargetType="Border">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Margin" Value="0,0,-2,8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <s:CommandList x:Key="MasterShortcuts">
            <x:Static Member="s:AppCommands.New"/>
            <x:Static Member="s:AppCommands.Edit"/>
            <x:Static Member="s:AppCommands.Post"/>
            <x:Static Member="s:AppCommands.Annul"/>
            <x:Static Member="s:AppCommands.Delete"/>
            <x:Static Member="s:AppCommands.Refresh"/>
            <x:Static Member="s:AppCommands.Search"/>
            <x:Static Member="s:AppCommands.FocusGrid"/>
        </s:CommandList>
        <Style x:Key="ActionButtonBorder" TargetType="Border">
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#1565C0"/>
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Detail (cuando hay) -->
        <ContentControl x:Name="CurrentDetail"
                        Visibility="{Binding IsDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <!-- Master -->
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1" CornerRadius="8" Margin="5"
                Visibility="{Binding IsMasterVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                s:Shortcuts.Enabled="{StaticResource MasterShortcuts}" Focusable="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Filtros: línea única -->
            <Grid Grid.Row="0" Margin="10,10,10,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="176"/>
                    <ColumnDefinition Width="144"/>
                    <ColumnDefinition Width="144"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <TextBlock Text="Documento" FontSize="13" Margin="0,0,0,3"/>
                    <Grid>
                        <dxe:ButtonEdit x:Name="FilterDocumentNumber"
                                        Text="{Binding FilterDocumentNumber, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                        NullText="Número de documento"
                                        ToolTip="Buscar (Ctrl+F)"
                                        MinHeight="25"
                                        CharacterCasing="Upper"
                                        BorderBrush="#C8CED6"
                                        AllowDefaultButton="False">
                            <dxe:ButtonEdit.Buttons>
                                <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                            </dxe:ButtonEdit.Buttons>
                        </dxe:ButtonEdit>
                        <Border IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ShortcutBadge}">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0,0,4,0"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsCtrlHeld, Source={x:Static s:ShortcutHintState.Instance}}" Value="True"/>
                                                <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="⌃F" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="4,0,4,0">
                    <TextBlock Text="Centro de costo" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:ComboBoxEdit ItemsSource="{Binding CostCenters}"
                                      SelectedItem="{Binding FilterCostCenter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      DisplayMember="Name"
                                      IsTextEditable="False"
                                      Padding="2"
                                      BorderBrush="#C8CED6"
                                      AllowNullInput="True"
                                      NullValueButtonPlacement="EditBox"
                                      NullText="Todos"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="4,0,4,0">
                    <TextBlock Text="Fuente contable" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:ComboBoxEdit ItemsSource="{Binding AccountingSources}"
                                      SelectedItem="{Binding FilterAccountingSource, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      DisplayMember="Name"
                                      IsTextEditable="False"
                                      Padding="2"
                                      BorderBrush="#C8CED6"
                                      AllowNullInput="True"
                                      NullValueButtonPlacement="EditBox"
                                      NullText="Todas"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="4,0,4,0">
                    <TextBlock Text="Estado" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:ComboBoxEdit ItemsSource="{Binding StatusOptions}"
                                      EditValue="{Binding FilterStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Padding="2" MinWidth="120"
                                      IsTextEditable="False"
                                      BorderBrush="#C8CED6"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="4,0,4,0">
                    <TextBlock Text="Período" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:ComboBoxEdit ItemsSource="{Binding PeriodOptions}"
                                      SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"
                                      DisplayMember="Label"
                                      IsTextEditable="False"
                                      Padding="2"
                                      BorderBrush="#C8CED6"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Margin="4,0,4,0"
                            Visibility="{Binding IsCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Desde" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:DateEdit EditValue="{Binding CustomDateFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  AllowNullInput="True"
                                  NullValueButtonPlacement="EditBox"
                                  NullText="Sin límite inferior"
                                  Padding="2"
                                  BorderBrush="#C8CED6"/>
                </StackPanel>

                <StackPanel Grid.Column="6" Margin="4,0,0,0"
                            Visibility="{Binding IsCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Hasta" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:DateEdit EditValue="{Binding CustomDateTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  AllowNullInput="True"
                                  NullValueButtonPlacement="EditBox"
                                  NullText="Sin límite superior"
                                  Padding="2"
                                  BorderBrush="#C8CED6"/>
                </StackPanel>
            </Grid>

            <!-- Grid -->
            <Grid Grid.Row="1" Margin="10,6,10,0">
            <busyIndicator:BusyMask IsBusy="{Binding IsBusy}"
                                    IndicatorType="BouncingDot"
                                    BusyContent="Por favor espere..."
                                    BusyContentMargin="0,20,0,0">
                <dxg:GridControl x:Name="StockMovementsGrid"
                                 ItemsSource="{Binding StockMovements}"
                                 SelectedItem="{Binding SelectedStockMovement, Mode=TwoWay}"
                                 AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False"
                                       AllowCascadeUpdate="False"
                                       EnableSelectedRowAppearance="True"
                                       ShowGroupPanel="False"
                                       AlternateRowBackground="Beige"
                                       AllowColumnMoving="False">
                            <dxg:TableView.RowStyle>
                                <Style TargetType="dxg:RowControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Row.IsCancelled}" Value="True">
                                            <Setter Property="Foreground" Value="Red"/>
                                            <Setter Property="Opacity" Value="0.8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </dxg:TableView.RowStyle>
                        </dxg:TableView>
                    </dxg:GridControl.View>
                    <dxg:GridColumn Header="Documento" FieldName="DocumentDisplay" Width="108" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RowData.Row.DocumentDisplay, Mode=OneWay}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Estado" FieldName="Status" Width="Auto" HorizontalHeaderContentAlignment="Center"/>
                    <dxg:GridColumn Header="Anulado" FieldName="CancelledWith" Width="105" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value=""/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RowData.Row.CancelledWith}" Value="A">
                                                    <Setter Property="Text" Value="Con documento"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RowData.Row.CancelledWith}" Value="X">
                                                    <Setter Property="Text" Value="Sin documento"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Fuente" FieldName="AccountingSource.Name" Width="*" HorizontalHeaderContentAlignment="Center"/>
                    <dxg:GridColumn Header="Centro de costo" FieldName="CostCenter.Name" Width="Auto" HorizontalHeaderContentAlignment="Center"/>
                    <dxg:GridColumn Header="Bodega" FieldName="Storage.Name" Width="Auto" HorizontalHeaderContentAlignment="Center"/>
                    <dxg:GridColumn Header="Creado por" FieldName="CreatedBy.FullName" Width="*" HorizontalHeaderContentAlignment="Center"/>
                    <dxg:GridColumn Header="Posteado" FieldName="PostedAt" Width="Auto"
                                    HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings DisplayFormat="yyyy-MM-dd HH:mm:ss"
                                                  HorizontalContentAlignment="Center"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Creado" FieldName="InsertedAt" Width="Auto"
                                    HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings DisplayFormat="yyyy-MM-dd HH:mm:ss"
                                                  HorizontalContentAlignment="Center"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </busyIndicator:BusyMask>
            <Border IsHitTestVisible="False">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource ShortcutBadge}">
                        <Setter Property="HorizontalAlignment" Value="Right"/>
                        <Setter Property="VerticalAlignment" Value="Top"/>
                        <Setter Property="Margin" Value="0,4,4,0"/>
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsCtrlHeld, Source={x:Static s:ShortcutHintState.Instance}}" Value="True"/>
                                    <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="⌃G" FontSize="10" FontWeight="Bold" Foreground="White"/>
            </Border>
            </Grid>

            <!-- Note documento seleccionado + bloque anulación condicional -->
            <Grid Grid.Row="2" Margin="10,6,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="*"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedStockMovement.CancelledAt}" Value="{x:Null}">
                                        <Setter Property="Width" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <TextBlock Text="Observación" FontSize="13" Foreground="Gray" Margin="0,0,0,3"/>
                    <dxe:TextEdit Text="{Binding SelectedStockMovement.Note, Mode=OneWay}"
                                  IsReadOnly="True"
                                  TextWrapping="Wrap"
                                  AcceptsReturn="True"
                                  VerticalContentAlignment="Top"
                                  HorizontalContentAlignment="Left"
                                  VerticalScrollBarVisibility="Visible"
                                  MinHeight="42"
                                  MaxHeight="80"
                                  Padding="3"
                                  BorderBrush="#C8CED6"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedStockMovement.CancelledAt}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock FontSize="13" Foreground="#B71C1C" Margin="0,0,0,3" TextWrapping="Wrap">
                        <Run Text="Anulado el "/>
                        <Run Text="{Binding SelectedStockMovement.CancelledAt, StringFormat='dd/MM/yyyy HH:mm', Mode=OneWay}"/>
                        <Run Text=" por "/>
                        <Run Text="{Binding SelectedStockMovement.CancelledBy.FullName, Mode=OneWay}"/>
                    </TextBlock>
                    <dxe:TextEdit Text="{Binding SelectedStockMovement.CancelNote, Mode=OneWay}"
                                  IsReadOnly="True"
                                  TextWrapping="Wrap"
                                  AcceptsReturn="True"
                                  VerticalContentAlignment="Top"
                                  HorizontalContentAlignment="Left"
                                  VerticalScrollBarVisibility="Visible"
                                  MinHeight="42"
                                  MaxHeight="80"
                                  Padding="3"
                                  BorderBrush="#E5B4B4"
                                  Background="#FFF5F5"
                                  Foreground="#B71C1C"/>
                </StackPanel>
            </Grid>

            <uc:GridPaging Grid.Row="3"
                           Margin="10,6,10,0"
                           PageIndex="{Binding PageIndex, Mode=TwoWay}"
                           PageSize="{Binding PageSize, Mode=TwoWay}"
                           TotalCount="{Binding TotalCount, Mode=OneWay}"
                           ResponseTime="{Binding ResponseTime, Mode=OneWay}"/>

            <!-- Botones -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">
                <Border Style="{StaticResource ActionButtonBorder}">
                    <Button cal:Message.Attach="NewAsync"
                            IsEnabled="{Binding CanNew}"
                            ToolTip="Nuevo (Ctrl+N)"
                            FocusVisualStyle="{x:Null}"
                            Background="Transparent" BorderThickness="0" Padding="13,3" Cursor="Hand">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" Focusable="False">
                                <Image Source="{dx:DXImage 'Images/Actions/New_32x32.png'}" Width="32" Height="32" Focusable="False">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.7"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Nuevo" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                   Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasCreatePermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource ShortcutBadge}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCtrlHeld, Source={x:Static s:ShortcutHintState.Instance}}" Value="True"/>
                                                    <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                    <Condition Binding="{Binding HasCreatePermission}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="⌃N" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                    </Button>
                </Border>
                <Border Style="{StaticResource ActionButtonBorder}">
                    <Button cal:Message.Attach="EditAsync" IsEnabled="{Binding CanEdit}"
                            ToolTip="Editar (F2)"
                            FocusVisualStyle="{x:Null}"
                            Background="Transparent" BorderThickness="0" Padding="13,3" Cursor="Hand">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" Focusable="False">
                                <Image Source="{dx:DXImage 'Images/Edit/Edit_32x32.png'}" Width="32" Height="32" Focusable="False">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.7"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Editar" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                   Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEditPermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource ShortcutBadge}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCtrlHeld, Source={x:Static s:ShortcutHintState.Instance}}" Value="True"/>
                                                    <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                    <Condition Binding="{Binding HasEditPermission}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="F2" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                    </Button>
                </Border>
                <Border Style="{StaticResource ActionButtonBorder}">
                    <Button cal:Message.Attach="PostAsync" IsEnabled="{Binding CanPost}"
                            ToolTip="Postear (F9)"
                            FocusVisualStyle="{x:Null}"
                            Background="Transparent" BorderThickness="0" Padding="13,3" Cursor="Hand">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" Focusable="False">
                                <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" Focusable="False">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.7"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Postear" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                   Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPostPermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource ShortcutBadge}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCtrlHeld, Source={x:Static s:ShortcutHintState.Instance}}" Value="True"/>
                                                    <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                    <Condition Binding="{Binding HasPostPermission}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="F9" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                    </Button>
                </Border>
                <Border Style="{StaticResource ActionButtonBorder}">
                    <Button cal:Message.Attach="CancelAsync" IsEnabled="{Binding CanCancel}"
                            ToolTip="Anular (Ctrl+Shift+X)"
                            FocusVisualStyle="{x:Null}"
                            Background="Transparent" BorderThickness="0" Padding="13,3" Cursor="Hand">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" Focusable="False">
                                <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" Focusable="False">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.7"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Anular" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                   Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAnnulPermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource ShortcutBadge}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCtrlHeld, Source={x:Static s:ShortcutHintState.Instance}}" Value="True"/>
                                                    <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                    <Condition Binding="{Binding HasAnnulPermission}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="⌃⇧X" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                    </Button>
                </Border>
                <Border Style="{StaticResource ActionButtonBorder}">
                    <Button cal:Message.Attach="DeleteDraftAsync" IsEnabled="{Binding CanDelete}"
                            ToolTip="Eliminar (Del)"
                            FocusVisualStyle="{x:Null}"
                            Background="Transparent" BorderThickness="0" Padding="13,3" Cursor="Hand">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" Focusable="False">
                                <Image Source="{dx:DXImage 'Images/Actions/DeleteList_32x32.png'}" Width="32" Height="32" Focusable="False">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.7"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Eliminar" HorizontalAlignment="Center" Margin="0,4,0,0" Focusable="False"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                   Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDeletePermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource ShortcutBadge}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCtrlHeld, Source={x:Static s:ShortcutHintState.Instance}}" Value="True"/>
                                                    <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                    <Condition Binding="{Binding HasDeletePermission}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="Del" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                    </Button>
                </Border>
            </StackPanel>
        </Grid>
        </Border>
    </Grid>
</UserControl>
