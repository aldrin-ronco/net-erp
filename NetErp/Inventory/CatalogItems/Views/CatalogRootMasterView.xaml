                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Descontinuar item: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Path=Data.DeleteItemCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanDeleteItem, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Delete_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
