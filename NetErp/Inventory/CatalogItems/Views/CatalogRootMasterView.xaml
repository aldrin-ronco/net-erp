<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:uc="clr-namespace:NetErp.UserControls"
             xmlns:model="clr-namespace:NetErp.Inventory.CatalogItems.DTO"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:views="clr-namespace:NetErp.Inventory.CatalogItems.Views"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             x:Class="NetErp.Inventory.CatalogItems.Views.CatalogRootMasterView"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900" Focusable="False">
    <UserControl.Resources>
        <h:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- CatalogDTO template (root level) -->
        <HierarchicalDataTemplate DataType="{x:Type model:CatalogDTO}" ItemsSource="{Binding ItemTypes}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0" VerticalAlignment="Center" Background="Transparent">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="{Binding Path=Data.NewCatalogCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanNewCatalog, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Actions/AddItem_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasCatalogCreatePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <TextBlock Text="Crear un nuevo catálogo"/>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Path=Data.NewItemTypeCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanNewItemType, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Actions/AddItem_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasItemTypeCreatePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <TextBlock Text="Crear un nuevo tipo de item"/>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Path=Data.EditCatalogCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanEditCatalog, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Edit_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasCatalogEditPermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Editar catálogo: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Path=Data.DeleteCatalogCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanDeleteCatalog, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Delete_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasCatalogDeletePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Eliminar catálogo: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18" VerticalAlignment="Center"
                       Source="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderClose.svg'}"/>
                <TextBlock Text="{Binding Row.Name}" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- ItemTypeDTO template -->
        <HierarchicalDataTemplate DataType="{x:Type model:ItemTypeDTO}" ItemsSource="{Binding ItemCategories}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0" VerticalAlignment="Center" Background="Transparent">
