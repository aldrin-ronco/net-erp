                                    <TextBlock Text="Editar sub categoría: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Path=Data.DeleteItemSubCategoryCommand, Source={StaticResource DataContextProxy}}"
