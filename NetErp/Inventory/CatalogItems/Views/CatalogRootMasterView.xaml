                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasItemSubCategoryDeletePermission, Source={StaticResource DataContextProxy}}" Value="False">
