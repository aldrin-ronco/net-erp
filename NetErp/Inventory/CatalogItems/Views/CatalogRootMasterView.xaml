                                  IsEnabled="{Binding Path=Data.CanDiscontinueItem, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Mail/Inbox_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
