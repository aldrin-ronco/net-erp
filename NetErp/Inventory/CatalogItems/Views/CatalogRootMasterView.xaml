                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Eliminar item: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18"
                       Source="{dx:DXImage 'Images/Miscellaneous/HighlightActiveElements_16x16.png'}"
                       VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Row.Name}" Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="5" Focusable="False">
        <Grid x:Name="MainContainer" Focusable="False">
            <Grid.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Border Background="Black" CornerRadius="7"
                                Width="{Binding ActualWidth, ElementName=MainContainer}"
                                Height="{Binding ActualHeight, ElementName=MainContainer}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Grid.OpacityMask>

            <!-- Empty State — shown only when there are zero catalogs in the system -->
            <uc:EmptyStateView Visibility="{Binding ShowEmptyState, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                               Title="No hay catálogos registrados"
                               Message="Cree un nuevo catálogo para comenzar"
                               ContextInfo="Los catálogos organizan los productos en tipos, categorías y subcategorías para gestionar el inventario de manera estructurada."
                               ButtonText="Crear catálogo"
                               HasPermission="{Binding HasCatalogCreatePermission}"
                               Command="{Binding NewCatalogCommand}"/>

            <!-- Content — tree + item side panel -->
            <Grid Visibility="{Binding HasRecords, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="6*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10,14,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search label -->
                    <TextBlock Grid.Row="0" Text="¿Qué item desea buscar?" Margin="0,0,0,3"/>

                    <!-- Search input -->
                    <dxe:ButtonEdit x:Name="FilterSearch"
                                    Grid.Row="1"
                                    Text="{Binding FilterSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                    NullText="Escribe al menos 4 letras para buscar un item"
                                    ToolTip="Busca por nombre, código, referencia o código de barras"
                                    MinHeight="25"
                                    CharacterCasing="Upper"
                                    BorderBrush="#C8CED6"
                                    AllowDefaultButton="False"
                                    h:FocusBehavior.IsFocused="{Binding FilterSearchIsFocused, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,6">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>

                    <!-- Badge "X resultados" -->
                    <Border Grid.Row="2" Background="#FFF4E5" BorderBrush="#FFA500" BorderThickness="1"
                            CornerRadius="4" Padding="6,3" Margin="0,0,0,6"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock FontSize="11" Foreground="#995E00">
                                    <Run Text="Mostrando"/>
                                    <Run Text="{Binding MatchedItemsCount, Mode=OneWay}" FontWeight="Bold"/>
                                    <Run Text="resultado(s) de búsqueda"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#CC5200" Margin="4,0,0,0"
                                           Text="(limitado, refine la búsqueda)"
                                           Visibility="{Binding MatchedItemsTruncated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Background="Transparent" BorderThickness="0" Padding="3,0,0,0" Cursor="Hand"
                                    Command="{Binding ClearSearchCommand}"
                                    ToolTip="Descartar resultados de búsqueda">
                                <Image Source="{dx:DXImage 'Images/Actions/Cancel_16x16.png'}" Width="14" Height="14"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Tree (with BusyMask scoped only to this row, not the whole view) -->
                    <busyIndicator:BusyMask x:Name="BusyIndicator"
                                            Grid.Row="3"
                                            IsBusy="{Binding IsBusy}"
                                            IndicatorType="BouncingDot"
                                            BusyContent="Por favor espere..."
                                            BusyContentMargin="0,20,0,0"
                                            IsBusyAtStartup="False">
                        <Grid>
                            <dxg:TreeViewControl ItemsSource="{Binding Catalogs}"
                                                 h:TreeViewExtension.SelectItemOnRightClick="True"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 HighlightSelectedNodeIndent="False"
                                                 BorderThickness="0"
                                                 ShowExpandButtons="True"
                                                 ShowBorder="False"
                                                 ExpandStateBinding="{Binding IsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 TreeDerivationMode="HierarchicalDataTemplate">
                                <dxg:TreeViewControl.Style>
                                    <Style TargetType="dxg:TreeViewControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PanelItemDetail.IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </dxg:TreeViewControl.Style>
                                <dxg:TreeViewControl.NodeStyle>
                                    <Style TargetType="dxg:RowControl">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Row.IsExpanded}" Value="True">
                                                <Setter Property="Foreground" Value="Blue"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </dxg:TreeViewControl.NodeStyle>
                            </dxg:TreeViewControl>

                            <!-- Placeholder mostrado mientras se edita un item -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PanelItemDetail.IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Image Source="{dx:DXImage 'Images/Edit/Edit_32x32.png'}" Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                                <TextBlock Text="Editando item" FontSize="16" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="Guarde o cancele los cambios para volver a navegar el árbol"
                                           FontSize="12" Foreground="#AAA" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="260"/>
                            </StackPanel>
                        </Grid>
                    </busyIndicator:BusyMask>
                </Grid>

                <Border Grid.Column="1" Margin="0,10,10,10"
                        BorderBrush="#D9DDE3" BorderThickness="1" CornerRadius="6" Padding="6">
                    <views:ItemDetailPanelView DataContext="{Binding PanelItemDetail}"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
