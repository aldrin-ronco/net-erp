                                  IsEnabled="{Binding Path=Data.CanNewItemCategory, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Actions/AddItem_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasItemCategoryCreatePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <TextBlock Text="Crear una nueva categoría"/>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Path=Data.EditItemTypeCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanEditItemType, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Edit_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasItemTypeEditPermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Editar tipo de item: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Path=Data.DeleteItemTypeCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanDeleteItemType, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Delete_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasItemTypeDeletePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Eliminar tipo de item: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18" VerticalAlignment="Center">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderClose.svg'}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Row.IsExpanded}" Value="True">
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderOpen.svg'}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <TextBlock Text="{Binding Row.Name}" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- ItemCategoryDTO template -->
        <HierarchicalDataTemplate DataType="{x:Type model:ItemCategoryDTO}" ItemsSource="{Binding SubCategories}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0" Background="Transparent">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="{Binding Path=Data.NewItemSubCategoryCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanNewItemSubCategory, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Actions/AddItem_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasItemSubCategoryCreatePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <TextBlock Text="Crear una nueva sub categoría"/>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Path=Data.EditItemCategoryCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanEditItemCategory, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Edit_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasItemCategoryEditPermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Editar categoría: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Path=Data.DeleteItemCategoryCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanDeleteItemCategory, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Delete_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Data.HasItemCategoryDeletePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Eliminar categoría: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18" VerticalAlignment="Center">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderClose.svg'}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Row.IsExpanded}" Value="True">
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderOpen.svg'}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <TextBlock Text="{Binding Row.Name}" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- ItemSubCategoryDTO template -->
        <HierarchicalDataTemplate DataType="{x:Type model:ItemSubCategoryDTO}" ItemsSource="{Binding Items}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0" Background="Transparent">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="{Binding Path=Data.NewItemCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Path=Data.CanNewItem, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Actions/AddItem_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
