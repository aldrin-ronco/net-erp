<UserControl x:Class="NetErp.Inventory.CatalogItems.Views.ItemTypeDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:h="clr-namespace:NetErp.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="380" d:DesignWidth="520"
             Background="#EEF1F5">
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}"
                Height="{Binding DialogHeight}">
            <Grid Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Nombre" FontSize="13" Margin="0,0,0,3"/>
                            <dxe:TextEdit x:Name="Name"
                                          Style="{StaticResource FocusedHighlightStyle}"
                                          CharacterCasing="Upper"
                                          Padding="3"
                                          MaxLength="{Binding NameMaxLength}"
                                          Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                          BorderBrush="#C8CED6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Prefijo" FontSize="13" Margin="0,0,0,3"/>
                            <dxe:ComboBoxEdit ItemsSource="{Binding AvailablePrefixChars}"
                                              SelectedItem="{Binding PrefixChar, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                              IsTextEditable="False"
                                              IsEnabled="{Binding IsNewRecord}"
                                              Padding="3"
                                              Width="55"
                                              BorderBrush="#C8CED6">
                                <dxe:ComboBoxEdit.Style>
                                    <Style TargetType="dxe:ComboBoxEdit">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="ToolTip" Value="El prefijo no se puede modificar una vez creado el tipo de item"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </dxe:ComboBoxEdit.Style>
                            </dxe:ComboBoxEdit>
                        </StackPanel>
                    </Grid>

                    <dxe:CheckEdit Content="Controla inventario"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   Padding="2"
                                   IsChecked="{Binding StockControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   IsEnabled="{Binding StockControlEnable}"
                                   Margin="0,4,0,8"/>

                    <TextBlock Text="Unidad de medida por defecto" FontSize="13" Margin="0,4,0,3"/>
                    <dxe:ComboBoxEdit ItemsSource="{Binding MeasurementUnits}"
                                      SelectedItem="{Binding SelectedMeasurementUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                      DisplayMember="Name"
                                      IsTextEditable="False"
                                      AllowNullInput="True"
                                      NullText="&lt;&lt; SELECCIONE UNA UNIDAD DE MEDIDA &gt;&gt;"
                                      Padding="2"
                                      BorderBrush="#C8CED6"
                                      Margin="0,0,0,8"/>

                    <TextBlock Text="Grupo contable por defecto" FontSize="13" Margin="0,4,0,3"/>
                    <dxe:ComboBoxEdit ItemsSource="{Binding AccountingGroups}"
                                      SelectedItem="{Binding SelectedAccountingGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                      DisplayMember="Name"
                                      IsTextEditable="False"
                                      AllowNullInput="True"
                                      NullText="&lt;&lt; SELECCIONE UN GRUPO CONTABLE &gt;&gt;"
                                      Padding="2"
                                      BorderBrush="#C8CED6"
                                      Margin="0,0,0,8"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
