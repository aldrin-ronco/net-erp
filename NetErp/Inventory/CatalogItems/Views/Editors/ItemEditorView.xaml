<UserControl x:Class="NetErp.Inventory.CatalogItems.Views.Editors.ItemEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:h="clr-namespace:NetErp.Helpers">
    <UserControl.Resources>
        <h:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tab Control with inline tabs -->
        <dx:DXTabControl Grid.Row="0" Margin="5"
                         SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

            <!-- Tab 1: Básicos -->
            <dx:DXTabItem Header="Básicos">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              IsEnabled="{Binding IsEditing, UpdateSourceTrigger=PropertyChanged}" Focusable="False">
                    <Grid Margin="10"
                          FocusManager.FocusedElement="{Binding ElementName=NameTextEdit}"
                          IsEnabledChanged="OnFormIsEnabledChanged">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Images Gallery -->
                        <dxlc:TileLayoutControl Background="{x:Null}" Grid.Row="0" Grid.ColumnSpan="2" 
                                                ItemsSource="{Binding Images, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                HorizontalAlignment="Center" Orientation="Horizontal"
                                                Padding="0" BreakFlowToFit="False" VerticalAlignment="Center">
                            <dxlc:TileLayoutControl.ItemTemplate>
                                <DataTemplate>
                                    <dxlc:Tile Size="Small" Content="{Binding}" Background="White"
                                               VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <dxlc:Tile.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Eliminar imagen"
                                                          Command="{Binding Data.DeleteImageCommand, Source={StaticResource DataContextProxy}}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Icon>
                                                        <Image Source="{dx:DXImage 'Images/Edit/Delete_16x16.png'}"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </dxlc:Tile.ContextMenu>
                                        <dxlc:Tile.ContentTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Image Source="{Binding SourceImage, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </dxlc:Tile.ContentTemplate>
                                    </dxlc:Tile>
                                </DataTemplate>
                            </dxlc:TileLayoutControl.ItemTemplate>
                        </dxlc:TileLayoutControl>

                        <!-- Add Image Button -->
                        <Button Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="0,5,0,10"
                                Command="{Binding AddImageCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Agregar imagen" VerticalAlignment="Center"/>
                                <Image Source="pack://application:,,,/DevExpress.Images.v25.2;component/Images/Actions/Add_32x32.png"
                                       VerticalAlignment="Center" Width="16" Height="16" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Código (read-only, oculto para nuevos registros) -->
                        <TextBlock Text="Código" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Right"
                                   Margin="0,0,5,0" VerticalAlignment="Center"
                                   Visibility="{Binding IsNewRecord, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}"/>
                        <dxe:TextEdit Grid.Row="2" Grid.Column="1"
                                      Text="{Binding Code, Mode=OneWay}"
                                      IsReadOnly="True" Margin="0,0,0,5" CharacterCasing="Upper"
                                      Visibility="{Binding IsNewRecord, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}"/>

                        <!-- Nombre -->
                        <TextBlock Text="Nombre" Grid.Row="3" Grid.Column="0" HorizontalAlignment="Right"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <dxe:TextEdit x:Name="NameTextEdit" Grid.Row="3" Grid.Column="1" Margin="0,0,0,5" CharacterCasing="Upper"
                                      MaxLength="{Binding NameMaxLength}"
                                      Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                        <!-- Referencia -->
                        <TextBlock Text="Referencia" Grid.Row="4" Grid.Column="0" HorizontalAlignment="Right"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <dxe:TextEdit Grid.Row="4" Grid.Column="1" Margin="0,0,0,5" CharacterCasing="Upper"
                                      MaxLength="{Binding ReferenceMaxLength}"
                                      Text="{Binding Reference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                        <!-- Unidad de medida -->
                        <TextBlock Text="Unidad de medida" Grid.Row="5" Grid.Column="0" HorizontalAlignment="Right"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <dxe:ComboBoxEdit Grid.Row="5" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,0,5"
                                          ItemsSource="{Binding MeasurementUnits}"
                                          DisplayMember="Name"
                                          SelectedItem="{Binding SelectedMeasurementUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                          IsTextEditable="False"/>

                        <!-- Marca -->
                        <TextBlock Text="Marca" Grid.Row="6" Grid.Column="0" HorizontalAlignment="Right"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <dxe:ComboBoxEdit Grid.Row="6" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,0,5"
                                          ItemsSource="{Binding ItemBrands}"
                                          DisplayMember="Name"
                                          SelectedItem="{Binding SelectedBrand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsTextEditable="False"
                                          NullText="SELECCIONE UNA MARCA"
                                          AllowNullInput="True" NullValueButtonPlacement="EditBox"/>

                        <!-- Grupo de tallaje -->
                        <TextBlock Text="Grupo de tallaje" Grid.Row="7" Grid.Column="0" HorizontalAlignment="Right"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <dxe:ComboBoxEdit Grid.Row="7" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,0,5"
                                          ItemsSource="{Binding Sizes}"
                                          DisplayMember="Name"
                                          SelectedItem="{Binding SelectedSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsTextEditable="False"
                                          NullText="SELECCIONE UN GRUPO DE TALLAJE"
                                          AllowNullInput="True" NullValueButtonPlacement="EditBox"/>

                        <!-- Grupo contable -->
                        <TextBlock Text="Grupo contable" Grid.Row="8" Grid.Column="0" HorizontalAlignment="Right"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <dxe:ComboBoxEdit Grid.Row="8" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,0,5"
                                          ItemsSource="{Binding AccountingGroups}"
                                          DisplayMember="Name"
                                          SelectedItem="{Binding SelectedAccountingGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                          IsTextEditable="False"/>
                    </Grid>
                </ScrollViewer>
            </dx:DXTabItem>

            <!-- Tab 2: Códigos de barras -->
            <dx:DXTabItem Header="Códigos de barras">
                <Grid Margin="10" IsEnabled="{Binding IsEditing, UpdateSourceTrigger=PropertyChanged}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Input + Add button -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding EanCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 CharacterCasing="Upper"/>
                        <Button Grid.Column="1" Margin="5,0,0,0"
                                Command="{Binding AddEanCodeCommand}">
                            <Image Source="{dx:DXImage 'Images/Actions/Add_16x16.png'}" Stretch="None">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value=".5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Button>
                    </Grid>

                    <!-- EanCodes Grid -->
                    <dxg:GridControl Grid.Row="1" Margin="0,8,0,0"
                                     EnableSmartColumnsGeneration="True"
                                     ItemsSource="{Binding EanCodes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AutoGenerateColumns="None"
                                     SelectedItem="{Binding SelectedEanCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <dxg:GridControl.View>
                            <dxg:TableView AllowCascadeUpdate="False"
                                           EnableSelectedRowAppearance="True"
                                           ShowGroupPanel="False"
                                           AlternateRowBackground="Beige"/>
                        </dxg:GridControl.View>

                        <dxg:GridColumn Header="Códigos de barras" Width="*"
                                        Binding="{Binding Mode=OneWay}"/>

                        <dxg:GridColumn Width="Auto">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <Button BorderThickness="0" Padding="3" Margin="3"
                                            Command="{Binding Data.DeleteEanCodeCommand, Source={StaticResource DataContextProxy}}">
                                        <Image Source="{dx:DXImage 'Images/Actions/Trash_16x16.png'}" Stretch="None"/>
                                    </Button>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl>
                </Grid>
            </dx:DXTabItem>

            <!-- Tab 3: Productos relacionados -->
            <dx:DXTabItem Header="Productos relacionados">
                <Grid Margin="10" IsEnabled="{Binding IsEditing, UpdateSourceTrigger=PropertyChanged}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Row 1: Search fields -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Producto" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <dxe:ButtonEdit Grid.Column="1" IsReadOnly="True"
                                        Text="{Binding ComponentName, Mode=OneWay}"
                                        AllowDefaultButton="False"
                                        NullText="Buscar producto o servicio...">
                            <dxe:ButtonEdit.Buttons>
                                <dxe:ButtonInfo GlyphKind="Search" Command="{Binding OpenSearchComponents}"
                                                ToolTip="Buscar producto"/>
                            </dxe:ButtonEdit.Buttons>
                        </dxe:ButtonEdit>

                        <TextBlock Text="Ref." Grid.Column="2" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <dxe:TextEdit Grid.Column="3" IsReadOnly="True" Width="100"
                                      Text="{Binding ComponentReference, Mode=OneWay}"/>

                        <TextBlock Text="Código" Grid.Column="4" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <dxe:TextEdit Grid.Column="5" IsReadOnly="True" Width="100"
                                      Text="{Binding ComponentCode, Mode=OneWay}"/>
                    </Grid>

                    <!-- Row 2: Quantity + Add -->
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Cantidad" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <dxe:SpinEdit x:Name="ComponentQuantitySpinEdit" Grid.Column="1" MinValue="0" Width="100"
                                      Value="{Binding ComponentQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding ComponentQuantityIsEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsFloatValue="{Binding ComponentAllowFraction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabledChanged="OnComponentQuantityIsEnabledChanged">
                            <dxe:SpinEdit.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddComponentCommand}"/>
                            </dxe:SpinEdit.InputBindings>
                        </dxe:SpinEdit>

                        <Button Grid.Column="3" Command="{Binding AddComponentCommand}"
                                Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{dx:DXImage 'Images/Actions/Add_16x16.png'}" Stretch="None" VerticalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value=".5"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Agregar" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Related Products Grid -->
                    <dxg:GridControl Grid.Row="2" Margin="0,8,0,0"
                                     EnableSmartColumnsGeneration="True"
                                     ItemsSource="{Binding Components, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AutoGenerateColumns="None"
                                     SelectedItem="{Binding SelectedComponent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <dxg:GridControl.View>
                            <dxg:TableView AllowCascadeUpdate="False"
                                           EnableSelectedRowAppearance="True"
                                           AllowEditing="False"
                                           ShowGroupPanel="False"
                                           AlternateRowBackground="Beige"/>
                        </dxg:GridControl.View>

                        <dxg:GridColumn Header="Nombre del producto" Width="*"
                                        Binding="{Binding Component.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <dxg:GridColumn Header="Referencia" Width="*"
                                        Binding="{Binding Component.Reference, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <dxg:GridColumn Header="Código" Width="*"
                                        Binding="{Binding Component.Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <dxg:GridColumn Header="Cantidad" Width="*"
                                        Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <dxg:GridColumn Header="Unidad de medida" Width="*"
                                        Binding="{Binding Component.MeasurementUnit.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <dxg:GridColumn Width="Auto">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <Button BorderThickness="0" Padding="3" Margin="3"
                                            Command="{Binding Data.DeleteComponentCommand, Source={StaticResource DataContextProxy}}">
                                        <Image Source="{dx:DXImage 'Images/Actions/Trash_16x16.png'}" Stretch="None"/>
                                    </Button>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl>
                </Grid>
            </dx:DXTabItem>

            <!-- Tab 4: Otros datos -->
            <dx:DXTabItem Header="Otros datos">
                <Grid Margin="10" IsEnabled="{Binding IsEditing, UpdateSourceTrigger=PropertyChanged}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <dxe:CheckEdit Content="Registrar información extendida" Grid.Row="0" Margin="0,5"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   IsChecked="{Binding HasExtendedInformation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <dxe:CheckEdit Content="Permitir fracción" Grid.Row="1" Margin="0,5"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   IsChecked="{Binding AllowFraction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <dxe:CheckEdit Content="Servicio basado en AIU" Grid.Row="2" Margin="0,5"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   IsChecked="{Binding AiuBasedService, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <dxe:CheckEdit Content="Aplica para venta" Grid.Row="3" Margin="0,5"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   IsChecked="{Binding Billable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <dxe:CheckEdit Content="Cantidad controlada por báscula en la venta" Grid.Row="4" Margin="0,5"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   IsChecked="{Binding AmountBasedOnWeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </dx:DXTabItem>
        </dx:DXTabControl>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,15">
            <Button Command="{Binding EditCommand}" IsEnabled="{Binding MasterCanEdit}"
                    Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                <StackPanel HorizontalAlignment="Center">
                    <Image Source="{dx:DXImage 'Images/Edit/Edit_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Editar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding UndoCommand}" IsEnabled="{Binding MasterCanUndo}"
                    Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                <StackPanel HorizontalAlignment="Center">
                    <Image Source="{dx:DXImage 'Images/History/Undo_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Deshacer" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SaveCommand}" IsEnabled="{Binding MasterCanSave}"
                    Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                <StackPanel HorizontalAlignment="Center">
                    <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
