<UserControl x:Class="NetErp.Treasury.Masters.Views.BankAccountDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="650"
             Background="#EEF1F5">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <h:StringToBooleanConverter x:Key="StringToBooleanConverter"/>
    </UserControl.Resources>
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}"
                Height="{Binding DialogHeight}">
            <Grid Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Banco padre (solo lectura) -->
                        <TextBlock Text="Banco" FontSize="13" Margin="0,0,0,3"/>
                        <dxe:TextEdit Style="{StaticResource FocusedHighlightStyle}"
                                      Padding="3" BorderBrush="#C8CED6"
                                      IsReadOnly="True" Margin="0,0,0,8"
                                      EditValue="{Binding BankName, Mode=OneWay}"/>

                        <!-- Tipo / Proveedor -->
                        <StackPanel Visibility="{Binding IsTraditionalBank, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,8">
                            <TextBlock Text="Tipo de cuenta" FontSize="13" Margin="0,0,0,3"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Ahorros" GroupName="BankAccountType" VerticalAlignment="Center"
                                             Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                             IsChecked="{Binding Type, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=A, UpdateSourceTrigger=PropertyChanged}"/>
                                <RadioButton Content="Corriente" GroupName="BankAccountType" VerticalAlignment="Center" Margin="15,0,0,0"
                                             Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                             IsChecked="{Binding Type, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=C, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsDigitalWallet, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,8">
                            <TextBlock Text="Proveedor" FontSize="13" Margin="0,0,0,3"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="NEQUI" GroupName="WalletProvider" VerticalAlignment="Center"
                                             Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                             IsChecked="{Binding Provider, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=N, UpdateSourceTrigger=PropertyChanged}"/>
                                <RadioButton Content="DAVIPLATA" GroupName="WalletProvider" VerticalAlignment="Center" Margin="15,0,0,0"
                                             Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                             IsChecked="{Binding Provider, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=D, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Número / Referencia -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="{Binding NumberLabel}" FontSize="13" Margin="0,0,0,3"/>
                                <dxe:TextEdit x:Name="Number"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              CharacterCasing="Upper"
                                              Padding="3"
                                              MaxLength="{Binding NumberMaxLength}"
                                              BorderBrush="#C8CED6"
                                              Visibility="{Binding IsTraditionalBank, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              EditValue="{Binding Number, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <dxe:TextEdit x:Name="NumberWallet"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              Padding="3"
                                              BorderBrush="#C8CED6"
                                              MaskType="Simple" Mask="000 000 00 00"
                                              MaskUseAsDisplayFormat="True"
                                              Visibility="{Binding IsDigitalWallet, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              EditValue="{Binding Number, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="Referencia" FontSize="13" Margin="0,0,0,3"/>
                                <dxe:TextEdit Style="{StaticResource FocusedHighlightStyle}"
                                              CharacterCasing="Upper"
                                              Padding="3"
                                              MaxLength="{Binding ReferenceMaxLength}"
                                              BorderBrush="#C8CED6"
                                              EditValue="{Binding Reference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Descripción computada -->
                        <TextBlock Text="Descripción" FontSize="13" Margin="0,0,0,3"/>
                        <dxe:TextEdit Style="{StaticResource FocusedHighlightStyle}"
                                      Padding="3" BorderBrush="#C8CED6"
                                      IsReadOnly="True" Margin="0,0,0,8"
                                      EditValue="{Binding Description, Mode=OneWay}"/>

                        <!-- Cuenta contable: crear automática vs seleccionar existente (opciones excluyentes) -->
                        <TextBlock Text="Cuenta contable" FontSize="13" Margin="0,4,0,3"/>
                        <StackPanel Margin="0,0,0,6" Visibility="{Binding IsNewRecord, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Crear cuenta contable automáticamente"
                                             GroupName="AccountingAccountMode" Padding="4,0,0,0"
                                             Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                             IsChecked="{Binding AccountingAccountAutoCreate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <RadioButton Content="Seleccionar una cuenta contable existente"
                                             GroupName="AccountingAccountMode" Padding="4,0,0,0" Margin="20,0,0,0"
                                             Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                             IsChecked="{Binding AccountingAccountSelectExisting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <TextBlock Text="La cuenta será creada automáticamente al guardar, con el código siguiente disponible."
                                       FontSize="11" Foreground="#6B7280" Margin="20,4,0,0"
                                       Visibility="{Binding ShowAutoCreateDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <dxg:LookUpEdit Padding="3"
                                        AutoPopulateColumns="False"
                                        IsCaseSensitiveSearch="False"
                                        FilterCondition="Contains"
                                        ImmediatePopup="True"
                                        ClearSelectionOnBackspace="True"
                                        NullText="Seleccione una cuenta contable..."
                                        BorderBrush="#C8CED6"
                                        Margin="0,0,0,8"
                                        Visibility="{Binding ShowAccountingAccountLookUp, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        ItemsSource="{Binding AccountingAccounts}"
                                        EditValue="{Binding SelectedAccountingAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        DisplayMember="FullName">
                            <dxg:LookUpEdit.PopupContentTemplate>
                                <ControlTemplate>
                                    <dxg:GridControl Name="PART_GridControl">
                                        <dxg:GridControl.View>
                                            <dxg:TableView AutoWidth="True"/>
                                        </dxg:GridControl.View>
                                        <dxg:GridControl.Columns>
                                            <dxg:GridColumn Header="Código" FieldName="Code" Width="100"/>
                                            <dxg:GridColumn Header="Nombre" FieldName="Name"/>
                                        </dxg:GridControl.Columns>
                                    </dxg:GridControl>
                                </ControlTemplate>
                            </dxg:LookUpEdit.PopupContentTemplate>
                            <dxg:LookUpEdit.ItemsPanel>
                                <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                            </dxg:LookUpEdit.ItemsPanel>
                        </dxg:LookUpEdit>

                        <!-- Método de pago -->
                        <dxe:CheckEdit Content="Habilitar como método de pago"
                                       Style="{StaticResource BlueCheckedTextStyle}" Padding="2" Margin="0,4,0,8"
                                       IsChecked="{Binding EnablePaymentMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Nombre generado del método de pago:" FontSize="11" Foreground="#6B7280" Margin="0,0,0,3"
                                   Visibility="{Binding EnablePaymentMethod, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <dxe:TextEdit Style="{StaticResource FocusedHighlightStyle}"
                                      Padding="3" BorderBrush="#C8CED6" IsReadOnly="True" Margin="0,0,0,8"
                                      EditValue="{Binding PaymentMethodName, Mode=OneWay}"
                                      Visibility="{Binding EnablePaymentMethod, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="1" Margin="0,5,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                            </dxmvvm:Interaction.Behaviors>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsCancel="True">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                            </dxmvvm:Interaction.Behaviors>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <dxe:CheckEdit Content="Cuenta activa"
                                   Style="{StaticResource BlueCheckedTextStyle}" Padding="2"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Visibility="{Binding IsEditRecord, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
