<UserControl x:Class="NetErp.Books.AccountingEntries.Views.AccountingEntriesMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetErp.Books.AccountingEntries.Views"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:uc="clr-namespace:NetErp.UserControls"
             xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:cal="http://www.caliburnproject.org"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800" FontFamily="Century Gothic">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <h:SimpleBooleanConverter x:Key="SimpleBooleanConverter" True="False" False="True"/>
        <h:CheckBoxForeColorConverter x:Key="CheckBoxForeColorConverter"/>
        <h:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
    </UserControl.Resources>
    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="10">
        <busyIndicator:BusyMask x:Name="BusyIndicator"
                                IndicatorType="BouncingDot"
                                BusyContent="Por favor espere..."
                                BusyContentMargin="0,20,0,0"
                                IsBusy="{Binding Path=IsBusy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!--Toolbar-->
            <dxr:RibbonControl Grid.Column="0" Grid.ColumnSpan="3" IsSimplified="False" 
                           AllowSimplifiedRibbon="True" ShowApplicationButton="False" ToolbarShowMode="Hide" 
                           RibbonStyle="Office2010" ToolbarShowCustomizationButton="False" RibbonTitleBarVisibility="Collapsed" VerticalAlignment="Center">

                <dxr:RibbonPage Caption="General">

                    <dxr:RibbonPageGroup Caption="Acciones">
                        <dxb:BarButtonItem Glyph="{dx:DXImage 'Images/Actions/AddFile_16x16.png'}" 
                                           LargeGlyph="{dx:DXImage 'Images/Actions/AddFile_32x32.png'}" 
                                           Content="Nuevo"
                                           RibbonStyle="Large"
                                           IsEnabled="{Binding Path=IsBusy, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}"
                                           Hint="Crear un nuevo comprobante">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding Path=CreateAccountingEntryCommand}" EventName="ItemClick"/>
                            </dxmvvm:Interaction.Behaviors>
                        </dxb:BarButtonItem>
                        <dxb:BarItemSeparator/>
                        <dxb:BarButtonItem Content="Eliminar" 
                                           Glyph="{dx:DXImage 'Images/Actions/DeleteList_16x16.png'}" 
                                           LargeGlyph="{dx:DXImage 'Images/Actions/DeleteList_32x32.png'}"                                             
                                           Description="Eliminar"
                                           Hint="Eliminar comprobantes"    
                                           IsEnabled="{Binding Path=CanDeleteEntry, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                           RibbonStyle="Large">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand 
                                    Command="{Binding Path=DeleteEntryCommand}" EventName="ItemClick"
                                   
                                    />
                            </dxmvvm:Interaction.Behaviors>
                        </dxb:BarButtonItem>
                        <dxb:BarItemLinkSeparator/>
                    </dxr:RibbonPageGroup>
                </dxr:RibbonPage>
            </dxr:RibbonControl>
            <!--Tabs-->
            <dx:DXTabControl Width="auto" Height="auto" Grid.Row="1" Margin="0,6,0,0">
                <dx:DXTabItem Padding="10" IsSelected="{Binding Path=IsSelectedTab1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <dx:DXTabItem.Header>
                        <TextBlock Text="Buscar Comprobante" FontSize="15"/>
                    </dx:DXTabItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!--Filtros colapsables-->
                        <Expander Grid.Row="0" Header="Filtros de búsqueda" IsExpanded="True" Margin="0,0,0,6">
                            <Grid Margin="8 4 8 8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!--Libro contable-->
                                <CheckBox Grid.Row="0" Grid.Column="0" Content="Libro contable" FontSize="13"
                                          Margin="0 0 8 4" VerticalAlignment="Center"
                                          Foreground="{Binding Path=SearchOnAccountingBook, Converter={StaticResource CheckBoxForeColorConverter}}"
                                          IsChecked="{Binding Path=SearchOnAccountingBook, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <dxe:ComboBoxEdit Grid.Row="0" Grid.Column="1" Margin="0 0 0 4"
                                    ItemsSource="{Binding Path=AccountingBooks}" IsTextEditable="False"
                                    DisplayMember="Name" ValueMember="Id"
                                    NullText="&lt;&lt; Seleccione libro contable &gt;&gt;"
                                    NullValueButtonPlacement="EditBox" AllowNullInput="True"
                                    EditValue="{Binding Path=SelectedAccountingBookId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Visibility="{Binding Path=SearchOnAccountingBook, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <!--Centro de costo-->
                                <CheckBox Grid.Row="1" Grid.Column="0" Content="Centro de costo" FontSize="13"
                                          Margin="0 0 8 4" VerticalAlignment="Center"
                                          Foreground="{Binding Path=SearchOnCostCenter, Converter={StaticResource CheckBoxForeColorConverter}}"
                                          IsChecked="{Binding Path=SearchOnCostCenter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <dxe:ComboBoxEdit Grid.Row="1" Grid.Column="1" Margin="0 0 0 4"
                                    ItemsSource="{Binding Path=CostCenters}" IsTextEditable="False"
                                    DisplayMember="Name" ValueMember="Id"
                                    NullText="&lt;&lt; Seleccione centro de costo &gt;&gt;"
                                    NullValueButtonPlacement="EditBox" AllowNullInput="True"
                                    EditValue="{Binding Path=SelectedCostCenterId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Visibility="{Binding Path=SearchOnCostCenter, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <!--Fuente contable-->
                                <CheckBox Grid.Row="2" Grid.Column="0" Content="Fuente contable" FontSize="13"
                                          Margin="0 0 8 4" VerticalAlignment="Center"
                                          Foreground="{Binding Path=SearchOnAccountingSource, Converter={StaticResource CheckBoxForeColorConverter}}"
                                          IsChecked="{Binding Path=SearchOnAccountingSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <dxe:ComboBoxEdit Grid.Row="2" Grid.Column="1" Margin="0 0 0 4"
                                    ItemsSource="{Binding Path=AccountingSources}" IsTextEditable="False"
                                    DisplayMember="Name" ValueMember="Id"
                                    NullText="&lt;&lt; Seleccione fuente contable &gt;&gt;"
                                    NullValueButtonPlacement="EditBox" AllowNullInput="True"
                                    EditValue="{Binding Path=SelectedAccountingSourceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Visibility="{Binding Path=SearchOnAccountingSource, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <!--Fecha-->
                                <CheckBox Grid.Row="3" Grid.Column="0" Content="Fecha" FontSize="13"
                                          Margin="0 0 8 4" VerticalAlignment="Center"
                                          Foreground="{Binding Path=SearchOnDate, Converter={StaticResource CheckBoxForeColorConverter}}"
                                          IsChecked="{Binding Path=SearchOnDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0 0 0 4"
                                            Visibility="{Binding Path=SearchOnDate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ComboBox Width="60" Margin="0 0 4 0" Padding="2"
                                              DisplayMemberPath="Value" SelectedValuePath="Key"
                                              HorizontalContentAlignment="Center"
                                              SelectedValue="{Binding Path=SelectedDateFilterOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding Path=DateFilterOptions, Mode=OneWay}"/>
                                    <DatePicker Width="105" Margin="0 0 4 0" Padding="2"
                                                SelectedDate="{Binding Path=StartDateFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DatePicker Width="105" Padding="2"
                                                SelectedDate="{Binding Path=EndDateFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Visibility="{Binding Path=IsDateRange, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                                <!--Número de documento-->
                                <CheckBox Grid.Row="4" Grid.Column="0" Content="Número de documento" FontSize="13"
                                          Margin="0 0 8 4" VerticalAlignment="Center"
                                          Foreground="{Binding Path=SearchOnDocumentNumber, Converter={StaticResource CheckBoxForeColorConverter}}"
                                          IsChecked="{Binding Path=SearchOnDocumentNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <dxe:TextEdit Grid.Row="4" Grid.Column="1" Width="140" HorizontalAlignment="Left"
                                              HorizontalContentAlignment="Center" MaxLength="9" Margin="0 0 0 4"
                                              x:Name="DocumentNumber"
                                              Text="{Binding Path=DocumentNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Visibility="{Binding Path=SearchOnDocumentNumber, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <!--Tercero-->
                                <CheckBox Grid.Row="5" Grid.Column="0" Content="Tercero" FontSize="13"
                                          Margin="0 0 8 4" VerticalAlignment="Center"
                                          Foreground="{Binding Path=SearchOnAccountingEntity, Converter={StaticResource CheckBoxForeColorConverter}}"
                                          IsChecked="{Binding Path=SearchOnAccountingEntity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <Grid Grid.Row="5" Grid.Column="1" Margin="0 0 0 4"
                                      Visibility="{Binding Path=SearchOnAccountingEntity, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <dxe:ComboBoxEdit Grid.Column="0" Margin="0 0 4 0"
                                          IsTextEditable="False"
                                          Visibility="{Binding Path=IsFilterSearchAccountinEntityOnEditMode, Converter={StaticResource SimpleBooleanConverter}}"
                                          x:Name="SelectedAccountingEntityId"
                                          DisplayMember="SearchName" ValueMember="Id"
                                          EditValue="{Binding Path=SelectedAccountingEntityId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ItemsSource="{Binding Path=AccountingEntitiesSearchResults}"
                                          ApplyItemTemplateToSelectedItem="False">
                                        <dxe:ComboBoxEdit.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Text="{Binding Path=SearchName}"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Nit." Foreground="Gray" FontSize="12"/>
                                                        <TextBlock Text="{Binding Path=IdentificationNumberWithVerificationDigit}" Foreground="Gray" FontSize="12"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </dxe:ComboBoxEdit.ItemTemplate>
                                        <dxe:ComboBoxEdit.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </dxe:ComboBoxEdit.ItemsPanel>
                                    </dxe:ComboBoxEdit>
                                    <dxe:TextEdit Grid.Column="0" Margin="0 0 4 0"
                                                  CharacterCasing="Upper" FontSize="13"
                                                  NullText="Digite por lo menos 3 caracteres y presione Buscar"
                                                  ShowNullTextIfFocused="True"
                                                  x:Name="FilterSearchAccountingEntity"
                                                  VerticalContentAlignment="Center"
                                                  Text="{Binding Path=FilterSearchAccountingEntity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Visibility="{Binding Path=IsFilterSearchAccountinEntityOnEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Grid.Column="1" Padding="3" x:Name="SearchForAccountingEntityMatch">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Margin="0 0 4 0" Width="16">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.5"/>
                                                            </Trigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsFilterSearchAccountinEntityOnEditMode}" Value="true"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Source" Value="{dx:DXImage 'Images/Print/Preview_16x16.png'}"/>
                                                            </MultiDataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsFilterSearchAccountinEntityOnEditMode}" Value="false"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Source" Value="{dx:DXImage 'Images/History/Undo_16x16.png'}"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="{Binding Path=FilterSearchButtonInfo, Mode=OneWay}" Margin="0 4 0 4" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <!--Botón buscar-->
                                <Button Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right" Margin="0 4 0 0"
                                        Padding="8 4" x:Name="SearchAccountingEntriesAsync">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Source="{dx:DXImage 'Images/Spreadsheet/FunctionsLookupAndReference_16x16.png'}" Margin="0 0 4 0" Width="16"/>
                                        <TextBlock Text="BUSCAR COMPROBANTE" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Expander>
                        <!--GridControl DevExpress-->
                        <dxg:GridControl Grid.Row="1"
                                         Margin="0,6,0,0"
                                         ItemsSource="{Binding Path=AccountingEntries, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         SelectedItem="{Binding Path=SelectedAccountingEntry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowEditing="False"
                                               AllowCascadeUpdate="False"
                                               EnableSelectedRowAppearance="True"
                                               ShowGroupPanel="False"
                                               AllowColumnMoving="False"
                                               IsColumnMenuEnabled="False"
                                               ColumnFilterPopupMode="Disabled"
                                               AllowSorting="False"
                                               AllowColumnFiltering="False"
                                               AlternateRowBackground="Beige">
                                    <dxg:TableView.RowStyle>
                                        <Style TargetType="dxg:RowControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Row.Status}" Value="CANCELLED_WITH_DOCUMENT">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Row.Status}" Value="CANCELLED_NO_DOCUMENT">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </dxg:TableView.RowStyle>
                                </dxg:TableView>
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <!--Check para seleccionar comprobante-->
                                <dxg:GridColumn Width="30" AllowEditing="True" AllowSorting="False" AllowColumnFiltering="False" ShowInColumnChooser="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox cal:Message.Attach="[Event Checked] = [Action OnChecked];[Event Unchecked] = [Action OnUnchecked]"
                                                      IsChecked="{Binding RowData.Row.IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                                <dxg:GridColumn Header="Fecha Comp." Width="Auto" MinWidth="100" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding DocumentDate, StringFormat={}{0:dd/MM/yyyy}}"/>
                                <dxg:GridColumn Header="Fuente contable" Width="Auto" MinWidth="150" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding AccountingSource.Name}"/>
                                <dxg:GridColumn Header="Número" Width="Auto" MinWidth="90" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding DocumentNumber}"/>
                                <dxg:GridColumn Header="Descripción del comprobante" Width="*" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding Description}"/>
                                <dxg:GridColumn Header="Creado Por" Width="Auto" MinWidth="150" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding CreatedBy.FullName}"/>
                                <dxg:GridColumn Header="Fecha Creación" Width="Auto" MinWidth="150" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding InsertedAt, StringFormat={}{0:dd/MM/yyyy hh:mm tt}}"/>
                                <dxg:GridColumn Header="Centro de costo" Width="Auto" MinWidth="150" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding CostCenter.Name}"/>
                                <dxg:GridColumn Header="Libro" Width="Auto" MinWidth="120" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding AccountingBook.Name}"/>
                                <dxg:GridColumn Header="Información" Width="300" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding Info}">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RowData.Row.Info}" TextWrapping="Wrap" Margin="5,3"/>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                                <!--Botón de detalle-->
                                <dxg:GridColumn Width="40" AllowEditing="True" AllowSorting="False" AllowColumnFiltering="False" ShowInColumnChooser="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button BorderThickness="0" Padding="3" Margin="3"
                                                    Width="auto" Height="auto" ToolTip="Ver documento"
                                                    cal:Message.Attach="[Event Click] = [Action ZoomDoc]">
                                                <Button.Content>
                                                    <Image Source="{dx:SvgImageSource Uri='pack://application:,,,/DevExpress.Images.v25.2;component/SvgImages/DiagramIcons/ShowPrintPreview.svg', Size='16,16'}" Stretch="None" />
                                                </Button.Content>
                                            </Button>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                        <!--Paginacion-->
                        <uc:GridPaging Grid.Row="2" Margin="0,6,0,0"
                                       PageSize="{Binding Path=PageSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       PageIndex="{Binding Path=PageIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       TotalCount="{Binding Path=TotalCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       ResponseTime="{Binding Path=ResponseTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </dx:DXTabItem>
                
                <dx:DXTabItem Padding="10" IsSelected="{Binding Path=IsSelectedTab2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <dx:DXTabItem.Header>
                        <TextBlock Text="Buscar Borradores" FontSize="15"/>
                    </dx:DXTabItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="¿Qué desea buscar?" Grid.Row="0" Margin="0,0,0,3"/>
                        <TextBox Grid.Row="1" Margin="0,0,0,0" Padding="3"/>
                        <dxg:GridControl Grid.Row="2" Margin="0,6,0,0"
                                         ItemsSource="{Binding Path=AccountingEntryDrafts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowEditing="False"
                                               AllowCascadeUpdate="False"
                                               EnableSelectedRowAppearance="True"
                                               ShowGroupPanel="False"
                                               AllowColumnMoving="False"
                                               IsColumnMenuEnabled="False"
                                               ColumnFilterPopupMode="Disabled"
                                               AllowSorting="False"
                                               AllowColumnFiltering="False"
                                               AlternateRowBackground="Beige"/>
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <!--Check para seleccionar borrador-->
                                <dxg:GridColumn Width="30" AllowEditing="True" AllowSorting="False" AllowColumnFiltering="False" ShowInColumnChooser="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox cal:Message.Attach="[Event Checked] = [Action OnChecked];[Event Unchecked] = [Action OnUnchecked]"
                                                      IsChecked="{Binding RowData.Row.IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                                <dxg:GridColumn Header="Fecha" Width="Auto" MinWidth="100" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding DocumentDate, StringFormat={}{0:dd/MM/yyyy}}"/>
                                <dxg:GridColumn Header="Fuente contable" Width="Auto" MinWidth="150" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding AccountingSource.Name}"/>
                                <dxg:GridColumn Header="Número" Width="Auto" MinWidth="90" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding DocumentNumber}"/>
                                <dxg:GridColumn Header="Descripción" Width="*" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding Description}"/>
                                <dxg:GridColumn Header="Creado Por" Width="Auto" MinWidth="150" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding CreatedBy.FullName}"/>
                                <dxg:GridColumn Header="Fecha Creación" Width="Auto" MinWidth="150" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding InsertedAt, StringFormat={}{0:dd/MM/yyyy hh:mm tt}}"/>
                                <dxg:GridColumn Header="Centro de costo" Width="Auto" MinWidth="150" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding CostCenter.Name}"/>
                                <dxg:GridColumn Header="Libro" Width="Auto" MinWidth="120" HorizontalHeaderContentAlignment="Center"
                                                Binding="{Binding AccountingBook.Name}"/>
                                <!--Botón de edición-->
                                <dxg:GridColumn Width="40" AllowEditing="True" AllowSorting="False" AllowColumnFiltering="False" ShowInColumnChooser="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button BorderThickness="0" Padding="3" Margin="3"
                                                    Width="auto" Height="auto" ToolTip="Editar borrador"
                                                    Command="{Binding Path=Data.EditDraftEntryCommand, Source={StaticResource DataContextProxy}}"
                                                    CommandParameter="{Binding RowData.Row}">
                                                <Button.Content>
                                                    <Image Source="{dx:SvgImageSource Uri='pack://application:,,,/DevExpress.Images.v25.2;component/SvgImages/Dashboards/Edit.svg', Size='16,16'}" Stretch="None" />
                                                </Button.Content>
                                            </Button>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                        <uc:GridPaging Grid.Row="3" Margin="0,6,0,0"
                                       ChangedIndexCommand="{Binding Path=DraftPaginationCommand}"
                                       PageIndex="{Binding Path=DraftPageIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       PageSize="{Binding Path=DraftPageSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       TotalCount="{Binding Path=DraftTotalCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       ResponseTime="{Binding Path=DraftResponseTime, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </dx:DXTabItem>
            </dx:DXTabControl>
        </Grid>
    </busyIndicator:BusyMask>
    </Border>
</UserControl>
