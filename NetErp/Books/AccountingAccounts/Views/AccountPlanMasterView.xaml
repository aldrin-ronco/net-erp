<UserControl x:Class="NetErp.Books.AccountingAccounts.Views.AccountPlanMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:model="clr-namespace:NetErp.Books.AccountingAccounts.DTO"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core">
    <UserControl.Resources>
        <h:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
        <dxmvvm:BooleanNegationConverter x:Key="BooleanNegationConverter"/>

        <HierarchicalDataTemplate  DataType="{x:Type model:AccountingAccountDTO}" ItemsSource="{Binding Childrens, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Nueva cuenta (Ctrl + N)" Command="{Binding Path=Data.CreateAsyncCommand, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Image Source="{dx:DXImage 'Images/Actions/AddItem_16x16.png'}"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Data.EditAsyncCommand, Source={StaticResource DataContextProxy}}"
                            CommandParameter="{Binding Row.Code}">
                            <MenuItem.Icon>
                                <Image Source="{dx:DXImage 'Images/Edit/Edit_16x16.png'}"/>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Modificar cuenta : "/>
                                    <TextBlock Text="{Binding Row.Code}" Margin="4 0 0 0"/>
                                    <TextBlock Text=" - "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Command="{Binding Path=Data.DeleteAsyncCommand, Source={StaticResource DataContextProxy}}"
                            CommandParameter="{Binding Row}">
                            <MenuItem.Icon>
                                <Image Source="{dx:DXImage 'Images/Edit/Delete_16x16.png'}"/>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Eliminar cuenta : "/>
                                    <TextBlock Text="{Binding Row.Code}" Margin="4 0 0 0"/>
                                    <TextBlock Text=" - "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <!--Close Folder-->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Row.IsAuxiliary}" Value="false"/>
                                        <Condition Binding="{Binding Row.IsExpanded}" Value="false"/>
                                    </MultiDataTrigger.Conditions>
                                    <!--PlaceHolderImage-->
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderClose.svg'}"/>
                                </MultiDataTrigger>
                                <!--Open Folder-->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Row.IsAuxiliary}" Value="false"/>
                                        <Condition Binding="{Binding Row.IsExpanded}" Value="true"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderOpen.svg'}"/>
                                </MultiDataTrigger>
                                <!--Cuenta Auxiliar-->
                                <DataTrigger Binding="{Binding Row.IsAuxiliary}" Value="true">
                                    <!--PlaceHolderImage-->
                                    <Setter Property="Source" Value="{dx:DXImage 'Images/Miscellaneous/HighlightActiveElements_16x16.png'}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <TextBlock Text="{Binding Row.Code}" Margin="4 0 0 0"
               ContextMenuService.Placement="MousePoint" VerticalAlignment="Center"/>

                <TextBlock Text=" - " VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Row.Name}"
               ContextMenuService.Placement="MousePoint" VerticalAlignment="Center"/>

            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>
    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:EventToCommand EventName="Loaded" Command="{Binding InitializeCommand}"/>
    </dxmvvm:Interaction.Behaviors>
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0"
                            IsBusyAtStartup="False"
                            Background="Transparent">

        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1" CornerRadius="8" Margin="5" Padding="10,10,10,0">
            <Grid Name="GridMain">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <dxg:TreeViewControl
                    ItemsSource="{Binding Path=AccountingAccounts, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                    h:TreeViewExtension.SelectItemOnRightClick="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    HighlightSelectedNodeIndent="False"
                    BorderThickness="0"
                    ShowExpandButtons="True"
                    ShowBorder="False" ShowSearchPanel="False" AllowEditing="False"
                    TreeDerivationMode="HierarchicalDataTemplate"
                    ExpandStateBinding="{Binding IsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Grid.Row="0">
                    <dxg:TreeViewControl.NodeStyle>
                        <Style TargetType="dxg:RowControl">
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsExpanded}" Value="true"/>
                                        <Condition Binding="{Binding Row.IsAuxiliary}" Value="false"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Foreground" Value="Blue"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:TreeViewControl.NodeStyle>
                </dxg:TreeViewControl>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">
                    <Button Command="{Binding CreateAsyncCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource BooleanNegationConverter}}"
                            Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/New_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Nuevo" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ReportAsyncCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource BooleanNegationConverter}}"
                            Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Reports/Report_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Reporte" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
