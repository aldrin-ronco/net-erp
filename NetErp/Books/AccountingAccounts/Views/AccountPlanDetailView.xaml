<UserControl x:Class="NetErp.Books.AccountingAccounts.Views.AccountPlanDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             Name="ucAccountDetail"
             Background="#EEF1F5">
    <UserControl.Resources>
        <dxmvvm:BooleanNegationConverter x:Key="BooleanNegationConverter"/>
        <h:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
    </UserControl.Resources>
    <!--AREA DE DETALLE Y EDICION DE CUENTAS CONTABLES-->
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}"
                Height="{Binding DialogHeight}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form content -->
                <Grid Grid.Row="0" Background="Transparent" h:EnterKeyTraversal.IsEnabled="True"
                      Margin="20,0,20,0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <!--Labels-->
                            <ColumnDefinition Width="auto"/>
                            <!--Cuenta-->
                            <ColumnDefinition Width="140"/>
                            <!--Nombre-->
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <!--Titulo o Encabezado-->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="DETALLES DE CUENTA CONTABLE" Grid.ColumnSpan="3" HorizontalAlignment="Center" Padding="10" FontSize="16" FontWeight="Bold" Margin="0,5,0,10"/>

                        <!--Clase-->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Clase" VerticalAlignment="Center" Margin="10,5,0,5"
                                   Visibility="{Binding Path=Data.Lv1Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"/>
                        <dxe:TextEdit Text="{Binding Path=Data.Lv1Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.Lv1Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"
                                      Grid.Row="1" Grid.Column="1"
                                      IsReadOnly="True" Padding="3" BorderBrush="#C8CED6"
                                      HorizontalContentAlignment="Center"
                                      Margin="10,5,10,5"/>
                        <dxe:TextEdit Text="{Binding Path=Data.Lv1Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.Lv1Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"
                                      IsReadOnly="{Binding Path=Data.IsReadOnlyLv1Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Style="{StaticResource FocusedHighlightStyle}"
                                      Grid.Row="1" Grid.Column="2"
                                      MaxLength="{Binding Path=Data.NameMaxLength, Source={StaticResource DataContextProxy}}"
                                      CharacterCasing="Upper" Padding="3" BorderBrush="#C8CED6"
                                      Margin="0,5,10,5">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:FocusBehavior SourceObject="{Binding Path=Data, Source={StaticResource DataContextProxy}}" PropertyName="Lv1NameIsFocused"/>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:TextEdit>

                        <!--Grupo-->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Grupo" VerticalAlignment="Center" Margin="10,5,0,5"
                                   Visibility="{Binding Path=Data.Lv2Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"/>
                        <dxe:TextEdit Text="{Binding Path=Data.Lv2Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.Lv2Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"
                                      Grid.Row="2" Grid.Column="1"
                                      IsReadOnly="True" Padding="3" BorderBrush="#C8CED6"
                                      HorizontalContentAlignment="Center"
                                      Margin="10,5,10,5"/>
                        <dxe:TextEdit Text="{Binding Path=Data.Lv2Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.Lv2Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"
                                      IsReadOnly="{Binding Path=Data.IsReadOnlyLv2Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Style="{StaticResource FocusedHighlightStyle}"
                                      Grid.Row="2" Grid.Column="2"
                                      MaxLength="{Binding Path=Data.NameMaxLength, Source={StaticResource DataContextProxy}}"
                                      CharacterCasing="Upper" Padding="3" BorderBrush="#C8CED6"
                                      Margin="0,5,10,5">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:FocusBehavior SourceObject="{Binding Path=Data, Source={StaticResource DataContextProxy}}" PropertyName="Lv2NameIsFocused"/>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:TextEdit>

                        <!--Cuenta-->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Cuenta" VerticalAlignment="Center" Margin="10,5,0,5"
                                   Visibility="{Binding Path=Data.Lv3Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"/>
                        <dxe:TextEdit Text="{Binding Path=Data.Lv3Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.Lv3Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"
                                      Grid.Row="3" Grid.Column="1"
                                      IsReadOnly="True" Padding="3" BorderBrush="#C8CED6"
                                      HorizontalContentAlignment="Center"
                                      Margin="10,5,10,5"/>
                        <dxe:TextEdit Text="{Binding Path=Data.Lv3Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.Lv3Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"
                                      IsReadOnly="{Binding Path=Data.IsReadOnlyLv3Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Style="{StaticResource FocusedHighlightStyle}"
                                      Grid.Row="3" Grid.Column="2"
                                      MaxLength="{Binding Path=Data.NameMaxLength, Source={StaticResource DataContextProxy}}"
                                      CharacterCasing="Upper" Padding="3" BorderBrush="#C8CED6"
                                      Margin="0,5,10,5">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:FocusBehavior SourceObject="{Binding Path=Data, Source={StaticResource DataContextProxy}}" PropertyName="Lv3NameIsFocused"/>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:TextEdit>

                        <!--SubCuenta-->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Sub Cuenta" VerticalAlignment="Center" Margin="10,5,0,5"
                                   Visibility="{Binding Path=Data.Lv4Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"/>
                        <dxe:TextEdit Text="{Binding Path=Data.Lv4Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.Lv4Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"
                                      Grid.Row="4" Grid.Column="1"
                                      IsReadOnly="True" Padding="3" BorderBrush="#C8CED6"
                                      HorizontalContentAlignment="Center"
                                      Margin="10,5,10,5"/>
                        <dxe:TextEdit Text="{Binding Path=Data.Lv4Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.Lv4Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"
                                      IsReadOnly="{Binding Path=Data.IsReadOnlyLv4Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Style="{StaticResource FocusedHighlightStyle}"
                                      Grid.Row="4" Grid.Column="2"
                                      MaxLength="{Binding Path=Data.NameMaxLength, Source={StaticResource DataContextProxy}}"
                                      CharacterCasing="Upper" Padding="3" BorderBrush="#C8CED6"
                                      Margin="0,5,10,5">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:FocusBehavior SourceObject="{Binding Path=Data, Source={StaticResource DataContextProxy}}" PropertyName="Lv4NameIsFocused"/>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:TextEdit>

                        <!--Auxiliar-->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Auxiliar" VerticalAlignment="Center" Margin="10,5,0,5"
                                   Visibility="{Binding Path=Data.Lv5Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"/>
                        <dxe:TextEdit x:Name="Lv5Code"
                                      Text="{Binding Path=Data.Lv5Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.Lv5Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"
                                      IsReadOnly="{Binding Path=Data.IsReadOnlyLv5Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Style="{StaticResource FocusedHighlightStyle}"
                                      Grid.Row="5" Grid.Column="1"
                                      MaxLength="{Binding Path=Data.CodeMaxLength, Source={StaticResource DataContextProxy}}"
                                      Padding="3" BorderBrush="#C8CED6"
                                      HorizontalContentAlignment="Center"
                                      Margin="10,5,10,5">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:FocusBehavior SourceObject="{Binding Path=Data, Source={StaticResource DataContextProxy}}" PropertyName="Lv5CodeIsFocused"/>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:TextEdit>

                        <dxe:TextEdit x:Name="Lv5Name"
                                      Text="{Binding Path=Data.Lv5Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.Lv5Visibility, Mode=OneWay, Source={StaticResource DataContextProxy}}"
                                      IsReadOnly="{Binding Path=Data.IsReadOnlyLv5Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Style="{StaticResource FocusedHighlightStyle}"
                                      Grid.Row="5" Grid.Column="2"
                                      MaxLength="{Binding Path=Data.NameMaxLength, Source={StaticResource DataContextProxy}}"
                                      CharacterCasing="Upper" Padding="3" BorderBrush="#C8CED6"
                                      Margin="0,5,10,5">
                            <dxe:TextEdit.Foreground>
                                <Binding Path="Data.AccountCodeExists" Source="{StaticResource DataContextProxy}">
                                    <Binding.Converter>
                                        <dxmvvm:BooleanToObjectConverter TrueValue="Red" FalseValue="Black"/>
                                    </Binding.Converter>
                                </Binding>
                            </dxe:TextEdit.Foreground>
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:FocusBehavior SourceObject="{Binding Path=Data, Source={StaticResource DataContextProxy}}" PropertyName="Lv5NameIsFocused"/>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:TextEdit>

                        <!--Naturaleza-->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Naturaleza" VerticalAlignment="Center" Margin="10 5 0 5"/>
                        <ComboBox ItemsSource="{Binding Path=Data.AccountNature, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                              DisplayMemberPath="Value"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding Data.SelectedAccountNature, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                              Grid.Row="6" Grid.Column="1"
                              IsEnabled="False"
                              IsTabStop="False"
                              Margin="10 5 10 5" Padding="3"
                              Grid.ColumnSpan="3"/>

                        <!--Margen y Base-->
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Margen" VerticalAlignment="Center" Margin="10 5 0 5"
                                   Visibility="{Binding Path=Data.MarginVisibility, Source={StaticResource DataContextProxy}}"/>
                        <dxe:SpinEdit Grid.Row="7" Grid.Column="1"
                                      EditValue="{Binding Data.Margin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource DataContextProxy}}"
                                      Visibility="{Binding Path=Data.MarginVisibility, Source={StaticResource DataContextProxy}}"
                                      MinValue="0" MaxValue="100"
                                      Increment="0.01"
                                      Mask="f2"
                                      MaskUseAsDisplayFormat="True"
                                      BorderBrush="#C8CED6"
                                      TabIndex="10"
                                      Margin="10 5 10 5"/>
                        <StackPanel Grid.Row="7" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding Path=Data.MarginVisibility, Source={StaticResource DataContextProxy}}"
                                    Margin="0 5 10 5">
                            <RadioButton Content="Base 100"
                                         Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                         IsChecked="{Binding Data.IsMarginBasis100, Mode=TwoWay, Source={StaticResource DataContextProxy}}"
                                         TabIndex="11" Margin="0,0,15,0"/>
                            <RadioButton Content="Base 1000"
                                         Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                         IsChecked="{Binding Data.IsMarginBasis1000, Mode=TwoWay, Source={StaticResource DataContextProxy}}"
                                         TabIndex="12"/>
                        </StackPanel>

                </Grid>

                <!-- Button bar centered -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding Data.CanSave, Source={StaticResource DataContextProxy}, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding Data.SaveCommand, Source={StaticResource DataContextProxy}}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding Data.CancelCommand, Source={StaticResource DataContextProxy}}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
    <!--fin GridDetails-->
</UserControl>
