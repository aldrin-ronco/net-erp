<UserControl x:Class="NetErp.Books.IdentificationTypes.Views.IdentificationTypeDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             Background="#EEF1F5"
             d:DesignHeight="300" d:DesignWidth="450">

    <busyIndicator:BusyMask IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Please wait..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="15" Padding="20" MinWidth="400" MaxWidth="500">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Code label -->
                <TextBlock Grid.Row="0" Text="Código DIAN (2 dígitos)" Margin="0,0,0,4"/>

                <!-- Row 1: Code field -->
                <dxe:TextEdit Grid.Row="1"
                              x:Name="IdentificationTypeCode"
                              Text="{Binding Path=Code, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                              MaxLength="2"
                              IsReadOnly="{Binding IsReadOnlyCode}"
                              BorderBrush="#C8CED6"
                              MaskType="RegEx"
                              Mask="[0-9]{1,2}"/>

                <!-- Row 2: Name label -->
                <TextBlock Grid.Row="2" Text="Nombre" Margin="0,12,0,4"/>

                <!-- Row 3: Name field -->
                <dxe:TextEdit Grid.Row="3"
                              x:Name="IdentificationTypeName"
                              Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                              CharacterCasing="Upper"
                              BorderBrush="#C8CED6"/>

                <!-- Row 4: MinimumDocumentLength label -->
                <TextBlock Grid.Row="4" Text="Longitud mínima del documento" Margin="0,12,0,4"/>

                <!-- Row 5: MinimumDocumentLength field -->
                <dxe:SpinEdit Grid.Row="5"
                              Value="{Binding Path=MinimumDocumentLength, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                              MinValue="5"
                              MaxValue="15"
                              IsFloatValue="False"
                              BorderBrush="#C8CED6"
                              HorizontalAlignment="Left"
                              MinWidth="80"/>

                <!-- Row 6: AllowsLetters -->
                <dxe:CheckEdit Grid.Row="6"
                               Content="Permite letras en el documento"
                               IsChecked="{Binding Path=AllowsLetters, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                               Margin="0,12,0,0"/>

                <!-- Row 7: HasVerificationDigit -->
                <dxe:CheckEdit Grid.Row="7"
                               Content="Requiere dígito de verificación"
                               IsChecked="{Binding Path=HasVerificationDigit, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                               Margin="0,12,0,0"/>

                <!-- Row 8: Buttons -->
                <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
