<UserControl x:Class="NetErp.Books.AccountingPresentations.Views.AccountingPresentationDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:h="clr-namespace:NetErp.Helpers"
             mc:Ignorable="d"
             Background="#EEF1F5"
             d:DesignHeight="500" d:DesignWidth="500">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8" MaxWidth="500">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Name label -->
                <TextBlock Grid.Row="0" Text="Nombre de la presentación" FontSize="13" Margin="15,15,15,5"/>

                <!-- Row 1: Name field -->
                <dxe:TextEdit Grid.Row="1"
                              x:Name="PresentationName"
                              Style="{StaticResource FocusedHighlightStyle}"
                              Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                              CharacterCasing="Upper"
                              BorderBrush="#C8CED6"
                              Margin="15,0,15,0"
                              h:FocusBehavior.IsFocused="True"/>

                <!-- Row 2: Accounting Books grid with checkboxes -->
                <TextBlock Grid.Row="2" Text="Libros contables asociados" FontSize="13" Margin="15,10,15,5"/>

                <dxg:GridControl Grid.Row="3"
                                 Margin="15,0,15,0"
                                 MinHeight="200"
                                 ItemsSource="{Binding AccountingBooks, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                                 AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView AllowCascadeUpdate="False"
                                       EnableSelectedRowAppearance="True"
                                       AllowSorting="False"
                                       ShowGroupPanel="False"
                                       AllowEditing="False"
                                       AllowColumnMoving="False"/>
                    </dxg:GridControl.View>
                    <dxg:GridColumn Header="..." Width="30" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center" Margin="3"
                                          IsChecked="{Binding RowData.Row.IsChecked, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                          cal:Message.Attach="ToggleActive($eventArgs)"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Libro contable" HorizontalHeaderContentAlignment="Center" Width="*"
                                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"/>
                </dxg:GridControl>

                <!-- Row 4: AllowsClosure checkbox -->
                <dxe:CheckEdit Grid.Row="4" Margin="15,10,15,0"
                               Content="Permitir cierre de cuentas"
                               Style="{StaticResource BlueCheckedTextStyle}" Padding="2"
                               IsChecked="{Binding AllowsClosure, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

                <!-- Row 5: Closure accounting book ComboBox -->
                <StackPanel Grid.Row="5" Margin="15,8,15,0"
                            Visibility="{Binding AllowsClosure, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Libro para cierre contable" Margin="0,0,0,4"/>
                    <dxe:ComboBoxEdit
                        ItemsSource="{Binding AccountingBooksToClosure}"
                        DisplayMember="Name"
                        ValueMember="Id"
                        IsTextEditable="False"
                        NullText="Seleccionar un libro"
                        EditValue="{Binding ClosureAccountingBookId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        BorderBrush="#C8CED6"/>
                </StackPanel>

                <!-- Row 6: Buttons -->
                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,15">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
