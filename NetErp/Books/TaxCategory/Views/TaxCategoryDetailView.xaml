<UserControl x:Class="NetErp.Books.TaxCategory.Views.TaxCategoryDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:NetErp.Books.TaxCategory.Views"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:h="clr-namespace:NetErp.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500"
             Background="#EEF1F5">
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Please wait..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="20" MinWidth="420">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form content -->
                <StackPanel Grid.Row="0" Margin="30,25,30,20">

                    <!-- Código (DIAN) -->
                    <TextBlock Text="Código (DIAN)" FontSize="13" Margin="0,0,0,5"/>
                    <dxe:TextEdit Text="{Binding Path=Code, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  CharacterCasing="Upper"
                                  x:Name="TaxCategoryCode"
                                  IsReadOnly="{Binding IsCodeReadOnly, Mode=OneWay}"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,15"/>

                    <!-- Nombre -->
                    <TextBlock Text="Nombre" FontSize="13" Margin="0,0,0,5"/>
                    <dxe:TextEdit Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  CharacterCasing="Upper"
                                  x:Name="TaxCategoryName"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,15"/>

                    <!-- Prefijo -->
                    <TextBlock Text="Prefijo" FontSize="13" Margin="0,0,0,5"/>
                    <dxe:TextEdit Text="{Binding Path=Prefix, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  CharacterCasing="Upper"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,15"/>

                    <!-- Usa Porcentaje -->
                    <dxe:CheckEdit Content="Usa Porcentaje"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   Padding="2"
                                   Margin="0,0,0,15"
                                   IsChecked="{Binding UsesPercentage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Impuesto Generado -->
                    <TextBlock Text="Impuesto Generado" FontSize="13" Margin="0,0,0,8"/>
                    <dxe:CheckEdit Content="Cuenta de Operación Requerida"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   Padding="2"
                                   Margin="0,0,0,5"
                                   IsChecked="{Binding GeneratedTaxAccountIsRequired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <dxe:CheckEdit Content="Cuenta De Devolución Requerida"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   Padding="2"
                                   Margin="0,0,0,10"
                                   IsReadOnly="{Binding IsReadOnlyGeneratedTaxRefundAccountIsRequired, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                   IsChecked="{Binding GeneratedTaxRefundAccountIsRequired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Impuesto Descontable -->
                    <TextBlock Text="Impuesto Descontable" FontSize="13" Margin="0,0,0,8"/>
                    <dxe:CheckEdit Content="Cuenta de Operación Requerida"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   Padding="2"
                                   Margin="0,0,0,5"
                                   IsChecked="{Binding DeductibleTaxAccountIsRequired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <dxe:CheckEdit Content="Cuenta De Devolución Requerida"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   Padding="2"
                                   Margin="0,0,0,0"
                                   IsReadOnly="{Binding IsReadOnlyDeductibleTaxRefundAccountIsRequired, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                   IsChecked="{Binding DeductibleTaxRefundAccountIsRequired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Button bar centered -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
