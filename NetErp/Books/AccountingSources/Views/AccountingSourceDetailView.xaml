<UserControl x:Class="NetErp.Books.AccountingSources.Views.AccountingSourceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="550"
             Background="#EEF1F5">
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8" MinWidth="480">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form content -->
                <StackPanel Grid.Row="0" Margin="30,25,30,10">

                    <!-- Tipo de proceso (ComboBox en creación, TextBlock en edición) -->
                    <TextBlock Text="Tipo de proceso" FontSize="13" Margin="0,0,0,4"/>
                    <dxe:ComboBoxEdit
                        Padding="2"
                        ItemsSource="{Binding Path=ProcessTypes, UpdateSourceTrigger=PropertyChanged}"
                        IsTextEditable="False"
                        DisplayMember="Name"
                        ValueMember="Id"
                        NullText="Seleccione un tipo de proceso"
                        NullValueButtonPlacement="EditBox"
                        EditValue="{Binding ProcessTypeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        BorderBrush="#C8CED6"
                        Margin="0,0,0,10"
                        Visibility="{Binding IsNewRecord, Converter={dxmvvm:BooleanToVisibilityConverter}}"/>
                    <TextBlock
                        Text="{Binding SelectedProcessTypeName, Mode=OneWay}"
                        FontSize="13"
                        Margin="0,0,0,10"
                        Visibility="{Binding IsNewRecord, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}"/>

                    <!-- Código corto (solo visible en creación) -->
                    <StackPanel Visibility="{Binding IsNewRecord, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                Margin="0,0,0,10">
                        <TextBlock Text="Código corto" FontSize="13" Margin="0,0,0,4"/>
                        <dxe:TextEdit Text="{Binding Path=ShortCode, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      Style="{StaticResource FocusedHighlightStyle}"
                                      CharacterCasing="Upper"
                                      x:Name="ShortCode"
                                      MaxLength="3"
                                      BorderBrush="#C8CED6"
                                      MaskType="RegEx"
                                      Mask="[a-zA-Z]{0,3}"/>
                    </StackPanel>

                    <!-- Nombre -->
                    <TextBlock Text="Nombre" FontSize="13" Margin="0,0,0,4"/>
                    <dxe:TextEdit Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  CharacterCasing="Upper"
                                  x:Name="Name"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,10"/>

                    <!-- Código largo (readonly) -->
                    <TextBlock Text="Código largo" FontSize="13" Margin="0,0,0,4"/>
                    <dxe:TextEdit Text="{Binding Code, Mode=OneWay}"
                                  IsReadOnly="True"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,10"/>

                    <!-- Tipo de anulación -->
                    <TextBlock Text="Tipo de anulación" FontSize="13" Margin="0,0,0,4"/>
                    <dxe:ComboBoxEdit
                        Padding="2"
                        ItemsSource="{Binding AnnulmentTypeDictionary, Mode=OneWay}"
                        IsTextEditable="False"
                        DisplayMember="Value"
                        ValueMember="Key"
                        EditValue="{Binding AnnulmentCharacter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        BorderBrush="#C8CED6"
                        Margin="0,0,0,10"/>

                    <!-- Concepto de Inventario -->
                    <dxe:CheckEdit Content="Concepto de Inventario"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   Padding="2"
                                   Margin="0,0,0,10"
                                   IsEnabled="{Binding IsNewRecord, Mode=OneWay}"
                                   IsChecked="{Binding IsKardexTransaction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Sección Kardex (visible solo cuando IsKardexTransaction) -->
                    <StackPanel Visibility="{Binding IsKardexTransaction, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                Margin="0,0,0,10">
                        <TextBlock Text="Tipo de concepto" FontSize="13" Margin="0,0,0,4"/>
                        <dxe:ComboBoxEdit
                            Padding="2"
                            ItemsSource="{Binding KardexFlowDictionary, Mode=OneWay}"
                            IsTextEditable="False"
                            DisplayMember="Value"
                            ValueMember="Key"
                            IsEnabled="{Binding IsNewRecord, Mode=OneWay}"
                            EditValue="{Binding KardexFlow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            BorderBrush="#C8CED6"
                            Margin="0,0,0,10"/>

                        <TextBlock Text="Cuenta contable" FontSize="13" Margin="0,0,0,4"/>
                        <dxe:ComboBoxEdit
                            Padding="2"
                            ItemsSource="{Binding Path=AuxiliaryAccountingAccounts, UpdateSourceTrigger=PropertyChanged}"
                            IsTextEditable="False"
                            DisplayMember="FullName"
                            ValueMember="Id"
                            NullText="Seleccione la cuenta contable"
                            NullValueButtonPlacement="EditBox"
                            EditValue="{Binding AccountingAccountId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            BorderBrush="#C8CED6"/>
                    </StackPanel>
                </StackPanel>

                <!-- Button bar centered -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
