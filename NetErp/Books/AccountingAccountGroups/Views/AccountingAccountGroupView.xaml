<UserControl x:Class="NetErp.Books.AccountingAccountGroups.Views.AccountingAccountGroupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="10">
        <busyIndicator:BusyMask x:Name="BusyIndicator"
                                IsBusy="{Binding IsBusy}"
                                IndicatorType="BouncingDot"
                                BusyContent="Please wait..."
                                BusyContentMargin="0,20,0,0">
            <Grid Margin="20,15,20,20">
                <!-- Empty state -->
                <Grid Visibility="{Binding ShowAllControls, UpdateSourceTrigger=PropertyChanged, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Agrupación de cuentas contables"
                                   FontWeight="Bold" HorizontalAlignment="Center" FontSize="22" Margin="0,0,0,10"/>
                        <TextBlock Text="Los grupos contables permiten configurar cuentas relacionadas para una mejor administración."
                                   HorizontalAlignment="Center" FontSize="14" TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="Gray" MaxWidth="500"/>
                        <TextBlock Text="En este momento no hay ningún grupo de cuentas."
                                   HorizontalAlignment="Center" Margin="0,20,0,0" FontSize="14" Foreground="Gray"/>
                    </StackPanel>
                </Grid>

                <!-- Main content -->
                <Grid Visibility="{Binding ShowAllControls, UpdateSourceTrigger=PropertyChanged, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Group selector -->
                    <StackPanel Grid.Row="0" Orientation="Vertical">
                        <TextBlock Text="Seleccione el grupo de cuenta contable" Margin="0,0,0,5"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding Path=Groups, UpdateSourceTrigger=PropertyChanged}"
                                          IsTextEditable="False"
                                          DisplayMember="Name"
                                          BorderBrush="#C8CED6"
                                          EditValue="{Binding SelectedGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding AccountingAccountGroupComboBoxIsEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Row 1: Group filters (read-only summary + config button) -->
                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Filtros del grupo" VerticalAlignment="Center"/>
                            <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Margin="6,0,0,0" Padding="2" VerticalAlignment="Center"
                                    ToolTip="Configurar filtros del grupo"
                                    IsEnabled="{Binding CanOpenFilterDialog, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand Command="{Binding OpenFilterDialogCommand}" EventName="Click"/>
                                </dxmvvm:Interaction.Behaviors>
                                <Image Source="{dx:DXImage 'Images/Setup/Properties_16x16.png'}" Width="16" Height="16"/>
                            </Button>
                        </StackPanel>
                        <!-- Read-only filter chips -->
                        <ItemsControl ItemsSource="{Binding GroupFilters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#E8F0FE" BorderBrush="#B0C4DE" BorderThickness="1"
                                            CornerRadius="4" Padding="6,3" Margin="0,0,6,4">
                                        <TextBlock Text="{Binding FullName}" VerticalAlignment="Center" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Sin filtros configurados — se mostrarán todas las cuentas"
                                   Foreground="Gray" FontSize="11" FontStyle="Italic"
                                   Visibility="{Binding HasGroupFilters, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}"/>
                    </StackPanel>

                    <!-- Row 2: Account selector -->
                    <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,12,0,0">
                        <TextBlock Text="Seleccione la cuenta contable" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <dxe:ComboBoxEdit ItemsSource="{Binding Path=FilteredAccountingAccounts, UpdateSourceTrigger=PropertyChanged}"
                                              IsTextEditable="False"
                                              DisplayMember="FullName"
                                              ValueMember="Code"
                                              BorderBrush="#C8CED6"
                                              NullText="Seleccione la(s) cuenta(s) contable(s) que desea agregar al grupo"
                                              EditValue="{Binding SelectedAccountingAccountCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Margin="8,0,0,0" Padding="6"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Command="{Binding AddAccountingAccountCommand}"
                                    IsEnabled="{Binding CanAddAccountingAccount, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}">
                                <Image Source="{dx:DXImage 'Images/Actions/Add_16x16.png'}" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Row 3: Search filter -->
                    <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,12,0,0">
                        <TextBlock Text="¿Qué desea buscar?" Margin="0,0,0,5"/>
                        <dxe:ButtonEdit
                            NullText="Escribe por lo menos 3 letras para iniciar la busqueda"
                            ToolTip="Escribe aqui para buscar"
                            MinHeight="25"
                            BorderBrush="#C8CED6"
                            AllowDefaultButton="False"
                            Text="{Binding FilterSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                            CharacterCasing="Upper">
                            <dxe:ButtonEdit.Buttons>
                                <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                            </dxe:ButtonEdit.Buttons>
                        </dxe:ButtonEdit>
                    </StackPanel>

                    <!-- Row 4: Grid -->
                    <dxg:GridControl Grid.Row="4" Margin="0,10,0,0"
                                     ItemsSource="{Binding Path=SelectedGroupAccountingAccounts, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                        <dxg:GridControl.View>
                            <dxg:TableView AllowEditing="False"
                                           AllowCascadeUpdate="False"
                                           EnableSelectedRowAppearance="True"
                                           ShowGroupPanel="False"
                                           AlternateRowBackground="Beige"
                                           AllowColumnMoving="False"
                                           ColumnFilterPopupMode="Disabled"
                                           AllowSorting="False"
                                           AllowColumnFiltering="False"
                                           IsColumnMenuEnabled="False"
                                           AllowPerPixelScrolling="False"
                                           RowMinHeight="23"/>
                        </dxg:GridControl.View>

                        <dxg:GridColumn Header="Código" Width="Auto" HorizontalHeaderContentAlignment="Center"
                                        Binding="{Binding Code}">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn Header="Nombre de la cuenta contable" Width="*" HorizontalHeaderContentAlignment="Left"
                                        Binding="{Binding Name}"/>

                        <dxg:GridColumn Header="Naturaleza" Width="100" HorizontalHeaderContentAlignment="Center"
                                        Binding="{Binding Nature}">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn Width="45" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center"
                                              IsChecked="{Binding DataContext.IsAllChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </DataTemplate>
                            </dxg:GridColumn.HeaderTemplate>
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Margin="4" HorizontalAlignment="Center"
                                              IsChecked="{Binding RowData.Row.IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl>

                    <!-- Row 5: Action buttons centered -->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <!-- Guardar -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding CanSave, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                            </dxmvvm:Interaction.Behaviors>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <!-- Deshacer -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding CanUndo, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding UndoCommand}" EventName="Click"/>
                            </dxmvvm:Interaction.Behaviors>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/History/Undo_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="Deshacer" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <!-- Eliminar cuentas -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding CanDeleteAccountingAccount, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding DeleteAccountingAccountCommand}" EventName="Click"/>
                            </dxmvvm:Interaction.Behaviors>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Actions/DeleteList_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="Eliminar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </busyIndicator:BusyMask>
    </Border>
</UserControl>
