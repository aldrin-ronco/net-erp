<UserControl x:Class="NetErp.Books.AccountingAccountGroups.Views.AccountingAccountGroupFilterDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="350" d:DesignWidth="550"
             Background="#EEF1F5">

    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8" Padding="15"
                Width="{Binding DialogWidth}"
                Height="{Binding DialogHeight}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Account selector for adding filters -->
                <StackPanel Grid.Row="0" Orientation="Vertical">
                    <TextBlock Text="Seleccione una cuenta para agregar como filtro" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <dxe:ComboBoxEdit ItemsSource="{Binding Path=AccountingAccounts, UpdateSourceTrigger=PropertyChanged}"
                                          IsTextEditable="False"
                                          DisplayMember="FullName"
                                          ValueMember="Code"
                                          BorderBrush="#C8CED6"
                                          NullText="Seleccione una cuenta prefijo"
                                          EditValue="{Binding SelectedFilterAccountCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Margin="8,0,0,0" Padding="6"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Command="{Binding AttachFilterCommand}"
                                IsEnabled="{Binding CanAttachFilter, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}">
                            <Image Source="{dx:DXImage 'Images/Actions/Add_16x16.png'}" Width="16" Height="16"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Row 1: Label -->
                <TextBlock Grid.Row="1" Text="Filtros activos" Margin="0,16,0,5" FontWeight="SemiBold"/>

                <!-- Row 2: Filter chips -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                    <ItemsControl ItemsSource="{Binding GroupFilters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#E8F0FE" BorderBrush="#B0C4DE" BorderThickness="1"
                                        CornerRadius="4" Padding="6,3" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding FullName}" VerticalAlignment="Center" FontSize="12"/>
                                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Margin="6,0,0,0" Padding="0" VerticalAlignment="Center"
                                                Command="{Binding DataContext.DetachFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_16x16.png'}" Width="12" Height="12"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Row 3: Close button -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CloseCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cerrar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
