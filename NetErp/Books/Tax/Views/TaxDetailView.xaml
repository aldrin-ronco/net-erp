<UserControl x:Class="NetErp.Books.Tax.Views.TaxDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="550"
             Background="#EEF1F5">
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8" MinWidth="480">
            <Grid Margin="15,15,15,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form content -->
                <StackPanel Grid.Row="0">

                    <!-- Tipo de impuesto (ComboBox en creación, TextEdit en edición) -->
                    <TextBlock Text="Tipo de impuesto" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:ComboBoxEdit
                        Padding="2"
                        ItemsSource="{Binding Path=TaxCategories, UpdateSourceTrigger=PropertyChanged}"
                        IsTextEditable="False"
                        DisplayMember="Name"
                        NullText="Seleccione un tipo de impuesto"
                        NullValueButtonPlacement="EditBox"
                        EditValue="{Binding SelectedTaxCategoryGraphQLModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        BorderBrush="#C8CED6"
                        Margin="0,0,0,8"
                        Visibility="{Binding IsNewRecord, Converter={dxmvvm:BooleanToVisibilityConverter}}"/>
                    <TextBlock
                        Text="{Binding SelectedTaxCategoryGraphQLModel.Name, Mode=OneWay}"
                        FontSize="13"
                        Margin="0,0,0,8"
                        Visibility="{Binding IsNewRecord, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}"/>

                    <!-- Nombre -->
                    <TextBlock Text="Nombre" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  CharacterCasing="Upper"
                                  Padding="3"
                                  x:Name="Name"
                                  BorderBrush="#C8CED6"
                                  MaxLength="{Binding NameMaxLength}"
                                  Margin="0,0,0,8"/>

                    <!-- Porcentaje (visible solo si TaxCategory usa porcentaje) -->
                    <StackPanel Visibility="{Binding IsVisiblePercentage, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                Margin="0,0,0,8">
                        <TextBlock Text="Porcentaje" FontSize="13" Margin="0,0,0,3"/>
                        <dxe:SpinEdit MinValue="0" Increment="1"
                                      Padding="2"
                                      Text="{Binding Path=Rate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      IsFloatValue="False"
                                      MaskType="Numeric"
                                      x:Name="Rate"
                                      BorderBrush="#C8CED6"/>
                    </StackPanel>

                    <!-- Impuesto Generado -->
                    <StackPanel Visibility="{Binding IsVisibleGeneratedTaxSection, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                Margin="0,0,0,8">
                        <TextBlock Text="Impuesto Generado" FontSize="13" Margin="0,0,0,3"/>
                        <TextBlock Text="Operación" FontSize="12" Margin="0,0,0,3"/>
                        <dxe:ComboBoxEdit
                            Padding="2"
                            ItemsSource="{Binding Path=AccountingAccountOperations, UpdateSourceTrigger=PropertyChanged}"
                            IsTextEditable="False"
                            DisplayMember="FullName"
                            ValueMember="Id"
                            NullText="Seleccione cuenta contable"
                            NullValueButtonPlacement="EditBox"
                            EditValue="{Binding GeneratedTaxAccountId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            BorderBrush="#C8CED6"
                            Margin="0,0,0,8"/>

                        <StackPanel Visibility="{Binding IsVisibleGeneratedTaxRefundAccount, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                            <TextBlock Text="Devolución" FontSize="12" Margin="0,0,0,3"/>
                            <dxe:ComboBoxEdit
                                Padding="2"
                                ItemsSource="{Binding Path=AccountingAccountDevolutions, UpdateSourceTrigger=PropertyChanged}"
                                IsTextEditable="False"
                                DisplayMember="FullName"
                                ValueMember="Id"
                                NullText="Seleccione cuenta de devolución"
                                NullValueButtonPlacement="EditBox"
                                EditValue="{Binding GeneratedTaxRefundAccountId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                BorderBrush="#C8CED6"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Impuesto Descontable -->
                    <StackPanel Visibility="{Binding IsVisibleDeductibleTaxSection, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                Margin="0,0,0,8">
                        <TextBlock Text="Impuesto Descontable" FontSize="13" Margin="0,0,0,3"/>
                        <TextBlock Text="Operación" FontSize="12" Margin="0,0,0,3"/>
                        <dxe:ComboBoxEdit
                            Padding="2"
                            ItemsSource="{Binding Path=AccountingAccountOperations, UpdateSourceTrigger=PropertyChanged}"
                            IsTextEditable="False"
                            DisplayMember="FullName"
                            ValueMember="Id"
                            NullText="Seleccione cuenta contable"
                            NullValueButtonPlacement="EditBox"
                            EditValue="{Binding DeductibleTaxAccountId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            BorderBrush="#C8CED6"
                            Margin="0,0,0,8"/>

                        <StackPanel Visibility="{Binding IsVisibleDeductibleTaxRefundAccount, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                            <TextBlock Text="Devolución" FontSize="12" Margin="0,0,0,3"/>
                            <dxe:ComboBoxEdit
                                Padding="2"
                                ItemsSource="{Binding Path=AccountingAccountDevolutions, UpdateSourceTrigger=PropertyChanged}"
                                IsTextEditable="False"
                                DisplayMember="FullName"
                                ValueMember="Id"
                                NullText="Seleccione cuenta de devolución"
                                NullValueButtonPlacement="EditBox"
                                EditValue="{Binding DeductibleTaxRefundAccountId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                BorderBrush="#C8CED6"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Impuesto Activo -->
                    <dxe:CheckEdit Content="Impuesto Activo"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   Padding="2"
                                   IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Button bar centered -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
