<UserControl x:Class="NetErp.Books.WithholdingCertificateConfig.Views.WithholdingCertificateConfigDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:h="clr-namespace:NetErp.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="10">
        <busyIndicator:BusyMask x:Name="BusyIndicator"
                                IsBusy="{Binding IsBusy}"
                                IndicatorType="BouncingDot"
                                BusyContent="Please wait..."
                                BusyContentMargin="0,20,0,0">
            <Grid Margin="20,15,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Centro de costo -->
                <StackPanel Grid.Row="0" Orientation="Vertical">
                    <TextBlock Text="Centro de costo" Margin="0,0,0,2"/>
                    <TextBlock Text="Centro de costo del cual se tomarán los datos geográficos (dirección, ciudad, teléfonos) que podrían aparecer en el certificado de retención"
                               Foreground="Gray" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <dxe:ComboBoxEdit ItemsSource="{Binding Path=CostCenters, UpdateSourceTrigger=PropertyChanged}"
                                      IsTextEditable="False"
                                      DisplayMember="FullName"
                                      ValueMember="Id"
                                      BorderBrush="#C8CED6"
                                      NullText="Seleccione un centro de costo"
                                      ShowNullTextForEmptyValue="True"
                                      AllowNullInput="True"
                                      NullValueButtonPlacement="EditBox"
                                      EditValue="{Binding CostCenterId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Row 1: Nombre -->
                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,12,0,0">
                    <TextBlock Text="Nombre del certificado de retención" Margin="0,0,0,2"/>
                    <TextBlock Text="Nombre que aparecerá como título al imprimir el certificado, por ejemplo: CERTIFICADO DE RETENCIÓN POR COMPRAS"
                               Foreground="Gray" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <dxe:TextEdit Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  CharacterCasing="Upper"
                                  BorderBrush="#C8CED6"
                                  h:FocusBehavior.IsFocused="{Binding NameIsFocused, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  x:Name="Name"/>
                </StackPanel>

                <!-- Row 2: Descripción -->
                <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,12,0,0">
                    <TextBlock Text="Descripción del certificado de retención" Margin="0,0,0,2"/>
                    <TextBlock Text="Texto descriptivo de uso interno para diferenciar este certificado de otros configurados"
                               Foreground="Gray" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <dxe:TextEdit Text="{Binding Path=Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  BorderBrush="#C8CED6"
                                  x:Name="Description"/>
                </StackPanel>

                <!-- Row 3: Grupo de cuentas contables -->
                <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,12,0,0">
                    <TextBlock Text="Grupo de cuentas contables" Margin="0,0,0,2"/>
                    <TextBlock Text="Grupo de cuentas contables cuyas cuentas estarán disponibles para asociar al certificado de retención"
                               Foreground="Gray" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <dxe:ComboBoxEdit ItemsSource="{Binding Path=AccountingAccountGroups, UpdateSourceTrigger=PropertyChanged}"
                                      IsTextEditable="False"
                                      DisplayMember="Name"
                                      ValueMember="Id"
                                      BorderBrush="#C8CED6"
                                      NullText="Seleccione un grupo de cuentas contables"
                                      AllowNullInput="True"
                                      NullValueButtonPlacement="EditBox"
                                      EditValue="{Binding SelectedAccountingAccountGroupId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Row 4: Label cuentas contables -->
                <TextBlock Grid.Row="4" Text="Cuentas contables del grupo seleccionado" Margin="0,12,0,5"/>

                <!-- Row 5: Grid de cuentas -->
                <dxg:GridControl Grid.Row="5" Margin="0,0,0,0"
                                 ItemsSource="{Binding Path=AccountingAccounts, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False"
                                       AllowCascadeUpdate="False"
                                       EnableSelectedRowAppearance="True"
                                       ShowGroupPanel="False"
                                       AlternateRowBackground="Beige"
                                       AllowColumnMoving="False"
                                       ColumnFilterPopupMode="Disabled"
                                       AllowSorting="False"
                                       AllowColumnFiltering="False"
                                       IsColumnMenuEnabled="False"
                                       AllowPerPixelScrolling="False"
                                       RowMinHeight="16"/>
                    </dxg:GridControl.View>

                    <dxg:GridColumn Width="45" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          IsChecked="{Binding DataContext.IsAllChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </DataTemplate>
                        </dxg:GridColumn.HeaderTemplate>
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox Margin="2" Padding="0"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          IsChecked="{Binding RowData.Row.IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Header="Código" Width="Auto" HorizontalHeaderContentAlignment="Center"
                                    Binding="{Binding Code}">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>

                    <dxg:GridColumn Header="Cuenta contable" Width="*" HorizontalHeaderContentAlignment="Left"
                                    Binding="{Binding Name}"/>

                    <dxg:GridColumn Header="Naturaleza" Width="Auto" HorizontalHeaderContentAlignment="Center"
                                    Binding="{Binding Nature}">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                </dxg:GridControl>

                <!-- Row 6: Action buttons centered -->
                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Regresar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding Path=IsBusy, Converter={dxmvvm:BooleanNegationConverter}}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding GoBackCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Navigation/Backward_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Regresar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </busyIndicator:BusyMask>
    </Border>
</UserControl>
