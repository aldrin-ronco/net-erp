<UserControl x:Class="NetErp.Billing.BillingConfig.Views.BillingConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:cal="http://www.caliburnproject.org"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900"
             Background="#EEF1F5"
             FontFamily="Century Gothic">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.8*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Panel central -->
        <Border Grid.Column="1"
                Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="40">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.1"
                                  ShadowDepth="8"
                                  BlurRadius="20"/>
            </Border.Effect>

            <busyIndicator:BusyMask x:Name="BusyIndicator"
                                    IsBusy="{Binding IsBusy}"
                                    IndicatorType="BouncingDot"
                                    BusyContent="Por favor espere..."
                                    BusyContentMargin="0,20,0,0">

                <StackPanel>
                    <!-- Título -->
                    <TextBlock Text="CONFIGURACIÓN DE FACTURACIÓN"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"
                               Foreground="#2c3e50"/>

                    <!-- Subtítulo -->
                    <TextBlock Text="Parámetros predeterminados de facturación"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,35"
                               Foreground="#6c757d"/>

                    <!-- Cliente por defecto -->
                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="Cliente por defecto"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"
                                   Foreground="#2c3e50"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <dxe:TextEdit Grid.Column="0"
                                          IsReadOnly="True"
                                          NullText="Sin cliente seleccionado"
                                          ShowNullTextForEmptyValue="True"
                                          Text="{Binding Path=SelectedDefaultCustomerDisplay, Mode=OneWay}"
                                          VerticalContentAlignment="Center"
                                          Padding="3" Margin="0,0,4,0"/>
                            <Button Grid.Column="1" Padding="10,3"
                                    IsEnabled="{Binding IsEditing}"
                                    cal:Message.Attach="OpenDefaultCustomerSearchAsync">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{dx:DXImage 'Images/Print/Preview_16x16.png'}"
                                           Width="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="Buscar..." VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Botones -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- Editar -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding CanEdit}"
                                Command="{Binding EditCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Edit/Edit_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Editar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Deshacer -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding IsEditing}"
                                Command="{Binding UndoCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/History/Undo_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Deshacer" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Guardar -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}"
                                Command="{Binding SaveCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </busyIndicator:BusyMask>
        </Border>
    </Grid>
</UserControl>
