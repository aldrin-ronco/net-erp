<UserControl x:Class="NetErp.Billing.PriceList.Views.UpdatePromotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:uc="clr-namespace:NetErp.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             d:Background="White">

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="5">
        <busyIndicator:BusyMask x:Name="DataControlsBusyIndicator"
                                IsBusy="{Binding HasCriticalError}"
                                IndicatorType="BouncingDot"
                                BusyContent="Módulo bloqueado por error crítico. Use el botón Regresar para salir."
                                BusyContentMargin="0,20,0,0"
                                IsBusyAtStartup="False">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Banner inactiva -->
                <StackPanel Grid.Row="0" Margin="10,10,10,0" Visibility="{Binding IsPromotionNotActive, UpdateSourceTrigger=PropertyChanged, Converter={dxmvvm:BooleanToVisibilityConverter}}" Background="Red">
                    <TextBlock Text="ESTA PROMOCIÓN NO ESTÁ ACTIVA" HorizontalAlignment="Center" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Info de la promoción (read-only) -->
                <Grid Grid.Row="1" Margin="10,6,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical" Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="Nombre de la promoción" Margin="0,0,0,3"/>
                        <dxe:TextEdit Padding="2" CharacterCasing="Upper" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" BorderBrush="#C8CED6">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:FocusBehavior SourceObject="{Binding}" PropertyName="NameFocus"/>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:TextEdit>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Grid.Column="1" Margin="4,0,4,0">
                        <TextBlock Text="Fecha inicial" Margin="0,0,0,3"/>
                        <dxe:DateEdit Padding="2" Mask="G" ShowClearButton="False" AllowDefaultButton="False" BorderBrush="#C8CED6"
                                      MaskUseAsDisplayFormat="True" DateTime="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True">
                            <dxe:DateEdit.StyleSettings>
                                <dxe:DateEditNavigatorWithTimePickerStyleSettings/>
                            </dxe:DateEdit.StyleSettings>
                        </dxe:DateEdit>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Grid.Column="2" Margin="4,0,0,0">
                        <TextBlock Text="Fecha final" Margin="0,0,0,3"/>
                        <dxe:DateEdit Padding="2" Mask="G" ShowClearButton="False" AllowDefaultButton="False" BorderBrush="#C8CED6"
                                      MaskUseAsDisplayFormat="True" DateTime="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True">
                            <dxe:DateEdit.StyleSettings>
                                <dxe:DateEditNavigatorWithTimePickerStyleSettings/>
                            </dxe:DateEdit.StyleSettings>
                        </dxe:DateEdit>
                    </StackPanel>
                </Grid>

                <!-- Búsqueda -->
                <dxe:ButtonEdit x:Name="FilterSearch"
                                Grid.Row="2"
                                Text="{Binding FilterSearch, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                NullText="Escribe por lo menos 2 caracteres para iniciar la búsqueda"
                                ToolTip="Escribe aquí para buscar"
                                MinHeight="25"
                                CharacterCasing="Upper"
                                BorderBrush="#C8CED6"
                                AllowDefaultButton="False"
                                Margin="10,6,10,0">
                    <dxe:ButtonEdit.Buttons>
                        <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                    </dxe:ButtonEdit.Buttons>
                </dxe:ButtonEdit>

                <!-- Filtros -->
                <Grid Grid.Row="3" Margin="10,6,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical" Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="Catálogo de productos" Margin="0,0,0,3"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding Catalogs, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectedCatalog, UpdateSourceTrigger=PropertyChanged}"
                                          IsTextEditable="False" DisplayMember="Name" Padding="2" BorderBrush="#C8CED6"
                                          AllowNullInput="True" NullValueButtonPlacement="EditBox" NullText="Todos los catálogos"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Grid.Column="1" Margin="4,0,4,0"
                                Visibility="{Binding CanShowItemTypes, UpdateSourceTrigger=PropertyChanged, Converter={dx:BooleanToVisibilityConverter}}">
                        <TextBlock Text="Tipo de producto" Margin="0,0,0,3"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding ItemTypes, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectedItemType, UpdateSourceTrigger=PropertyChanged}"
                                          IsTextEditable="False" DisplayMember="Name" Padding="2" BorderBrush="#C8CED6"
                                          AllowNullInput="True" NullValueButtonPlacement="EditBox" NullText="Todos los tipos"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Grid.Column="2" Margin="4,0,4,0" Visibility="{Binding CanShowItemCategories, UpdateSourceTrigger=PropertyChanged, Converter={dx:BooleanToVisibilityConverter}}">
                        <TextBlock Text="Línea/Categoría" Margin="0,0,0,3"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding ItemCategories, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectedItemCategory, UpdateSourceTrigger=PropertyChanged}"
                                          IsTextEditable="False" DisplayMember="Name" Padding="2" BorderBrush="#C8CED6"
                                          AllowNullInput="True" NullValueButtonPlacement="EditBox" NullText="Todas las categorías"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Grid.Column="3" Margin="4,0,0,0" Visibility="{Binding CanShowItemSubCategories, UpdateSourceTrigger=PropertyChanged, Converter={dx:BooleanToVisibilityConverter}}">
                        <TextBlock Text="Sublínea/Subcategoría" Margin="0,0,0,3"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding ItemSubCategories, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectedItemSubCategory, UpdateSourceTrigger=PropertyChanged}"
                                          IsTextEditable="False" DisplayMember="Name" Padding="2" BorderBrush="#C8CED6"
                                          AllowNullInput="True" NullValueButtonPlacement="EditBox" NullText="Todas las subcategorías"/>
                    </StackPanel>
                </Grid>

                <!-- Grid -->
                <busyIndicator:BusyMask
                    IsBusy="{Binding IsBusy}"
                    IndicatorType="BouncingDot"
                    BusyContent="Por favor espere..."
                    BusyContentMargin="0,20,0,0"
                    IsBusyAtStartup="False"
                    Grid.Row="4" Margin="10,6,10,0">

                    <dxg:GridControl ItemsSource="{Binding PriceListItems, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <dxg:GridControl.View>
                            <dxg:TableView
                                AllowCascadeUpdate="False"
                                EnableSelectedRowAppearance="True"
                                ShowGroupPanel="False" AlternateRowBackground="Beige"
                                AllowColumnMoving="False" ColumnFilterPopupMode="Disabled"
                                AllowSorting="False" AllowColumnFiltering="False"/>
                        </dxg:GridControl.View>

                        <dxg:GridColumn Binding="{Binding Item.Code, UpdateSourceTrigger=PropertyChanged}" Header="Código" Width="65" HorizontalHeaderContentAlignment="Center"/>
                        <dxg:GridColumn Binding="{Binding Item.Name}" Header="Nombre del producto" Width="*"/>
                        <dxg:GridColumn Binding="{Binding Item.Reference}" Header="Referencia" HorizontalHeaderContentAlignment="Center"/>
                        <dxg:GridColumn Binding="{Binding Item.MeasurementUnit.Abbreviation}" Header="UND" Width="Auto"/>

                        <dxg:GridColumn Width="30" Header="{Binding}" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.HeaderTemplate>
                                <DataTemplate>
                                    <dxe:CheckEdit VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   ToolTip="Seleccionar / deseleccionar todos"
                                                   IsChecked="{Binding ItemsHeaderIsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </dxg:GridColumn.HeaderTemplate>
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Margin="4"
                                              HorizontalAlignment="Center"
                                              IsChecked="{Binding RowData.Row.IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl>
                </busyIndicator:BusyMask>

                <!-- Paginación -->
                <uc:GridPaging Grid.Row="5"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Center"
                               Margin="10,6,10,0"
                               ChangedIndexCommand="{Binding PaginationCommand}"
                               PageIndex="{Binding PageIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               PageSize="{Binding PageSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               TotalCount="{Binding TotalCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               ResponseTime="{Binding ResponseTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Botones de acción -->
                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            Command="{Binding GoBackCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Navigation/Backward_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Regresar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanPerformDataOperations, UpdateSourceTrigger=PropertyChanged}"
                            Command="{Binding AddCommand}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Actions/New_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Agregar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                   Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEditPromotionPermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanDelete, UpdateSourceTrigger=PropertyChanged}"
                            Command="{Binding DeleteListCommand}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Actions/DeleteList_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Eliminar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                   Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEditPromotionPermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanClearPromotion, UpdateSourceTrigger=PropertyChanged}"
                            Command="{Binding ClearPromotionCommand}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Actions/Clear_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Limpiar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                   Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEditPromotionPermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanPerformDataOperations, UpdateSourceTrigger=PropertyChanged}"
                            Command="{Binding EditCommand}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Setup/Properties_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Configurar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                   Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEditPromotionPermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </busyIndicator:BusyMask>
    </Border>
</UserControl>
