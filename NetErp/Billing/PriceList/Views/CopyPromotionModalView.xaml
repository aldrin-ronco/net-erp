<UserControl x:Class="NetErp.Billing.PriceList.Views.CopyPromotionModalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             mc:Ignorable="d"
             d:DesignHeight="260" d:DesignWidth="450"
             Width="{Binding DialogWidth}"
             Height="{Binding DialogHeight}"
             Background="#EEF1F5">

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="8,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Form content -->
            <StackPanel Grid.Row="0" Margin="15,15,15,5">

                <!-- Origen (read-only) -->
                <TextBlock Text="Promoción origen" FontSize="13" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding SourceName, UpdateSourceTrigger=PropertyChanged}"
                           FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"
                           Background="#F4F6F9" Padding="8,6" Margin="0,0,0,12"/>

                <!-- Nuevo nombre -->
                <TextBlock Text="Nombre de la nueva promoción" FontSize="13" Margin="0,0,0,5"/>
                <dxe:TextEdit Style="{StaticResource FocusedHighlightStyle}"
                              Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                              CharacterCasing="Upper" Padding="3" BorderBrush="#C8CED6"
                              MaxLength="{Binding NameMaxLength}"
                              Margin="0,0,0,12">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:FocusBehavior SourceObject="{Binding}" PropertyName="NameFocus"/>
                    </dxmvvm:Interaction.Behaviors>
                </dxe:TextEdit>

                <!-- Lista destino (opcional) -->
                <TextBlock Text="Lista de precios destino" FontSize="13" Margin="0,0,0,5"/>
                <dxe:ComboBoxEdit ItemsSource="{Binding AvailableParents}"
                                  SelectedItem="{Binding SelectedParent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMember="Name"
                                  AllowNullInput="True"
                                  NullValueButtonPlacement="EditBox"
                                  NullText="{Binding ParentNullText}"
                                  IsTextEditable="False"
                                  Padding="3" BorderBrush="#C8CED6"
                                  Margin="0,0,0,12"/>

            </StackPanel>

            <!-- Botones -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                <!-- Guardar -->
                <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                        IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                    </dxmvvm:Interaction.Behaviors>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Copiar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Cancelar -->
                <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                        IsCancel="True">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                    </dxmvvm:Interaction.Behaviors>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
