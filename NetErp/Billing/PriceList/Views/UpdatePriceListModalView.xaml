<UserControl x:Class="NetErp.Billing.PriceList.Views.UpdatePriceListModalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="500"
             Width="{Binding DialogWidth}"
             Height="{Binding DialogHeight}"
             Background="#EEF1F5">

    <UserControl.Resources>
        <h:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
        <h:StringToBooleanConverter x:Key="StringToBooleanConverter"/>
        <h:EnumBooleanConverter x:Key="EnumBooleanConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="8,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tabs -->
            <dx:DXTabControl Grid.Row="0" Margin="10,10,10,0" Padding="8"
                                    TabContentCacheMode="CacheTabsOnSelecting">

                <!-- Tab 1: Datos Básicos -->
                <dx:DXTabItem ToolTip="{Binding Data.BasicDataTabTooltip, Source={StaticResource DataContextProxy}}">
                    <dx:DXTabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Datos Básicos" VerticalAlignment="Center"/>
                            <Ellipse Width="8" Height="8" Fill="#FFA500" Margin="6,0,0,0" VerticalAlignment="Center"
                                     Visibility="{Binding Data.HasBasicDataErrors, Source={StaticResource DataContextProxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </dx:DXTabItem.Header>
                    <Grid Margin="10,10,10,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Nombre -->
                        <TextBlock Grid.Row="0" Text="Nombre de la lista de precios" FontSize="13" Margin="0,0,0,5"/>
                        <dxe:TextEdit Grid.Row="1"
                                      Style="{StaticResource FocusedHighlightStyle}"
                                      Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      CharacterCasing="Upper" Padding="3" BorderBrush="#C8CED6"
                                      MaxLength="{Binding NameMaxLength}"
                                      Margin="0,0,0,10">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:FocusBehavior SourceObject="{Binding}" PropertyName="NameFocus"/>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:TextEdit>

                        <!-- Modo de costo -->
                        <Grid Grid.Row="2" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Modo de costo" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <RadioButton Grid.Column="1" Content="Costo promedio" GroupName="CostMode" Margin="0,0,15,0"
                                         Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                         IsChecked="{Binding SelectedCostMode, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=USE_AVERAGE_COST, UpdateSourceTrigger=PropertyChanged}"/>
                            <RadioButton Grid.Column="2" Content="Por bodega" GroupName="CostMode"
                                         Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                         IsChecked="{Binding SelectedCostMode, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=COST_BY_STORAGE, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Bodega (visible solo cuando CostMode = COST_BY_STORAGE) -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,10"
                                    Visibility="{Binding ShowStorageSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Bodega" FontSize="13" Margin="0,0,0,5"/>
                            <dxe:ComboBoxEdit ItemsSource="{Binding Storages}"
                                              SelectedItem="{Binding SelectedStorage, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, ValidatesOnDataErrors=True}"
                                              DisplayMember="Name" IsTextEditable="False"
                                              NullText="Seleccione una bodega..."
                                              Padding="2" BorderBrush="#C8CED6"/>
                        </StackPanel>

                        <!-- Checkboxes -->
                        <dxe:CheckEdit Grid.Row="4" Content="¿Esta lista de precios discrimina impuesto?"
                                       Margin="0,0,0,6"
                                       IsChecked="{Binding IsTaxable, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                       Style="{StaticResource BlueCheckedTextStyle}" Padding="2"/>

                        <dxe:CheckEdit Grid.Row="5" Content="¿El precio de venta incluye impuesto?"
                                       Margin="0,0,0,6"
                                       IsChecked="{Binding PriceListIncludeTax, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                       Style="{StaticResource BlueCheckedTextStyle}" Padding="2"
                                       Visibility="{Binding IsTaxable, Converter={dxmvvm:BooleanToVisibilityConverter}}"/>

                        <!-- Tipo de cálculo -->
                        <Grid Grid.Row="6" Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Tipo de cálculo" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <RadioButton Grid.Column="1" GroupName="Formula" Content="Por defecto" Margin="0,0,15,0"
                                         Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                         IsChecked="{Binding SelectedFormula, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=D, UpdateSourceTrigger=PropertyChanged}"/>
                            <RadioButton Grid.Column="2" GroupName="Formula" Content="Alternativo"
                                         Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                         IsChecked="{Binding SelectedFormula, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=A, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Info formula -->
                        <Border Grid.Row="7" Background="#F7F9FB" BorderBrush="#D9DDE3" BorderThickness="1"
                                CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Image Source="{dx:DXImage 'Images/Function Library/Information_16x16.png'}" Width="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Fórmula para calcular el precio de venta" Foreground="#555" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Formula}" FontSize="12" FontFamily="Consolas" Foreground="#2C3E50"
                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Grid centros de costo -->
                        <DockPanel Grid.Row="8" MaxHeight="150">
                            <TextBlock DockPanel.Dock="Top" Text="Centros de costos compatibles" FontSize="13"
                                       HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <dxg:GridControl ItemsSource="{Binding ShadowCostCenters, UpdateSourceTrigger=PropertyChanged}">
                                <dxg:GridControl.View>
                                    <dxg:TableView AllowCascadeUpdate="False"
                                                   EnableSelectedRowAppearance="True"
                                                   ShowGroupPanel="False" AlternateRowBackground="Beige"
                                                   AllowEditing="False" AllowColumnMoving="False"/>
                                </dxg:GridControl.View>
                                <dxg:GridColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                            </dxg:GridControl>
                        </DockPanel>
                    </Grid>
                </dx:DXTabItem>

                <!-- Tab 2: Formas de pago -->
                <dx:DXTabItem Header="Formas de Pago">
                    <Grid Margin="10,10,10,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Seleccione las formas de pago que estarán disponibles cuando se facture con esta lista de precios"
                                   TextWrapping="Wrap" Margin="0,0,0,10" Foreground="Gray" FontSize="12"/>

                        <dxg:GridControl Grid.Row="1" ItemsSource="{Binding PaymentMethods, UpdateSourceTrigger=PropertyChanged}">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowCascadeUpdate="False" AllowSorting="False" AllowColumnMoving="False"
                                               EnableSelectedRowAppearance="True"
                                               ShowGroupPanel="False" AlternateRowBackground="Beige" AllowEditing="False"
                                               RowMinHeight="22"/>
                            </dxg:GridControl.View>
                            <dxg:GridColumn Header="Abreviación" Binding="{Binding Abbreviation, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                            <dxg:GridColumn Header="Nombre" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <dxg:GridColumn Header="" Width="30" HorizontalHeaderContentAlignment="Center">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox Margin="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                  IsChecked="{Binding RowData.Row.IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl>
                    </Grid>
                </dx:DXTabItem>

                <!-- Tab 3: Otros -->
                <dx:DXTabItem Header="Otros">
                    <StackPanel Margin="10,10,10,5">
                        <dxe:CheckEdit Content="Aplicar descuento automáticamente" Margin="0,0,0,8"
                                       IsChecked="{Binding AutoApplyDiscount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       Style="{StaticResource BlueCheckedTextStyle}" Padding="2"/>

                        <dxe:CheckEdit Content="Permitir cambiar precio de venta en la factura" Margin="0,0,0,8"
                                       IsChecked="{Binding EditablePrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       Style="{StaticResource BlueCheckedTextStyle}" Padding="2"/>

                        <dxe:CheckEdit Content="Lista de precios pública (Disponible para todos los clientes)" Margin="0,0,0,8"
                                       IsChecked="{Binding IsPublic, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       Style="{StaticResource BlueCheckedTextStyle}" Padding="2"/>

                        <dxe:CheckEdit Content="¿Lista de precios activa?" Margin="0,0,0,12"
                                       IsChecked="{Binding IsActiveFlag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       Style="{StaticResource BlueCheckedTextStyle}" Padding="2"/>

                        <TextBlock Text="Cuando el costo cambie quiero..." FontSize="13" Margin="0,0,0,5"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding ListUpdateBehaviorOnCostChange, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                          IsTextEditable="False" DisplayMember="Value"
                                          EditValue="{Binding SelectedListUpdateBehaviorOnCostChange, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                          ValueMember="Key" Padding="2" BorderBrush="#C8CED6"/>
                    </StackPanel>
                </dx:DXTabItem>

            </dx:DXTabControl>

            <!-- Botones -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                <!-- Guardar -->
                <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                        IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                    </dxmvvm:Interaction.Behaviors>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Cancelar -->
                <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                        IsCancel="True">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                    </dxmvvm:Interaction.Behaviors>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
