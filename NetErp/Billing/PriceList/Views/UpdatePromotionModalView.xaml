<UserControl x:Class="NetErp.Billing.PriceList.Views.UpdatePromotionModalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500"
             Background="#EEF1F5">

    <UserControl.Resources>
        <h:MultiplyConverter x:Key="MultiplyConverter"/>
    </UserControl.Resources>

    <UserControl.Width>
        <Binding Source="{x:Static SystemParameters.PrimaryScreenWidth}"
                 Converter="{StaticResource MultiplyConverter}" ConverterParameter="0.30"/>
    </UserControl.Width>
    <UserControl.Height>
        <Binding Source="{x:Static SystemParameters.PrimaryScreenHeight}"
                 Converter="{StaticResource MultiplyConverter}" ConverterParameter="0.45"/>
    </UserControl.Height>

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="8,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Form content -->
            <Grid Grid.Row="0" Margin="15,15,15,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Nombre -->
                <TextBlock Grid.Row="0" Text="Nombre de la promoción" FontSize="13" Margin="0,0,0,5"/>
                <dxe:TextEdit Grid.Row="1"
                              Style="{StaticResource FocusedHighlightStyle}"
                              Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                              CharacterCasing="Upper" Padding="3" BorderBrush="#C8CED6"
                              Margin="0,0,0,10">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:FocusBehavior SourceObject="{Binding}" PropertyName="NameFocus"/>
                    </dxmvvm:Interaction.Behaviors>
                </dxe:TextEdit>

                <!-- Fechas -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Fecha inicial" FontSize="13" Margin="0,0,0,5"/>
                        <dxe:DateEdit Padding="3" Mask="G" ShowClearButton="False" BorderBrush="#C8CED6"
                                      MinValue="{Binding MinimumDate, UpdateSourceTrigger=PropertyChanged}"
                                      MaskUseAsDisplayFormat="True" MaskType="DateTime"
                                      DateTime="{Binding StartDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                            <dxe:DateEdit.StyleSettings>
                                <dxe:DateEditNavigatorWithTimePickerStyleSettings/>
                            </dxe:DateEdit.StyleSettings>
                        </dxe:DateEdit>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fecha final" FontSize="13" Margin="0,0,0,5"/>
                        <dxe:DateEdit Padding="3" Mask="G" ShowClearButton="False" BorderBrush="#C8CED6"
                                      MinValue="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}"
                                      MaskUseAsDisplayFormat="True" MaskType="DateTime"
                                      DateTime="{Binding EndDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                            <dxe:DateEdit.StyleSettings>
                                <dxe:DateEditNavigatorWithTimePickerStyleSettings/>
                            </dxe:DateEdit.StyleSettings>
                        </dxe:DateEdit>
                    </StackPanel>
                </Grid>

                <!-- Activa -->
                <dxe:CheckEdit Grid.Row="3" Content="¿Promoción activa?" Margin="0,10,0,0"
                               IsChecked="{Binding IsActiveFlag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource BlueCheckedTextStyle}" Padding="2"/>
            </Grid>

            <!-- Botones -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                <!-- Guardar -->
                <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                        IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                    </dxmvvm:Interaction.Behaviors>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Cancelar -->
                <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                        IsCancel="True">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                    </dxmvvm:Interaction.Behaviors>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
