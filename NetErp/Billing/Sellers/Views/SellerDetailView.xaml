<UserControl x:Class="NetErp.Billing.Sellers.Views.SellerDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:cal="http://caliburnmicro.com"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="800"
             Background="#EEF1F5">

    <UserControl.Resources>
        <h:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <h:SimpleBooleanConverter x:Key="SimpleBooleanConverter" True="False" False="True"/>
        <h:EnumBooleanConverter x:Key="EnumBooleanConverter"/>
    </UserControl.Resources>

    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}"
                Height="{Binding DialogHeight}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form content -->
                <Grid Grid.Row="0" Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Número de documento -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Número de documento" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <dxe:TextEdit x:Name="IdentificationNumber"
                                      Style="{StaticResource FocusedHighlightStyle}"
                                      Grid.Column="1"
                                      MinWidth="180" Padding="3"
                                      MaskType="RegEx"
                                      Mask="{Binding IdentificationNumberMask}"
                                      IsReadOnly="{Binding IsNewRecord, Converter={StaticResource SimpleBooleanConverter}}"
                                      BorderBrush="#C8CED6"/>
                    </Grid>

                    <!-- Tabs -->
                    <dx:DXTabControl Grid.Row="1" Padding="8"
                                     TabContentCacheMode="CacheTabsOnSelecting"
                                     SelectedIndex="{Binding Path=SelectedIndexPage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                        <!-- TAB: Datos Basicos -->
                        <dx:DXTabItem ToolTip="{Binding Data.BasicDataTabTooltip, Source={StaticResource DataContextProxy}}">
                            <dx:DXTabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Datos Básicos" VerticalAlignment="Center"/>
                                    <Ellipse Width="8" Height="8" Fill="#FFA500" Margin="6,0,0,0" VerticalAlignment="Center"
                                             Visibility="{Binding Data.HasBasicDataErrors, Source={StaticResource DataContextProxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </dx:DXTabItem.Header>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Nombres (PN) -->
                                <TextBlock Text="Primer Nombre" Grid.Column="0" Grid.Row="0" Margin="0,0,4,3" FontSize="13"
                                           Visibility="{Binding CaptureInfoAsPN, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <dxe:TextEdit x:Name="FirstName" Grid.Column="0" Grid.Row="1"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              CharacterCasing="Upper" MaxLength="{Binding FirstNameMaxLength}"
                                              Visibility="{Binding CaptureInfoAsPN, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              Margin="0,0,4,8" Padding="3" BorderBrush="#C8CED6"/>

                                <TextBlock Text="Segundo Nombre" Grid.Column="1" Grid.Row="0" Margin="4,0,4,3" FontSize="13"
                                           Visibility="{Binding CaptureInfoAsPN, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <dxe:TextEdit x:Name="MiddleName" Grid.Column="1" Grid.Row="1"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              CharacterCasing="Upper" MaxLength="{Binding MiddleNameMaxLength}"
                                              Visibility="{Binding CaptureInfoAsPN, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              Margin="4,0,4,8" Padding="3" BorderBrush="#C8CED6"/>

                                <TextBlock Text="Primer Apellido" Grid.Column="2" Grid.Row="0" Margin="4,0,4,3" FontSize="13"
                                           Visibility="{Binding CaptureInfoAsPN, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <dxe:TextEdit x:Name="FirstLastName" Grid.Column="2" Grid.Row="1"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              CharacterCasing="Upper" MaxLength="{Binding FirstLastNameMaxLength}"
                                              Visibility="{Binding CaptureInfoAsPN, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              Margin="4,0,4,8" Padding="3" BorderBrush="#C8CED6"/>

                                <TextBlock Text="Segundo Apellido" Grid.Column="3" Grid.Row="0" Margin="4,0,0,3" FontSize="13"
                                           Visibility="{Binding CaptureInfoAsPN, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <dxe:TextEdit x:Name="MiddleLastName" Grid.Column="3" Grid.Row="1"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              CharacterCasing="Upper" MaxLength="{Binding MiddleLastNameMaxLength}"
                                              Visibility="{Binding CaptureInfoAsPN, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              Margin="4,0,0,8" Padding="3" BorderBrush="#C8CED6"/>

                                <!-- Telefonos -->
                                <TextBlock Text="Teléfono Fijo 1" Grid.Column="0" Grid.Row="2" Margin="0,0,4,3" FontSize="13"/>
                                <dxe:TextEdit x:Name="PrimaryPhone" Grid.Column="0" Grid.Row="3"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              MaxLength="10"
                                              MaskType="Simple" Mask="000 00 00"

                                              Margin="0,0,4,8" Padding="3" BorderBrush="#C8CED6" Validation.ErrorTemplate="{x:Null}"/>

                                <TextBlock Text="Teléfono Fijo 2" Grid.Column="1" Grid.Row="2" Margin="4,0,4,3" FontSize="13"/>
                                <dxe:TextEdit x:Name="SecondaryPhone" Grid.Column="1" Grid.Row="3"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              MaxLength="10"
                                              MaskType="Simple" Mask="000 00 00"

                                              Margin="4,0,4,8" Padding="3" BorderBrush="#C8CED6" Validation.ErrorTemplate="{x:Null}"/>

                                <TextBlock Text="Celular 1" Grid.Column="2" Grid.Row="2" Margin="4,0,4,3" FontSize="13"/>
                                <dxe:TextEdit x:Name="PrimaryCellPhone" Grid.Column="2" Grid.Row="3"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              MaxLength="14"
                                              MaskType="Simple" Mask="000 000 00 00"

                                              Margin="4,0,4,8" Padding="3" BorderBrush="#C8CED6" Validation.ErrorTemplate="{x:Null}"/>

                                <TextBlock Text="Celular 2" Grid.Column="3" Grid.Row="2" Margin="4,0,0,3" FontSize="13"/>
                                <dxe:TextEdit x:Name="SecondaryCellPhone" Grid.Column="3" Grid.Row="3"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              MaxLength="14"
                                              MaskType="Simple" Mask="000 000 00 00"

                                              Margin="4,0,0,8" Padding="3" BorderBrush="#C8CED6" Validation.ErrorTemplate="{x:Null}"/>

                                <!-- Pais -->
                                <TextBlock Text="País" Grid.Column="0" Grid.Row="4" Margin="0,0,0,3" FontSize="13"/>
                                <dxg:LookUpEdit Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="5"
                                                Margin="0,0,0,8" Padding="3"
                                                AutoPopulateColumns="False"
                                                IsCaseSensitiveSearch="False"
                                                FilterCondition="Contains"
                                                ImmediatePopup="True"
                                                ClearSelectionOnBackspace="True"
                                                NullText="Seleccione un país..."
                                                ItemsSource="{Binding Path=Countries}"
                                                DisplayMember="Name" ValueMember="Id"
                                                SelectedItem="{Binding Path=SelectedCountry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                BorderBrush="#C8CED6">
                                    <dxg:LookUpEdit.PopupContentTemplate>
                                        <ControlTemplate>
                                            <dxg:GridControl Name="PART_GridControl">
                                                <dxg:GridControl.View><dxg:TableView AutoWidth="True"/></dxg:GridControl.View>
                                                <dxg:GridControl.Columns>
                                                    <dxg:GridColumn Header="Nombre del país" FieldName="Name"/>
                                                </dxg:GridControl.Columns>
                                            </dxg:GridControl>
                                        </ControlTemplate>
                                    </dxg:LookUpEdit.PopupContentTemplate>
                                    <dxg:LookUpEdit.ItemsPanel>
                                        <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                    </dxg:LookUpEdit.ItemsPanel>
                                </dxg:LookUpEdit>

                                <!-- Departamento -->
                                <TextBlock Text="Departamento" Grid.Column="0" Grid.Row="6" Margin="0,0,0,3" FontSize="13"/>
                                <dxg:LookUpEdit Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="7"
                                                Margin="0,0,0,8" Padding="3"
                                                AutoPopulateColumns="False"
                                                IsCaseSensitiveSearch="False"
                                                FilterCondition="Contains"
                                                ImmediatePopup="True"
                                                ClearSelectionOnBackspace="True"
                                                NullText="Seleccione un departamento..."
                                                CharacterCasing="Upper"
                                                ItemsSource="{Binding Path=SelectedCountry.Departments, Mode=OneWay}"
                                                DisplayMember="Name" ValueMember="Id"
                                                SelectedItem="{Binding SelectedDepartment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                BorderBrush="#C8CED6">
                                    <dxg:LookUpEdit.PopupContentTemplate>
                                        <ControlTemplate>
                                            <dxg:GridControl Name="PART_GridControl">
                                                <dxg:GridControl.View><dxg:TableView AutoWidth="True" ShowSearchPanelMode="Never"/></dxg:GridControl.View>
                                                <dxg:GridControl.Columns>
                                                    <dxg:GridColumn Header="Nombre del departamento" FieldName="Name"/>
                                                </dxg:GridControl.Columns>
                                            </dxg:GridControl>
                                        </ControlTemplate>
                                    </dxg:LookUpEdit.PopupContentTemplate>
                                    <dxg:LookUpEdit.ItemsPanel>
                                        <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                    </dxg:LookUpEdit.ItemsPanel>
                                </dxg:LookUpEdit>

                                <!-- Municipio -->
                                <TextBlock Text="Municipio" Grid.Column="0" Grid.Row="8" Margin="0,0,0,3" FontSize="13"/>
                                <dxg:LookUpEdit Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="9"
                                                Margin="0,0,0,8" Padding="3"
                                                AutoPopulateColumns="False"
                                                IsCaseSensitiveSearch="False"
                                                FilterCondition="Contains"
                                                ImmediatePopup="True"
                                                ClearSelectionOnBackspace="True"
                                                NullText="Seleccione un municipio..."
                                                CharacterCasing="Upper"
                                                ItemsSource="{Binding Path=SelectedDepartment.Cities, Mode=OneWay}"
                                                DisplayMember="Name" ValueMember="Id"
                                                EditValue="{Binding SelectedCityId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                BorderBrush="#C8CED6">
                                    <dxg:LookUpEdit.PopupContentTemplate>
                                        <ControlTemplate>
                                            <dxg:GridControl Name="PART_GridControl">
                                                <dxg:GridControl.View><dxg:TableView AutoWidth="True" ShowSearchPanelMode="Never"/></dxg:GridControl.View>
                                                <dxg:GridControl.Columns>
                                                    <dxg:GridColumn Header="Nombre del municipio" FieldName="Name"/>
                                                </dxg:GridControl.Columns>
                                            </dxg:GridControl>
                                        </ControlTemplate>
                                    </dxg:LookUpEdit.PopupContentTemplate>
                                    <dxg:LookUpEdit.ItemsPanel>
                                        <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                    </dxg:LookUpEdit.ItemsPanel>
                                </dxg:LookUpEdit>

                                <!-- Direccion -->
                                <TextBlock Text="Dirección" Grid.Column="0" Grid.Row="10" Margin="0,0,0,3" FontSize="13"/>
                                <dxe:TextEdit x:Name="Address" Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="11"
                                              Style="{StaticResource FocusedHighlightStyle}"
                                              MaxLength="{Binding AddressMaxLength}"
                                              Padding="3" BorderBrush="#C8CED6" Margin="0,0,0,8"/>

                                <!-- Vendedor activo -->
                                <dxe:CheckEdit Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="12"
                                               IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                               Content="Vendedor activo"
                                               Style="{StaticResource BlueCheckedTextStyle}" Padding="2"/>
                            </Grid>
                        </dx:DXTabItem>

                        <!-- TAB: Centros de Costos -->
                        <dx:DXTabItem ToolTip="{Binding Data.CostCenterTabTooltip, Source={StaticResource DataContextProxy}}">
                            <dx:DXTabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Centros de Costos" VerticalAlignment="Center"/>
                                    <Ellipse Width="8" Height="8" Fill="#FFA500" Margin="6,0,0,0" VerticalAlignment="Center"
                                             Visibility="{Binding Data.HasCostCenterErrors, Source={StaticResource DataContextProxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </dx:DXTabItem.Header>
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="El vendedor debe estar asociado como mínimo a un centro de costo"
                                           Foreground="Gray" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <ListView ItemsSource="{Binding Path=CostCenters, Mode=OneWay}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="auto">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding Path=IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Width="auto" Header="Centro de Costo" DisplayMemberBinding="{Binding Path=Name, Mode=OneWay}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>
                        </dx:DXTabItem>

                        <!-- TAB: Emails -->
                        <dx:DXTabItem Header="Emails">
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Agregar email -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Column="0" Grid.Row="0" FontSize="13" Margin="0,0,4,5">
                                        <Run Text="Descripción"/>
                                        <Run Text=" ( Ej: Gerencia, Compras )" Foreground="Gray"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Grid.Row="0" FontSize="13" Margin="4,0,0,5">
                                        <Run Text="Email"/>
                                        <Run Text=" ( Ej: micorreo@gmail.com )" Foreground="Gray"/>
                                    </TextBlock>

                                    <dxe:TextEdit x:Name="EmailDescription" Grid.Column="0" Grid.Row="1"
                                                  Style="{StaticResource FocusedHighlightStyle}"
                                                  Margin="0,0,4,0" Padding="3" BorderBrush="#C8CED6"/>
                                    <dxe:TextEdit Style="{StaticResource FocusedHighlightStyle}"
                                                  EditValue="{Binding Path=Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Grid.Column="1" Grid.Row="1"
                                                  Margin="4,0,0,0" Padding="3" BorderBrush="#C8CED6"/>
                                    <Button Grid.Column="2" Grid.Row="1" Margin="4,0,0,0" Padding="4" x:Name="AddEmail" Cursor="Hand">
                                        <Image Source="{dx:DXImage 'Images/Actions/Add_16x16.png'}" Stretch="None">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value=".5"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Button>
                                </Grid>

                                <!-- Lista de emails -->
                                <DataGrid Grid.Row="1" Margin="0,8,0,0"
                                          AutoGenerateColumns="False"
                                          VerticalGridLinesBrush="LightGray"
                                          HorizontalGridLinesBrush="LightGray"
                                          BorderThickness="0"
                                          CanUserAddRows="False"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          MinRowHeight="30"
                                          AlternatingRowBackground="Beige"
                                          Background="Transparent"
                                          CanUserDeleteRows="False"
                                          cal:Message.Attach="[Event CellEditEnding] = [Action EndRowEditing]"
                                          ItemsSource="{Binding Path=Emails, Mode=OneWay}"
                                          SelectedItem="{Binding Path=SelectedEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Descripción" Width="*"
                                                            Binding="{Binding Path=Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <DataGridTextColumn Header="Email" Width="*"
                                                            Binding="{Binding Path=Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <DataGridTemplateColumn Width="40">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Margin="4" Padding="4"
                                                            Command="{Binding Data.DeleteMailCommand, Source={StaticResource DataContextProxy}}">
                                                        <Image Source="{dx:DXImage 'Images/Actions/Trash_16x16.png'}" Stretch="None"/>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </dx:DXTabItem>

                        <!-- TAB: Otros Datos -->
                        <dx:DXTabItem Header="Otros Datos">
                            <StackPanel Margin="0,8,0,0">
                                <!-- Zona -->
                                <TextBlock Text="Zona" FontSize="13" Margin="0,0,0,3"/>
                                <dxg:LookUpEdit Margin="0,0,0,8" Padding="3"
                                                AutoPopulateColumns="False"
                                                IsCaseSensitiveSearch="False"
                                                FilterCondition="Contains"
                                                ImmediatePopup="True"
                                                ClearSelectionOnBackspace="True"
                                                AllowNullInput="True"
                                                AssignNullValueOnClearingEditText="True"
                                                NullValueButtonPlacement="EditBox"
                                                NullText="Escriba para buscar zona (opcional)"
                                                CharacterCasing="Upper"
                                                ItemsSource="{Binding Path=Zones, Mode=OneWay}"
                                                DisplayMember="Name" ValueMember="Id"
                                                SelectedItem="{Binding SelectedZone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                BorderBrush="#C8CED6">
                                    <dxg:LookUpEdit.PopupContentTemplate>
                                        <ControlTemplate>
                                            <dxg:GridControl Name="PART_GridControl">
                                                <dxg:GridControl.View><dxg:TableView AutoWidth="True" ShowSearchPanelMode="Never"/></dxg:GridControl.View>
                                                <dxg:GridControl.Columns>
                                                    <dxg:GridColumn Header="Nombre" FieldName="Name"/>
                                                </dxg:GridControl.Columns>
                                            </dxg:GridControl>
                                        </ControlTemplate>
                                    </dxg:LookUpEdit.PopupContentTemplate>
                                    <dxg:LookUpEdit.ItemsPanel>
                                        <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                    </dxg:LookUpEdit.ItemsPanel>
                                </dxg:LookUpEdit>

                            </StackPanel>
                        </dx:DXTabItem>
                    </dx:DXTabControl>

                    <!-- Leyenda indicador de error -->
                    <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,4,0,0">
                        <Ellipse Width="8" Height="8" Fill="#FFA500" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Indica que la pestaña contiene campos obligatorios pendientes por diligenciar"
                                   Foreground="Gray" FontSize="11" FontStyle="Italic" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Button bar centered -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
