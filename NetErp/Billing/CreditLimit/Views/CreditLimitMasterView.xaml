<UserControl x:Class="NetErp.Billing.CreditLimit.Views.CreditLimitMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:uc="clr-namespace:NetErp.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Search label -->
            <TextBlock Grid.Row="0" Text="¿Qué desea buscar?" Margin="10,10,10,3"/>

            <!-- Row 1: Search box -->
            <dxe:ButtonEdit Grid.Row="1"
                            x:Name="FilterSearch"
                            Margin="10,0,10,0"
                            NullText="Escribe por lo menos 3 letras para iniciar la búsqueda"
                            ToolTip="Escribe aquí para buscar"
                            MinHeight="25"
                            CharacterCasing="Upper"
                            BorderBrush="#C8CED6"
                            AllowDefaultButton="False"
                            h:FocusBehavior.IsFocused="True"
                            IsEnabled="{Binding IsFilteringEnabled}"
                            EditValue="{Binding FilterSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <dxe:ButtonEdit.Buttons>
                    <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                </dxe:ButtonEdit.Buttons>
            </dxe:ButtonEdit>

            <!-- Row 2: Filter -->
            <dxe:CheckEdit Grid.Row="2"
                           Content="Mostrar solo clientes con cupo"
                           Margin="10,6,10,0"
                           IsEnabled="{Binding IsFilteringEnabled}"
                           IsChecked="{Binding OnlyCustomersWithCreditLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           Style="{StaticResource BlueCheckedTextStyle}" Padding="2"/>

            <!-- Row 3: Grid -->
            <busyIndicator:BusyMask Grid.Row="3"
                                    x:Name="BusyIndicator"
                                    IsBusy="{Binding IsBusy}"
                                    IndicatorType="BouncingDot"
                                    BusyContent="Por favor espere..."
                                    BusyContentMargin="0,20,0,0"
                                    IsBusyAtStartup="False">
                <dxg:GridControl Margin="10,6,10,0"
                                 ItemsSource="{Binding Path=CreditLimits, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 SelectedItem="{Binding SelectedCreditLimitItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <dxg:GridControl.View>
                        <dxg:TableView AllowCascadeUpdate="False"
                                       AllowColumnMoving="False"
                                       AllowSorting="False"
                                       EnableSelectedRowAppearance="True"
                                       AllowDragDrop="False"
                                       AllowFilterEditor="False"
                                       AllowResizing="False"
                                       AllowColumnFiltering="False"
                                       ShowGroupPanel="False"
                                       AlternateRowBackground="Beige">
                            <dxg:TableView.RowStyle>
                                <Style TargetType="dxg:RowControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Row.CreditLimit}" Value="0">
                                            <Setter Property="TextBlock.Foreground" Value="Red"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Row.Status}" Value="Pending">
                                            <Setter Property="Background" Value="#FFEED0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Row.Status}" Value="Saved">
                                            <Setter Property="Background" Value="#E0FFE0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Row.Status}" Value="Failed">
                                            <Setter Property="Background" Value="#FFE0E0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </dxg:TableView.RowStyle>
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridColumn Header="Nombre o razón social" HorizontalHeaderContentAlignment="Left" Width="*"
                                    Binding="{Binding Customer.AccountingEntity.SearchName, UpdateSourceTrigger=PropertyChanged}"/>
                    <dxg:GridColumn Header="N.I.T" HorizontalHeaderContentAlignment="Center" Width="Auto"
                                    Binding="{Binding Customer.AccountingEntity.IdentificationNumberWithVerificationDigit, UpdateSourceTrigger=PropertyChanged}"/>
                    <dxg:GridColumn Header="Información telefónica" HorizontalHeaderContentAlignment="Center" Width="Auto"
                                    Binding="{Binding Customer.AccountingEntity.TelephonicInformation, UpdateSourceTrigger=PropertyChanged}"/>
                    <dxg:GridColumn Header="Autorizado" Width="120" HorizontalHeaderContentAlignment="Center"
                                    Binding="{Binding CreditLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings MaskType="Numeric" MaskCulture="en-US" MaskUseAsDisplayFormat="True"
                                                  Mask="{Binding Mask, UpdateSourceTrigger=PropertyChanged}"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Usado" Width="120" ReadOnly="True" HorizontalHeaderContentAlignment="Center"
                                    Binding="{Binding Used, UpdateSourceTrigger=PropertyChanged}">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings MaskType="Numeric" MaskCulture="en-US" MaskUseAsDisplayFormat="True"
                                                  Mask="{Binding Mask, UpdateSourceTrigger=PropertyChanged}"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Disponible" Width="120" ReadOnly="True" HorizontalHeaderContentAlignment="Center"
                                    Binding="{Binding Available, UpdateSourceTrigger=PropertyChanged}">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings MaskType="Numeric" MaskCulture="en-US" MaskUseAsDisplayFormat="True"
                                                  Mask="{Binding Mask, UpdateSourceTrigger=PropertyChanged}"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </busyIndicator:BusyMask>

            <!-- Row 4: Pagination -->
            <uc:GridPaging Grid.Row="4"
                           Margin="10,6,10,10"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           ChangedIndexCommand="{Binding PaginationCommand}"
                           PageIndex="{Binding PageIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           PageSize="{Binding PageSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           TotalCount="{Binding TotalCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           ResponseTime="{Binding ResponseTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
    </Border>
</UserControl>
