<UserControl x:Class="NetErp.Global.AccessProfile.Views.AccessProfileDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="450"
             Background="#EEF1F5">

    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0"
                            IsBusyAtStartup="False">

        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}">

            <Grid Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Form Content -->
                <StackPanel Grid.Row="0">

                    <!-- Nombre -->
                    <TextBlock Text="Nombre" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit x:Name="ProfileName"
                                  Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  MaxLength="{Binding NameMaxLength}"
                                  CharacterCasing="Upper"
                                  Padding="3"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>

                    <!-- Descripción -->
                    <TextBlock Text="Descripción" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit Text="{Binding Description, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  MaxLength="{Binding DescriptionMaxLength}"
                                  Padding="3"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>

                    <!-- Activo (solo en edición) -->
                    <dxe:CheckEdit Content="Activo"
                                   IsChecked="{Binding ProfileIsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   Padding="2"
                                   Margin="0,0,0,6"
                                   Visibility="{Binding IsNewRecord, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}"/>

                </StackPanel>

                <!-- Row 1: Action Buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">

                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave}"
                            Command="{Binding SaveCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True"
                            Command="{Binding CancelCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
