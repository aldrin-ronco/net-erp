<UserControl x:Class="NetErp.Global.S3StorageLocation.Views.S3StorageLocationDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="420" d:DesignWidth="500"
             Background="#EEF1F5">
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}"
                Height="{Binding DialogHeight}">
            <Grid Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form content -->
                <StackPanel Grid.Row="0">

                    <!-- Descripción -->
                    <TextBlock Text="Descripción" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit x:Name="Description"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  CharacterCasing="Upper"
                                  Padding="3"
                                  MaxLength="{Binding DescriptionMaxLength}"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>

                    <!-- Clave -->
                    <TextBlock Text="Clave" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit x:Name="Key"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  Padding="3"
                                  MaxLength="{Binding KeyMaxLength}"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>

                    <!-- Bucket -->
                    <TextBlock Text="Bucket" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit x:Name="Bucket"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  Padding="3"
                                  MaxLength="{Binding BucketMaxLength}"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>

                    <!-- Directorio -->
                    <TextBlock Text="Directorio" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit x:Name="Directory"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  Padding="3"
                                  MaxLength="{Binding DirectoryMaxLength}"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>

                    <!-- Configuración AWS S3 -->
                    <TextBlock Text="Configuración AWS S3" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:ComboBoxEdit ItemsSource="{Binding AwsS3Configs}"
                                      DisplayMember="Description"
                                      SelectedItem="{Binding SelectedAwsS3Config, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Padding="2"
                                      BorderBrush="#C8CED6"
                                      IsTextEditable="False"
                                      NullText="SELECCIONE UNA CONFIGURACIÓN"
                                      AllowNullInput="True" NullValueButtonPlacement="EditBox"
                                      Margin="0,0,0,8"/>
                </StackPanel>

                <!-- Button bar centered -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
