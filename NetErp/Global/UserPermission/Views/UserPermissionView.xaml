<UserControl x:Class="NetErp.Global.UserPermission.Views.UserPermissionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="5">

        <busyIndicator:BusyMask x:Name="BusyIndicator"
                                IsBusy="{Binding IsBusy}"
                                IndicatorType="BouncingDot"
                                BusyContent="Por favor espere..."
                                BusyContentMargin="0,20,0,0"
                                IsBusyAtStartup="False">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: User selector + Filters -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Colaborador" FontSize="13" Margin="0,0,0,3"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding Collaborators}"
                                          SelectedItem="{Binding SelectedCollaborator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMember="Account.FullName"
                                          IsTextEditable="False"
                                          AllowNullInput="True"
                                          NullText="Seleccione un colaborador"
                                          NullValueButtonPlacement="EditBox"
                                          ShowNullValueButtonOnFocusOnly="False"
                                          Padding="2"
                                          BorderBrush="#C8CED6"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Visibility="{Binding HasCollaboratorSelected, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                        <TextBlock Text="Filtrar por módulo" FontSize="13" Margin="0,0,0,3"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding ModuleFilters}"
                                          SelectedItem="{Binding SelectedModuleFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMember="Name"
                                          IsTextEditable="False"
                                          AllowNullInput="True"
                                          NullText="Todos los módulos"
                                          NullValueButtonPlacement="EditBox"
                                          ShowNullValueButtonOnFocusOnly="False"
                                          Padding="2"
                                          BorderBrush="#C8CED6"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4"
                                Visibility="{Binding HasModuleFilterSelected, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                        <TextBlock Text="Filtrar por grupo" FontSize="13" Margin="0,0,0,3"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding GroupFilters}"
                                          SelectedItem="{Binding SelectedGroupFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMember="Name"
                                          IsTextEditable="False"
                                          AllowNullInput="True"
                                          NullText="Todos los grupos"
                                          NullValueButtonPlacement="EditBox"
                                          ShowNullValueButtonOnFocusOnly="False"
                                          Padding="2"
                                          BorderBrush="#C8CED6"/>
                    </StackPanel>
                </Grid>

                <!-- Row 1: Context message -->
                <TextBlock Grid.Row="1"
                           Text="Establezca permisos individuales para el colaborador seleccionado. Los permisos sin valor explícito heredarán el default de la empresa o del sistema."
                           Foreground="Gray" FontSize="11" FontStyle="Italic"
                           TextWrapping="Wrap" Margin="0,0,0,6"/>

                <!-- Row 2: TreeListControl -->
                <Border Grid.Row="2" BorderBrush="#C8CED6" BorderThickness="1" CornerRadius="4"
                        Visibility="{Binding HasCollaboratorSelected, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                    <dxg:TreeListControl x:Name="PermissionTreeList"
                                         ItemsSource="{Binding DisplayTreeNodes}">
                        <dxg:TreeListControl.Columns>

                            <!-- Column: Name -->
                            <dxg:TreeListColumn FieldName="Name" Header="Opción / Permiso" Width="*">
                                <dxg:TreeListColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RowData.Row.NodeBackground}">
                                            <StackPanel Orientation="Horizontal" Margin="6,3,4,3">
                                                <!-- Icono estado (solo permisos) -->
                                                <Image Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                                       Visibility="{Binding RowData.Row.IsPermission, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Source" Value="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"/>
                                                            <Setter Property="ToolTip" Value="Denegado / Requerido"/>
                                                            <Setter Property="Opacity" Value="{Binding RowData.Row.NegativeIconOpacity}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RowData.Row.IsEffectivelyPositive}" Value="True">
                                                                    <Setter Property="Source" Value="{dx:DXImage 'Images/XAF/BO_Validation.png'}"/>
                                                                    <Setter Property="ToolTip" Value="Permitido / Opcional"/>
                                                                    <Setter Property="Opacity" Value="{Binding RowData.Row.PositiveIconOpacity}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <TextBlock Text="{Binding RowData.Row.DisplayName}"
                                                           VerticalAlignment="Center"
                                                           FontWeight="{Binding RowData.Row.NodeFontWeight}"
                                                           FontSize="{Binding RowData.Row.NodeFontSize}"
                                                           Foreground="{Binding RowData.Row.NodeForeground}"
                                                           Padding="0,1,0,1"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </dxg:TreeListColumn.CellTemplate>
                            </dxg:TreeListColumn>

                            <!-- Column: Code -->
                            <dxg:TreeListColumn FieldName="Code" Header="Código" Width="180">
                                <dxg:TreeListColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RowData.Row.NodeBackground}">
                                            <TextBlock Text="{Binding RowData.Row.Code}"
                                                       Visibility="{Binding RowData.Row.IsPermission, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                                       FontSize="11" Foreground="Gray"
                                                       VerticalAlignment="Center" Margin="6,3"/>
                                        </Border>
                                    </DataTemplate>
                                </dxg:TreeListColumn.CellTemplate>
                            </dxg:TreeListColumn>

                            <!-- Column: Effective Default -->
                            <dxg:TreeListColumn FieldName="EffectiveDefaultDisplay" Header="Default Efectivo" Width="120"
                                                HorizontalHeaderContentAlignment="Center">
                                <dxg:TreeListColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RowData.Row.NodeBackground}">
                                            <TextBlock Text="{Binding RowData.Row.EffectiveDefaultDisplay}"
                                                       Visibility="{Binding RowData.Row.IsPermission, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,3"/>
                                        </Border>
                                    </DataTemplate>
                                </dxg:TreeListColumn.CellTemplate>
                            </dxg:TreeListColumn>

                            <!-- Column: User Value (editable) -->
                            <dxg:TreeListColumn FieldName="UserValue" Header="Valor Usuario" Width="150"
                                                HorizontalHeaderContentAlignment="Center">
                                <dxg:TreeListColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RowData.Row.NodeBackground}">
                                            <dxe:ComboBoxEdit
                                                EditValue="{Binding RowData.Row.UserValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Visibility="{Binding RowData.Row.IsPermission, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                                IsEnabled="{Binding DataContext.HasEditPermission, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                ItemsSource="{Binding RowData.Row.ApplicableOptions}"
                                                ValueMember="Value"
                                                DisplayMember="Display"
                                                IsTextEditable="False"
                                                AllowNullInput="True"
                                                NullText="Sin establecer"
                                                NullValueButtonPlacement="EditBox"
                                                ShowNullValueButtonOnFocusOnly="False"
                                                Padding="2"
                                                BorderThickness="0"
                                                ShowBorder="False"/>
                                        </Border>
                                    </DataTemplate>
                                </dxg:TreeListColumn.CellTemplate>
                            </dxg:TreeListColumn>

                            <!-- Column: Expiration Date -->
                            <dxg:TreeListColumn FieldName="ExpiresAt" Header="Expiración" Width="140"
                                                HorizontalHeaderContentAlignment="Center">
                                <dxg:TreeListColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RowData.Row.NodeBackground}">
                                            <dxe:DateEdit
                                                EditValue="{Binding RowData.Row.ExpiresAt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Visibility="{Binding RowData.Row.HasUserOverride, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                                IsEnabled="{Binding DataContext.HasEditPermission, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                AllowNullInput="True"
                                                NullText="Permanente"
                                                NullValueButtonPlacement="EditBox"
                                                ShowNullValueButtonOnFocusOnly="False"
                                                MinValue="{x:Static sys:DateTime.Today}"
                                                MaskType="DateTime"
                                                Mask="d"
                                                Padding="2"
                                                BorderThickness="0"
                                                ShowBorder="False"/>
                                        </Border>
                                    </DataTemplate>
                                </dxg:TreeListColumn.CellTemplate>
                            </dxg:TreeListColumn>

                        </dxg:TreeListControl.Columns>
                        <dxg:TreeListControl.View>
                            <dxg:TreeListView x:Name="PermissionTreeView"
                                              AllowEditing="False"
                                              ShowIndicator="False"
                                              ShowColumnHeaders="True"
                                              AlternateRowBackground="Transparent"
                                              ChildNodesPath="Children"
                                              TreeDerivationMode="ChildNodesSelector"
                                              RowMinHeight="28"/>
                        </dxg:TreeListControl.View>
                    </dxg:TreeListControl>
                </Border>

                <!-- Row 3: Action Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">

                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave}"
                            Command="{Binding SaveCommand}"
                            Visibility="{Binding HasCollaboratorSelected, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}" Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEditPermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Button>

                    <!-- Deshacer -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding HasChanges}"
                            Command="{Binding UndoCommand}"
                            Visibility="{Binding HasCollaboratorSelected, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/History/Undo_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Deshacer" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Asignación masiva -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanBatchAssign}"
                            Command="{Binding BatchAssignCommand}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/People/UserGroup_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Masivo" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}" Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasBatchAssignPermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Button>

                </StackPanel>

            </Grid>
        </busyIndicator:BusyMask>
    </Border>
</UserControl>
