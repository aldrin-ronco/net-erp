<UserControl x:Class="NetErp.Global.AwsS3Config.Views.AwsS3ConfigDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="350" d:DesignWidth="500"
             Background="#EEF1F5">
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8" MinWidth="420">
            <Grid Margin="15,15,15,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form content -->
                <StackPanel Grid.Row="0">

                    <!-- Descripción -->
                    <TextBlock Text="Descripción" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit Text="{Binding Path=Description, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  CharacterCasing="Upper"
                                  Padding="3"
                                  x:Name="Description"
                                  BorderBrush="#C8CED6"
                                  MaxLength="{Binding DescriptionMaxLength}"
                                  Margin="0,0,0,8"/>

                    <!-- Región -->
                    <TextBlock Text="Región" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:ComboBoxEdit Padding="2"
                                      ItemsSource="{Binding AwsSesRegionDictionary}"
                                      DisplayMember="Value" ValueMember="Key"
                                      IsTextEditable="False"
                                      EditValue="{Binding Path=Region, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      BorderBrush="#C8CED6"
                                      Margin="0,0,0,8"/>

                    <!-- Clave de acceso -->
                    <TextBlock Text="Clave de acceso" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit Text="{Binding Path=AccessKey, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  Padding="3"
                                  x:Name="AccessKey"
                                  BorderBrush="#C8CED6"
                                  MaxLength="{Binding AccessKeyMaxLength}"
                                  Margin="0,0,0,8"/>

                    <!-- Clave secreta -->
                    <TextBlock Text="Clave secreta" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit Text="{Binding Path=SecretKey, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  Padding="3"
                                  x:Name="SecretKey"
                                  BorderBrush="#C8CED6"
                                  MaxLength="{Binding SecretKeyMaxLength}"/>
                </StackPanel>

                <!-- Button bar centered -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
