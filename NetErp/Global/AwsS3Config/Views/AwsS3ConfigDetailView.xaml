<UserControl x:Class="NetErp.Global.AwsS3Config.Views.AwsS3ConfigDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NetErp.Global.AwsS3Config.Views"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
    xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
>
    <busyIndicator:BusyMask x:Name="BusyIndicator"
        IsBusy="{Binding IsBusy}"
        IndicatorType="BouncingDot"
        BusyContent="Please wait..."
        BusyContentMargin="0,20,0,0"
        IsBusyAtStartup="False">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />

            </Grid.RowDefinitions>
            <dxr:RibbonControl Grid.Row="0" Grid.ColumnSpan="3" IsSimplified="False"
                AllowSimplifiedRibbon="True" ShowApplicationButton="False" ToolbarShowMode="Hide"
                RibbonStyle="Office2010" ToolbarShowCustomizationButton="False"
                RibbonTitleBarVisibility="Collapsed" VerticalAlignment="Center">

                <dxr:RibbonPage Caption="General">

                    <dxr:RibbonPageGroup Caption="Acciones">
                        <dxb:BarButtonItem x:Name="btnBack"
                            Glyph="{dx:DXImage 'Images/Navigation/Backward_16x16.png'}"
                            LargeGlyph="{dx:DXImage 'Images/Navigation/Backward_32x32.png'}"
                            Content="Regresar"
                            RibbonStyle="Large"
                            Hint="Regresa a la lista"
                            Command="{Binding Path=GoBackCommand}" />
                        <dxb:BarItemSeparator />
                        <dxb:BarButtonItem
                            x:Name="btnSave"
                            Glyph="{dx:DXImage 'Images/Save/Save_16x16.png'}"
                            LargeGlyph="{dx:DXImage 'Images/Save/Save_32x32.png'}"
                            Content="Guardar"
                            RibbonStyle="Large"
                            IsEnabled="{Binding Path=CanSave, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            Hint="Guardar">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand Command="{Binding Path=SaveCommand}"
                                    EventName="ItemClick" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxb:BarButtonItem>
                        <dxb:BarItemSeparator />

                        <dxb:BarItemLinkSeparator />
                    </dxr:RibbonPageGroup>
                </dxr:RibbonPage>
            </dxr:RibbonControl>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>

                    <!--TODO
                corroborar distribución no responsive-->
                    <RowDefinition Height="1.0*" />
                    <RowDefinition Height="8.0*" />
                    <RowDefinition Height="1.0*" />

                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="7*" />
                    <ColumnDefinition Width="1.5*" />

                </Grid.ColumnDefinitions>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto" Grid.Row="1" Grid.Column="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />

                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="6 5 0 5"
                            Orientation="Vertical">
                            <TextBlock Text="Descripción" Margin="0 0 0 2" />
                            <dxe:TextEdit
                                Margin="0 0 0 2"
                                Text="{Binding Path=Description , UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                CharacterCasing="Upper"
                                x:Name="Name"
                            />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="6 5 0 5"
                            Orientation="Vertical">
                            <TextBlock Text="Región " Margin="0 0 0 2" />
                            <dxe:ComboBoxEdit Grid.Column="1" Padding="2"
                  ItemsSource="{Binding AwsSesRegionDictionary}"
                  DisplayMember="Value" ValueMember="Key"
                  IsTextEditable="False"
                  EditValue="{Binding Path=Region, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  BorderBrush="#C8CED6"/>
                            
                        </StackPanel>
                        <StackPanel Grid.Row="2" Margin="6 5 0 5"
                            Orientation="Vertical">
                            <TextBlock Text="Clave de acceso" Margin="0 0 0 2" />
                            <dxe:TextEdit
                                Margin="0 0 0 2"
                                Text="{Binding Path=AccessKey , UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                CharacterCasing="Upper"
                                x:Name="AccessKey"
                            />
                        </StackPanel>
                        <StackPanel Grid.Row="3" Margin="6 5 0 5"
                            Orientation="Vertical">
                            <TextBlock Text="Clave secreta" Margin="0 0 0 2" />
                            <dxe:TextEdit
                                Margin="0 0 0 2"
                                Text="{Binding Path=SecretKey , UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                CharacterCasing="Upper"
                                x:Name="SecretKey"
                            />
                        </StackPanel>


                    </Grid>
                </ScrollViewer>


            </Grid>

        </Grid>
    </busyIndicator:BusyMask>
</UserControl>