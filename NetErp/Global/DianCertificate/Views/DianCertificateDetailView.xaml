<UserControl x:Class="NetErp.Global.DianCertificate.Views.DianCertificateDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:h="clr-namespace:NetErp.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="550"
             Background="#EEF1F5">

    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}">
            <Grid Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form content -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- File path + browse -->
                        <TextBlock Text="Archivo del certificado (.p12 / .pfx)" FontSize="13" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <dxe:TextEdit Grid.Column="0"
                                          Text="{Binding FilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsReadOnly="True"
                                          NullText="Seleccione un archivo .p12 o .pfx"
                                          BorderBrush="#C8CED6"/>
                            <Button x:Name="BrowseButton" Grid.Column="1" Content="Examinar..." Padding="12,0" Margin="8,0,0,0"
                                    Cursor="Hand"
                                    Command="{Binding BrowseCommand}"/>
                        </Grid>

                        <!-- Password -->
                        <TextBlock Text="Contraseña del certificado" FontSize="13" Margin="0,0,0,3"/>
                        <dxe:PasswordBoxEdit
                            Password="{Binding FilePassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            NullText="Ingrese la contraseña del archivo .p12"
                            BorderBrush="#C8CED6"
                            Margin="0,0,0,8"/>

                        <!-- Extract button -->
                        <Button Margin="0,0,0,8" Padding="8,6"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{Binding CanExtract, Mode=OneWay}"
                                Command="{Binding ExtractCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Spreadsheet/FunctionsLookupAndReference_16x16.png'}"
                                       Margin="0,0,4,0" Width="16"/>
                                <TextBlock Text="Extraer información del certificado" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Certificate Info (visible after extraction) -->
                        <StackPanel>

                            <!-- Serial Number -->
                            <TextBlock Text="No. de serie" FontSize="13" Margin="0,0,0,3"/>
                            <dxe:TextEdit Text="{Binding SerialNumber, Mode=OneWay}"
                                          IsReadOnly="True" BorderBrush="#C8CED6" Margin="0,0,0,8"/>

                            <!-- Issuer -->
                            <TextBlock Text="Emisor" FontSize="13" Margin="0,0,0,3"/>
                            <dxe:TextEdit Text="{Binding Issuer, Mode=OneWay}"
                                          IsReadOnly="True" BorderBrush="#C8CED6" Margin="0,0,0,8"
                                          TextWrapping="Wrap" AcceptsReturn="True"
                                          VerticalContentAlignment="Top" MinHeight="25"/>

                            <!-- Subject -->
                            <TextBlock Text="Sujeto" FontSize="13" Margin="0,0,0,3"/>
                            <dxe:TextEdit Text="{Binding Subject, Mode=OneWay}"
                                          IsReadOnly="True" BorderBrush="#C8CED6" Margin="0,0,0,8"
                                          TextWrapping="Wrap" AcceptsReturn="True"
                                          VerticalContentAlignment="Top" MinHeight="25"/>

                            <!-- ValidFrom + ValidTo -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Válido desde" FontSize="13" Margin="0,0,0,3"/>
                                    <dxe:DateEdit EditValue="{Binding ValidFrom, Mode=OneWay}"
                                                  IsReadOnly="True" BorderBrush="#C8CED6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Text="Válido hasta" FontSize="13" Margin="0,0,0,3"/>
                                    <dxe:DateEdit EditValue="{Binding ValidTo, Mode=OneWay}"
                                                  IsReadOnly="True" BorderBrush="#C8CED6"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Button bar centered -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}"
                            Command="{Binding SaveCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True"
                            Command="{Binding CancelCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
