<UserControl x:Class="NetErp.Global.DianCertificate.Views.DianCertificateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:uc="clr-namespace:NetErp.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="5">
        <busyIndicator:BusyMask IsBusy="{Binding IsBusy}"
                                IndicatorType="BouncingDot"
                                BusyContent="Por favor espere..."
                                BusyContentMargin="0,20,0,0">
        <Grid>
            <!-- Empty State (full area when no records) -->
            <uc:EmptyStateView Visibility="{Binding ShowEmptyState, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                               Title="No hay certificados registrados"
                               Message="Cree un nuevo certificado DIAN para comenzar"
                               ContextInfo="Los certificados digitales (firma electrónica) son requeridos para la firma de documentos electrónicos ante la DIAN, como facturación electrónica y nómina electrónica. Aquí puede cargar archivos .p12 o .pfx que contengan su firma digital vigente."
                               Command="{Binding CreateCommand}"/>

            <!-- Content (visible when records exist) -->
            <Grid Visibility="{Binding HasRecords, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Search label -->
                <TextBlock Grid.Row="0" Text="¿Qué desea buscar?" Margin="10,10,10,3"/>

                <!-- Row 1: Search box -->
                <dxe:ButtonEdit
                    Grid.Row="1"
                    Margin="10,0,10,0"
                    NullText="Escribe por lo menos 3 letras para iniciar la búsqueda"
                    ToolTip="Escribe aquí para buscar"
                    MinHeight="25"
                    CharacterCasing="Upper"
                    BorderBrush="#C8CED6"
                    AllowDefaultButton="False"
                    h:FocusBehavior.IsFocused="True"
                    Text="{Binding FilterSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=500}">
                    <dxe:ButtonEdit.Buttons>
                        <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                    </dxe:ButtonEdit.Buttons>
                </dxe:ButtonEdit>

                <!-- Row 2: Filter + legend -->
                <Grid Grid.Row="2" Margin="10,6,10,0">
                    <dxe:CheckEdit Content="Mostrar únicamente certificados vigentes"
                                   Style="{StaticResource BlueCheckedTextStyle}"
                                   Padding="2"
                                   IsChecked="{Binding IsValidFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#E8F5E9" Width="14" Height="14" CornerRadius="2"
                                BorderBrush="#A5D6A7" BorderThickness="1" Margin="0,0,5,0"/>
                        <TextBlock Text="Certificado por defecto" FontSize="11" Foreground="Gray"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Row 3: Grid -->
                <dxg:GridControl Grid.Row="3" Margin="10,6,10,0"
                                 ItemsSource="{Binding Certificates, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 SelectedItem="{Binding SelectedCertificate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False"
                                       AllowCascadeUpdate="False"
                                       EnableSelectedRowAppearance="True"
                                       ShowGroupPanel="False"
                                       AlternateRowBackground="Beige"
                                       AllowColumnMoving="False"
                                       IsColumnMenuEnabled="False"
                                       ColumnFilterPopupMode="Disabled"
                                       AllowSorting="False"
                                       AllowColumnFiltering="False">
                            <dxg:TableView.RowStyle>
                                <Style TargetType="dxg:RowControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Row.IsDefault}" Value="True">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Row.IsExpired}" Value="True">
                                            <Setter Property="Foreground" Value="Red"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </dxg:TableView.RowStyle>
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridColumn Header="No. Serie" HorizontalHeaderContentAlignment="Center" Width="Auto"
                                    Binding="{Binding SerialNumber}">
                        <dxg:GridColumn.CellDisplayTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}" Padding="4,3,4,3"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellDisplayTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Emisor" HorizontalHeaderContentAlignment="Center" Width="*"
                                    Binding="{Binding Issuer}">
                        <dxg:GridColumn.CellDisplayTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}" TextWrapping="Wrap" Padding="4,3,4,3"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellDisplayTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Sujeto" HorizontalHeaderContentAlignment="Center" Width="*"
                                    Binding="{Binding Subject}">
                        <dxg:GridColumn.CellDisplayTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}" TextWrapping="Wrap" Padding="4,3,4,3"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellDisplayTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Válido desde" HorizontalHeaderContentAlignment="Center" Width="Auto"
                                    Binding="{Binding ValidFrom, StringFormat='{}{0:yyyy-MM-dd}'}">
                        <dxg:GridColumn.CellDisplayTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}" HorizontalAlignment="Center" Padding="4,3,4,3"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellDisplayTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="Válido hasta" HorizontalHeaderContentAlignment="Center" Width="Auto"
                                    Binding="{Binding ValidTo, StringFormat='{}{0:yyyy-MM-dd}'}">
                        <dxg:GridColumn.CellDisplayTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}" HorizontalAlignment="Center" Padding="4,3,4,3"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellDisplayTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>

                <!-- Row 4: Pagination -->
                <uc:GridPaging Grid.Row="4"
                           Margin="10,6,10,0"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           ChangedIndexCommand="{Binding PaginationCommand}"
                           PageIndex="{Binding PageIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           PageSize="{Binding PageSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           TotalCount="{Binding TotalCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           ResponseTime="{Binding ResponseTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Row 5: Action buttons centered -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">
                <!-- Nuevo -->
                <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                        IsEnabled="{Binding IsBusy, Converter={dxmvvm:BooleanNegationConverter}}">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding CreateCommand}" EventName="Click"/>
                    </dxmvvm:Interaction.Behaviors>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Actions/New_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Nuevo" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Eliminar -->
                <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                        IsEnabled="{Binding CanDeleteCertificate}">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand Command="{Binding DeleteCommand}" EventName="Click"/>
                    </dxmvvm:Interaction.Behaviors>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{dx:DXImage 'Images/Actions/DeleteList_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="Eliminar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                </StackPanel>
            </Grid>
        </Grid>
        </busyIndicator:BusyMask>
    </Border>
</UserControl>
