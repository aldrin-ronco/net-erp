<UserControl x:Class="NetErp.Global.MenuItem.Views.MenuItemDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:h="clr-namespace:NetErp.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="500"
             Background="#EEF1F5">
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}"
                Height="{Binding DialogHeight}">
            <Grid Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form content -->
                <StackPanel Grid.Row="0">

                    <!-- Módulo (filtro visual, no se envía a API) -->
                    <TextBlock Text="Módulo" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:ComboBoxEdit
                        ItemsSource="{Binding Modules}"
                        EditValue="{Binding SelectedModuleId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        DisplayMember="Name" ValueMember="Id"
                        IsTextEditable="False"
                        Padding="2"
                        BorderBrush="#C8CED6"
                        NullText="Seleccione un módulo"
                        Margin="0,0,0,8"/>

                    <!-- Grupo -->
                    <TextBlock Text="Grupo" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:ComboBoxEdit
                        ItemsSource="{Binding Groups}"
                        EditValue="{Binding SelectedGroupId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        DisplayMember="Name" ValueMember="Id"
                        IsTextEditable="False"
                        Padding="2"
                        BorderBrush="#C8CED6"
                        NullText="Seleccione un grupo"
                        Margin="0,0,0,8"/>

                    <!-- Clave del ítem -->
                    <TextBlock Text="Clave del ítem (ViewModel)" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit x:Name="ItemKey"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  Padding="3"
                                  MaxLength="{Binding ItemKeyMaxLength}"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>

                    <!-- Nombre -->
                    <TextBlock Text="Nombre" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit x:Name="Name"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  Padding="3"
                                  MaxLength="{Binding NameMaxLength}"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>

                    <!-- Icono -->
                    <TextBlock Text="Icono" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit x:Name="Icon"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  Padding="3"
                                  MaxLength="{Binding IconMaxLength}"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>

                    <!-- Checkboxes -->
                    <dxe:CheckEdit Content="Ítem bloqueable"
                                   IsChecked="{Binding IsLockable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   Style="{StaticResource BlueCheckedTextStyle}" Padding="2"
                                   Margin="0,0,0,6"/>
                    <dxe:CheckEdit Content="Ítem activo"
                                   IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   Style="{StaticResource BlueCheckedTextStyle}" Padding="2"/>
                </StackPanel>

                <!-- Button bar centered -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
