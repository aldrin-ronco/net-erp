<UserControl x:Class="NetErp.Global.GlobalConfig.Views.GlobalConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="#EEF1F5"
             FontFamily="Century Gothic">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.8*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Panel central -->
        <Border Grid.Column="1"
                Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="40">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.1"
                                  ShadowDepth="8"
                                  BlurRadius="20"/>
            </Border.Effect>

            <busyIndicator:BusyMask x:Name="BusyIndicator"
                                    IsBusy="{Binding IsBusy}"
                                    IndicatorType="BouncingDot"
                                    BusyContent="Por favor espere..."
                                    BusyContentMargin="0,20,0,0">

                <StackPanel>
                    <!-- Título -->
                    <TextBlock Text="CONFIGURACIÓN GLOBAL"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"
                               Foreground="#2c3e50"/>

                    <!-- Subtítulo -->
                    <TextBlock Text="Parámetros predeterminados del sistema"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,35"
                               Foreground="#6c757d"/>

                    <!-- Configuración AWS S3 predeterminada -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Configuración AWS S3 predeterminada"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"
                                   Foreground="#2c3e50"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding AwsS3Configs}"
                                          EditValue="{Binding SelectedDefaultAwsS3Config, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMember="Description"
                                          IsTextEditable="False"
                                          FontSize="14"
                                          Padding="10"
                                          Height="40"
                                          BorderThickness="2"
                                          NullText="Seleccione una configuración (opcional)"
                                          ShowNullTextForEmptyValue="True"/>
                    </StackPanel>

                    <!-- Certificado DIAN predeterminado -->
                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="Certificado DIAN predeterminado"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"
                                   Foreground="#2c3e50"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding DianCertificates}"
                                          EditValue="{Binding SelectedDefaultDianCertificate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMember="SerialNumber"
                                          IsTextEditable="False"
                                          FontSize="14"
                                          Padding="10"
                                          Height="40"
                                          BorderThickness="2"
                                          NullText="Seleccione un certificado (opcional)"
                                          ShowNullTextForEmptyValue="True"/>
                    </StackPanel>

                    <!-- Botón Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            HorizontalAlignment="Center"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}"
                            Command="{Binding SaveCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </busyIndicator:BusyMask>
        </Border>
    </Grid>
</UserControl>
