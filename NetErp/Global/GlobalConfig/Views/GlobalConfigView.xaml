<UserControl x:Class="NetErp.Global.GlobalConfig.Views.GlobalConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="#EEF1F5"
             FontFamily="Century Gothic">

    <UserControl.Resources>
        <Style x:Key="ActionButtonBorder" TargetType="Border">
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#1565C0"/>
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionButtonImage" TargetType="Image">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.8*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Panel central -->
        <Border Grid.Column="1"
                Grid.Row="1"
                Background="White"
                BorderBrush="#D9DDE3"
                BorderThickness="1"
                CornerRadius="12"
                Padding="40">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.1"
                                  ShadowDepth="8"
                                  BlurRadius="20"/>
            </Border.Effect>

            <busyIndicator:BusyMask x:Name="BusyIndicator"
                                    IsBusy="{Binding IsBusy}"
                                    IndicatorType="BouncingDot"
                                    BusyContent="Por favor espere..."
                                    BusyContentMargin="0,20,0,0">

                <StackPanel>
                    <!-- Título -->
                    <TextBlock Text="CONFIGURACIÓN GLOBAL"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"
                               Foreground="#2c3e50"/>

                    <!-- Subtítulo -->
                    <TextBlock Text="Parámetros predeterminados del sistema"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,35"
                               Foreground="#6c757d"/>

                    <!-- Configuración AWS S3 predeterminada -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Configuración AWS S3 predeterminada"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"
                                   Foreground="#2c3e50"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding AwsS3Configs}"
                                          EditValue="{Binding SelectedDefaultAwsS3Config, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMember="Description"
                                          IsTextEditable="False"
                                          IsEnabled="{Binding IsEditing}"
                                          Padding="2"
                                          BorderBrush="#C8CED6"
                                          NullText="Seleccione una configuración (opcional)"
                                          ShowNullTextForEmptyValue="True"/>
                    </StackPanel>

                    <!-- Certificado DIAN predeterminado -->
                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="Certificado DIAN predeterminado"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"
                                   Foreground="#2c3e50"/>
                        <dxe:ComboBoxEdit ItemsSource="{Binding DianCertificates}"
                                          EditValue="{Binding SelectedDefaultDianCertificate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMember="SerialNumber"
                                          IsTextEditable="False"
                                          IsEnabled="{Binding IsEditing}"
                                          Padding="2"
                                          BorderBrush="#C8CED6"
                                          NullText="Seleccione un certificado (opcional)"
                                          ShowNullTextForEmptyValue="True"/>
                    </StackPanel>

                    <!-- Botones -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">
                        <!-- Editar -->
                        <Border Style="{StaticResource ActionButtonBorder}">
                            <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"
                                    ToolTip="Editar la configuración"
                                    IsEnabled="{Binding CanEdit}"
                                    Command="{Binding EditCommand}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Source="{dx:DXImage 'Images/Edit/Edit_32x32.png'}" Width="32" Height="32"
                                           HorizontalAlignment="Center" Style="{StaticResource ActionButtonImage}"/>
                                    <TextBlock Text="Editar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <!-- Deshacer -->
                        <Border Style="{StaticResource ActionButtonBorder}">
                            <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"
                                    ToolTip="Deshacer cambios y salir del modo edición"
                                    IsEnabled="{Binding IsEditing}"
                                    Command="{Binding UndoCommand}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Source="{dx:DXImage 'Images/History/Undo_32x32.png'}" Width="32" Height="32"
                                           HorizontalAlignment="Center" Style="{StaticResource ActionButtonImage}"/>
                                    <TextBlock Text="Deshacer" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <!-- Guardar -->
                        <Border Style="{StaticResource ActionButtonBorder}">
                            <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"
                                    ToolTip="Guardar cambios"
                                    IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}"
                                    Command="{Binding SaveCommand}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32"
                                           HorizontalAlignment="Center" Style="{StaticResource ActionButtonImage}"/>
                                    <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </busyIndicator:BusyMask>
        </Border>
    </Grid>
</UserControl>
