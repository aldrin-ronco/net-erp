<UserControl x:Class="NetErp.Global.AuthorizationSequence.Views.AuthorizationSequenceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:NetErp.Global.AuthorizationSequence.Views"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="600"
             Background="#EEF1F5">

    <UserControl.Resources>
        <h:EnumBooleanConverter x:Key="EnumBooleanConverter"/>
        <h:DateOnlyToDateTimeConverter x:Key="DateOnlyConverter"/>
    </UserControl.Resources>

    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form content -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">

                        <!-- Origin Selection (only for new records) -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding OriginVisibility, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,8">
                            <RadioButton Content="Manual"
                                         Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                         GroupName="SequenceType"
                                         IsChecked="{Binding SelectedSequenceOrigin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,
                                                     Converter={StaticResource EnumBooleanConverter}, ConverterParameter=M}"/>
                            <Border Background="Transparent" Margin="15,0,0,0"
                                    ToolTip="{Binding DianUnavailableReason, Mode=OneWay}"
                                    ToolTipService.ShowOnDisabled="True">
                                <RadioButton Content="Desde DIAN"
                                             Style="{StaticResource BlueRadioButtonCheckedTextStyle}"
                                             GroupName="SequenceType"
                                             IsChecked="{Binding SelectedSequenceOrigin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,
                                                         Converter={StaticResource EnumBooleanConverter}, ConverterParameter=D}"
                                             IsEnabled="{Binding IsDianAvailable, Mode=OneWay}"/>
                            </Border>
                        </StackPanel>

                        <!-- DIAN Search Button -->
                        <Button Margin="0,0,0,8" Padding="8,6"
                                HorizontalAlignment="Stretch"
                                Command="{Binding SearchDianCommand}"
                                Visibility="{Binding Lv1Visibility, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Spreadsheet/FunctionsLookupAndReference_16x16.png'}"
                                       Margin="0,0,4,0" Width="16"/>
                                <TextBlock Text="Buscar autorizaciones DIAN" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- DIAN Authorization Selection -->
                        <StackPanel Visibility="{Binding AuthorizationsVisibility, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,8">
                            <TextBlock Text="Selecciona una autorización" FontSize="13" Margin="0,0,0,3"/>
                            <dxe:ComboBoxEdit
                                ItemsSource="{Binding AuthorizationSequences, UpdateSourceTrigger=PropertyChanged}"
                                IsTextEditable="False"
                                Padding="2"
                                DisplayMember="Description"
                                EditValue="{Binding SelectedDianAuthorization, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                NullText="Seleccione una autorización"
                                ShowNullTextForEmptyValue="True"
                                BorderBrush="#C8CED6"/>
                        </StackPanel>

                        <!-- Fields Section (visible when manual or DIAN selected) -->
                        <StackPanel Visibility="{Binding FieldsVisibility, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">

                            <!-- Centro de Costo -->
                            <TextBlock Text="Centro de costo" FontSize="13" Margin="0,0,0,3"/>
                            <dxe:ComboBoxEdit
                                ItemsSource="{Binding CostCenters, UpdateSourceTrigger=PropertyChanged}"
                                IsTextEditable="False"
                                Padding="2"
                                DisplayMember="Name"
                                ValueMember="Id"
                                EditValue="{Binding CostCenterId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding EnabledToCreated, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                NullText="Centro de costo al que se asignará esta numeración"
                                ShowNullTextForEmptyValue="True"
                                BorderBrush="#C8CED6"
                                Margin="0,0,0,8"/>

                            <!-- No Autorizacion + Fechas + Prefijo + Rango de facturación -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: No. Autorización, Fecha, Vence, Prefijo -->
                                <Grid Grid.Row="0" Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="No. Autorización" FontSize="13"/>
                                    <dxe:TextEdit Grid.Row="2"
                                        Style="{StaticResource FocusedHighlightStyle}"
                                        VerticalAlignment="Stretch"
                                        Text="{Binding Number, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                        IsReadOnly="{Binding SequenceD, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                        MaskType="RegEx"
                                        Mask="{Binding NumberMask}"
                                        x:Name="Number"
                                        BorderBrush="#C8CED6"/>
                                </Grid>

                                <Grid Grid.Row="0" Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Fecha" FontSize="13"/>
                                    <dxe:DateEdit Grid.Row="2"
                                        VerticalAlignment="Stretch"
                                        EditValue="{Binding StartDate, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource DateOnlyConverter}}"
                                        IsEnabled="{Binding SequenceD, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={dxmvvm:BooleanNegationConverter}}"
                                        BorderBrush="#C8CED6"/>
                                </Grid>

                                <Grid Grid.Row="0" Grid.Column="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Vence" FontSize="13"/>
                                    <dxe:DateEdit Grid.Row="2"
                                        VerticalAlignment="Stretch"
                                        EditValue="{Binding EndDate, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource DateOnlyConverter}}"
                                        IsEnabled="{Binding SequenceD, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={dxmvvm:BooleanNegationConverter}}"
                                        BorderBrush="#C8CED6"/>
                                </Grid>

                                <Grid Grid.Row="0" Grid.Column="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Prefijo" FontSize="13"/>
                                    <dxe:TextEdit Grid.Row="2"
                                        Style="{StaticResource FocusedHighlightStyle}"
                                        VerticalAlignment="Stretch"
                                        Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                        IsReadOnly="{Binding SequenceD, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                        CharacterCasing="Upper"
                                        MaxLength="{Binding PrefixMaxLength}"
                                        x:Name="Prefix"
                                        BorderBrush="#C8CED6"/>
                                </Grid>

                                <!-- Row 2: Section label -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7"
                                           Text="Rango de facturación" FontSize="13"/>

                                <!-- Row 4: Rango inicial + Rango final (aligned to col 0), Factura actual + Tipo (aligned to col 2-6) -->
                                <Grid Grid.Row="4" Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Rango inicial" FontSize="13"/>
                                    <dxe:SpinEdit Grid.Row="2" Grid.Column="0"
                                                  MinValue="0" Increment="1" IsFloatValue="False"
                                                  EditValueType="{x:Type sys:Int32}"
                                                  MaskType="Numeric" Mask="d"
                                                  AllowNullInput="True"
                                                  VerticalAlignment="Stretch"
                                                  EditValue="{Binding StartRange, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  IsReadOnly="{Binding SequenceD, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                  x:Name="StartRange"
                                                  BorderBrush="#C8CED6"/>

                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Rango final" FontSize="13"/>
                                    <dxe:SpinEdit Grid.Row="2" Grid.Column="2"
                                                  MinValue="0" Increment="1" IsFloatValue="False"
                                                  EditValueType="{x:Type sys:Int32}"
                                                  MaskType="Numeric" Mask="d"
                                                  AllowNullInput="True"
                                                  VerticalAlignment="Stretch"
                                                  EditValue="{Binding EndRange, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  IsReadOnly="{Binding SequenceD, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                  x:Name="EndRange"
                                                  BorderBrush="#C8CED6"/>
                                </Grid>

                                <Grid Grid.Row="4" Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Factura actual" FontSize="13"/>
                                    <dxe:SpinEdit Grid.Row="2"
                                                  MinValue="0" Increment="1" IsFloatValue="False"
                                                  EditValueType="{x:Type sys:Int32}"
                                                  MaskType="Numeric" Mask="d"
                                                  AllowNullInput="True"
                                                  VerticalAlignment="Stretch"
                                                  EditValue="{Binding CurrentInvoiceNumber, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  x:Name="CurrentInvoiceNumber"
                                                  BorderBrush="#C8CED6"/>
                                </Grid>

                                <Grid Grid.Row="4" Grid.Column="4" Grid.ColumnSpan="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Tipo" FontSize="13"/>
                                    <dxe:ComboBoxEdit Grid.Row="2"
                                        x:Name="ModeDictionary"
                                        VerticalAlignment="Stretch"
                                        ItemsSource="{Binding ModeDictionary, UpdateSourceTrigger=PropertyChanged}"
                                        IsTextEditable="False"
                                        Padding="2"
                                        DisplayMember="Value"
                                        ValueMember="Key"
                                        EditValue="{Binding Mode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        BorderBrush="#C8CED6"/>
                                </Grid>
                            </Grid>

                            <!-- Tipo de Autorización -->
                            <TextBlock Text="Tipo de autorización" FontSize="13" Margin="0,0,0,3"/>
                            <dxe:ComboBoxEdit
                                ItemsSource="{Binding AvailableAuthorizationSequenceTypes, UpdateSourceTrigger=PropertyChanged}"
                                IsTextEditable="False"
                                Padding="2"
                                DisplayMember="Name"
                                ValueMember="Id"
                                EditValue="{Binding AuthorizationSequenceTypeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding EnabledAST, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                NullText="Seleccione tipo de autorización"
                                ShowNullTextForEmptyValue="True"
                                BorderBrush="#C8CED6"
                                Margin="0,0,0,8"/>

                            <!-- Referencia -->
                            <TextBlock Text="Referencia" FontSize="13" Margin="0,0,0,3"/>
                            <dxe:TextEdit
                                Style="{StaticResource FocusedHighlightStyle}"
                                Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                CharacterCasing="Upper"
                                MaxLength="{Binding ReferenceMaxLength}"
                                x:Name="Reference"
                                BorderBrush="#C8CED6"
                                Margin="0,0,0,8"/>

                            <!-- Clave Técnica -->
                            <TextBlock Text="Clave técnica" FontSize="13" Margin="0,0,0,3"/>
                            <dxe:TextEdit
                                Style="{StaticResource FocusedHighlightStyle}"
                                Text="{Binding TechnicalKey, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                CharacterCasing="Upper"
                                MaxLength="{Binding TechnicalKeyMaxLength}"
                                IsReadOnly="{Binding SequenceD, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                x:Name="TechnicalKey"
                                BorderBrush="#C8CED6"
                                Margin="0,0,0,8"/>

                            <!-- Resolución de Relevo -->
                            <StackPanel Visibility="{Binding ReliefVisibility, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="0,0,0,8">
                                <TextBlock Text="Resolución de relevo" FontSize="13" Margin="0,0,0,3"/>
                                <dxe:ComboBoxEdit
                                    ItemsSource="{Binding OrphanAuthorizationSequences, UpdateSourceTrigger=PropertyChanged}"
                                    IsTextEditable="False"
                                    Padding="2"
                                    DisplayMember="Description"
                                    ValueMember="Id"
                                    EditValue="{Binding NextAuthorizationSequenceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    NullText="Seleccione resolución de relevo"
                                    ShowNullTextForEmptyValue="True"
                                    BorderBrush="#C8CED6"/>
                            </StackPanel>

                            <!-- Activa (solo visible en edición) -->
                            <dxe:CheckEdit Content="Autorización activa"
                                           Style="{StaticResource BlueCheckedTextStyle}"
                                           Padding="2"
                                           IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           Visibility="{Binding IsNewRecord, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Button bar centered -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}"
                            Command="{Binding SaveCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True"
                            Command="{Binding CancelCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
