<UserControl x:Class="NetErp.Global.AuthorizationSequence.Views.AuthorizationSequenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:local="clr-namespace:NetErp.Global.AuthorizationSequence.Views"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:uc="clr-namespace:NetErp.UserControls"
             xmlns:dict="clr-namespace:Dictionaries;assembly=Dictionaries"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
            CornerRadius="8" Margin="5">
        <Grid>
            <!-- Dependency State (highest priority) -->
            <uc:DependencyStateView Visibility="{Binding HasUnmetDependencies, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                    Title="Configuración requerida para Autorizaciones de numeración"
                                    Message="Antes de registrar autorizaciones de numeración, debe configurar los siguientes elementos:"
                                    Dependencies="{Binding Dependencies}"/>

            <!-- Empty State -->
            <uc:EmptyStateView Visibility="{Binding CanShowEmptyState, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                               Title="No hay autorizaciones de numeración registradas"
                               Message="Cree una nueva autorización de numeración para comenzar"
                               ContextInfo="Las autorizaciones de numeración definen los rangos y consecutivos autorizados para facturación electrónica por centro de costo."
                               Command="{Binding CreateCommand}"
                               HasPermission="{Binding HasCreatePermission}"/>

            <!-- Content -->
            <Grid Visibility="{Binding HasRecords, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Cost Center filter -->
                <StackPanel Grid.Row="0" Margin="0">
                    <TextBlock Text="Selecciona un almacén" Margin="10,10,10,3"/>
                    <dxe:ComboBoxEdit
                        ItemsSource="{Binding CostCenters, UpdateSourceTrigger=PropertyChanged}"
                        IsTextEditable="False"
                        DisplayMember="Name"
                        EditValue="{Binding SelectedCostCenter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        NullText="Todos los almacenes"
                        ShowNullTextForEmptyValue="True"
                        AllowNullInput="True"
                        NullValueButtonPlacement="EditBox"
                        Margin="10,0,10,0"
                        BorderBrush="#C8CED6"/>
                </StackPanel>

                <!-- Row 1: Search box -->
                <StackPanel Grid.Row="1" Margin="0">
                    <TextBlock Text="¿Qué desea buscar?" Margin="10,6,10,3"/>
                    <dxe:ButtonEdit
                        NullText="Escribe por lo menos 3 letras para iniciar la búsqueda"
                        ToolTip="Escribe aquí para buscar"
                        MinHeight="25"
                        CharacterCasing="Upper"
                        BorderBrush="#C8CED6"
                        AllowDefaultButton="False"
                        Margin="10,0,10,0"
                        h:FocusBehavior.IsFocused="True"
                        Text="{Binding FilterSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=500}">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>
                </StackPanel>

                <!-- Row 2: Active filter -->
                <dxe:CheckEdit Grid.Row="2" Content="Mostrar únicamente autorizaciones activas"
                               Style="{StaticResource BlueCheckedTextStyle}"
                               Padding="2"
                               IsChecked="{Binding IsActiveFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               Margin="10,6,10,0"/>

                <!-- Row 3: Grid -->
                <busyIndicator:BusyMask x:Name="BusyIndicator"
                                        IsBusy="{Binding IsBusy}"
                                        IndicatorType="BouncingDot"
                                        BusyContent="Por favor espere..."
                                        BusyContentMargin="0,20,0,0"
                                        Grid.Row="3">

                    <dxg:GridControl Margin="10,6,10,0"
                                     ItemsSource="{Binding Authorizations, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                     SelectedItem="{Binding SelectedAuthorizationSequence, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                        <dxg:GridControl.View>
                            <dxg:TableView AllowEditing="False"
                                           AllowCascadeUpdate="False"
                                           EnableSelectedRowAppearance="True"
                                           ShowGroupPanel="False"
                                           AlternateRowBackground="Beige"
                                           AllowColumnMoving="False"
                                           ColumnFilterPopupMode="Disabled"
                                           AllowSorting="False"
                                           AllowColumnFiltering="False">
                                <dxg:TableView.RowStyle>
                                    <Style TargetType="dxg:RowControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Row.IsActive}" Value="False">
                                                <Setter Property="Foreground" Value="Red"/>
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </dxg:TableView.RowStyle>
                            </dxg:TableView>
                        </dxg:GridControl.View>

                        <dxg:GridColumn Header="Descripción" HorizontalHeaderContentAlignment="Left" Width="*"
                                        Binding="{Binding Description}"/>
                        <dxg:GridColumn Header="Centro de Costo" HorizontalHeaderContentAlignment="Center" Width="Auto"
                                        Binding="{Binding CostCenter.Name}"/>
                        <dxg:GridColumn Header="Tipo de Autorización" HorizontalHeaderContentAlignment="Center" Width="Auto"
                                        Binding="{Binding AuthorizationSequenceType.Name}"/>
                        <dxg:GridColumn Header="Modo" HorizontalHeaderContentAlignment="Center" Width="Auto"
                                        FieldName="Mode">
                            <dxg:GridColumn.EditSettings>
                                <dxe:ComboBoxEditSettings ItemsSource="{x:Static dict:BooksDictionaries.ModeDictionary}"
                                                          DisplayMember="Value" ValueMember="Key"
                                                          IsTextEditable="False"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                        <dxg:GridColumn Header="Consecutivo Actual" HorizontalHeaderContentAlignment="Center" Width="Auto"
                                        Binding="{Binding CurrentInvoiceNumber}"/>
                        <dxg:GridColumn Header="Estado" HorizontalHeaderContentAlignment="Center" Width="80"
                                        Binding="{Binding IsActive, Converter={dxmvvm:BooleanToObjectConverter TrueValue='Activo', FalseValue='Inactivo'}}"/>

                    </dxg:GridControl>
                </busyIndicator:BusyMask>

                <!-- Row 4: Pagination -->
                <uc:GridPaging Grid.Row="4"
                               Margin="10,6,10,0"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Center"
                               ChangedIndexCommand="{Binding PaginationCommand}"
                               PageIndex="{Binding PageIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               PageSize="{Binding PageSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               TotalCount="{Binding TotalCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               ResponseTime="{Binding ResponseTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Row 5: Action buttons centered -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">
                    <!-- Nuevo -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanCreateAuthorizationSequence}"
                            Command="{Binding CreateCommand}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Actions/New_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Nuevo" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}" Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasCreatePermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Button>
                    <!-- Editar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanEditAuthorizationSequence}"
                            Command="{Binding EditCommand}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Edit/Edit_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Editar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}" Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEditPermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Button>
                    <!-- Eliminar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanDeleteAuthorizationSequence}"
                            Command="{Binding DeleteCommand}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Actions/DeleteList_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Eliminar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}" Width="14" Height="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,-2,12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDeletePermission}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
