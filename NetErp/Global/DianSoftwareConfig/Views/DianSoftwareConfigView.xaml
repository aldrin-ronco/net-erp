<UserControl x:Class="NetErp.Global.DianSoftwareConfig.Views.DianSoftwareConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="#EEF1F5"
             FontFamily="Century Gothic">

    <UserControl.Resources>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2c3e50"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ConfigTextEditStyle" TargetType="dxe:TextEdit">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <DataTemplate x:Key="ConfigFormTemplate">
            <ScrollViewer dx:ScrollBarExtensions.ScrollBarMode="TouchOverlap"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20,15,20,15">

                    <!-- Selector de entorno -->
                    <Border Background="#F8F9FA"
                            CornerRadius="6"
                            Padding="14,10"
                            Margin="0,0,0,18"
                            BorderBrush="#DEE2E6"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Entorno DIAN"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Producción"
                                             GroupName="EnvironmentGroup"
                                             IsChecked="{Binding IsProductionSelected, Mode=TwoWay}"
                                             IsEnabled="{Binding CanChangeEnvironment}"
                                             FontSize="13"
                                             VerticalAlignment="Center"
                                             Margin="0,0,30,0"/>
                                <RadioButton Content="Habilitación (Sandbox)"
                                             GroupName="EnvironmentGroup"
                                             IsChecked="{Binding IsSandboxSelected, Mode=TwoWay}"
                                             IsEnabled="{Binding CanChangeEnvironment}"
                                             FontSize="13"
                                             VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Grid de campos en 2 columnas -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- NIT del proveedor -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="NIT del proveedor tecnológico" Style="{StaticResource FieldLabelStyle}"/>
                            <dxe:TextEdit EditValue="{Binding ProviderNit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsEditing}"
                                          NullText="Ingrese el NIT"
                                          ShowNullTextForEmptyValue="True"
                                          Style="{StaticResource ConfigTextEditStyle}"/>
                        </StackPanel>

                        <!-- DV del proveedor -->
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="DV del proveedor tecnológico" Style="{StaticResource FieldLabelStyle}"/>
                            <dxe:TextEdit EditValue="{Binding ProviderDv, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsEditing}"
                                          NullText="Ingrese el DV"
                                          ShowNullTextForEmptyValue="True"
                                          Style="{StaticResource ConfigTextEditStyle}"/>
                        </StackPanel>

                        <!-- Software ID -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="ID del software DIAN" Style="{StaticResource FieldLabelStyle}"/>
                            <dxe:TextEdit EditValue="{Binding SoftwareId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsEditing}"
                                          NullText="Ingrese el ID del software"
                                          ShowNullTextForEmptyValue="True"
                                          Style="{StaticResource ConfigTextEditStyle}"/>
                        </StackPanel>

                        <!-- Software PIN -->
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="PIN del software DIAN" Style="{StaticResource FieldLabelStyle}"/>
                            <dxe:TextEdit EditValue="{Binding SoftwarePin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsEditing}"
                                          NullText="Ingrese el PIN"
                                          ShowNullTextForEmptyValue="True"
                                          Style="{StaticResource ConfigTextEditStyle}"/>
                        </StackPanel>

                        <!-- Test Set ID -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="Test Set ID (set de pruebas)" Style="{StaticResource FieldLabelStyle}"/>
                            <dxe:TextEdit EditValue="{Binding TestSetId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsEditing}"
                                          NullText="Ingrese el Test Set ID (solo habilitación)"
                                          ShowNullTextForEmptyValue="True"
                                          Style="{StaticResource ConfigTextEditStyle}"/>
                        </StackPanel>

                        <!-- Service URL -->
                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="URL del servicio DIAN" Style="{StaticResource FieldLabelStyle}"/>
                            <dxe:TextEdit EditValue="{Binding ServiceUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsEditing}"
                                          NullText="https://..."
                                          ShowNullTextForEmptyValue="True"
                                          Style="{StaticResource ConfigTextEditStyle}"/>
                        </StackPanel>

                        <!-- WSDL URL -->
                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,16">
                            <TextBlock Text="URL del WSDL del servicio DIAN" Style="{StaticResource FieldLabelStyle}"/>
                            <dxe:TextEdit EditValue="{Binding WsdlUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsEditing}"
                                          NullText="https://..."
                                          ShowNullTextForEmptyValue="True"
                                          Style="{StaticResource ConfigTextEditStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel central -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="12"
                Padding="32,24,32,24"
                Margin="0,24,0,24"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.1"
                                  ShadowDepth="8"
                                  BlurRadius="20"/>
            </Border.Effect>

            <busyIndicator:BusyMask x:Name="BusyIndicator"
                                    IsBusy="{Binding IsBusy}"
                                    IndicatorType="BouncingDot"
                                    BusyContent="Por favor espere..."
                                    BusyContentMargin="0,20,0,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cabecera -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="CONFIGURACIÓN DEL SOFTWARE DIAN"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"
                                   Foreground="#2c3e50"/>
                        <TextBlock Text="Parámetros del proveedor tecnológico DIAN por categoría de documento y entorno"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Foreground="#6c757d"/>
                    </StackPanel>

                    <!-- TabControl con las 3 categorías -->
                    <dx:DXTabControl Grid.Row="1"
                                     Background="Transparent"
                                     TabContentCacheMode="CacheTabsOnSelecting"
                                     SelectedIndex="{Binding SelectedCategoryIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <dx:DXTabItem Header="Facturación electrónica"
                                      IsEnabled="{Binding CanSelectInvoiceTab}">
                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource ConfigFormTemplate}"/>
                        </dx:DXTabItem>
                        <dx:DXTabItem Header="Nómina electrónica"
                                      IsEnabled="{Binding CanSelectPayrollTab}">
                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource ConfigFormTemplate}"/>
                        </dx:DXTabItem>
                        <dx:DXTabItem Header="Documento soporte"
                                      IsEnabled="{Binding CanSelectSupportTab}">
                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource ConfigFormTemplate}"/>
                        </dx:DXTabItem>
                    </dx:DXTabControl>

                    <!-- Botones (fuera de los tabs, siempre visibles) -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">
                        <!-- Editar -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding CanEdit}"
                                Command="{Binding EditCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Edit/Edit_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Editar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Deshacer -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding IsEditing}"
                                Command="{Binding UndoCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/History/Undo_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Deshacer" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Guardar -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}"
                                Command="{Binding SaveCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </busyIndicator:BusyMask>
        </Border>
    </Grid>
</UserControl>
