<UserControl x:Class="NetErp.Global.Collaborator.Views.CollaboratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:uc="clr-namespace:NetErp.UserControls"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0"
                            IsBusyAtStartup="False">

        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="5">
            <Grid>

                <!-- Empty State -->
                <uc:EmptyStateView Visibility="{Binding ShowEmptyState, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                                   Title="No hay colaboradores registrados"
                                   Message="Invite un nuevo colaborador para comenzar"
                                   ContextInfo="Los colaboradores son usuarios que tienen acceso al sistema para gestionar la información de esta empresa."
                                   Command="{Binding InviteCollaboratorCommand}"
                                   ButtonText="Invitar"/>

                <!-- Content -->
                <Grid Visibility="{Binding HasRecords, Converter={dxmvvm:BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Search Label -->
                    <TextBlock Grid.Row="0" Text="¿Qué colaborador desea buscar?" Margin="10,10,10,3"/>

                    <!-- Row 1: Search Field -->
                    <dxe:ButtonEdit Grid.Row="1"
                                    Margin="10,0,10,0"
                                    MinHeight="25"
                                    NullText="Escribe por lo menos 3 letras para iniciar la búsqueda"
                                    ToolTip="Escribe aquí para buscar"
                                    CharacterCasing="Upper"
                                    BorderBrush="#C8CED6"
                                    AllowDefaultButton="False"
                                    h:FocusBehavior.IsFocused="True"
                                    Text="{Binding FilterSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=500}">
                        <dxe:ButtonEdit.Buttons>
                            <dxe:ButtonInfo IsLeft="True" GlyphKind="Search" Margin="4,0,2,0"/>
                        </dxe:ButtonEdit.Buttons>
                    </dxe:ButtonEdit>

                    <!-- Row 2: Grid -->
                    <dxg:GridControl Grid.Row="2"
                                     Margin="10,6,10,0"
                                     ItemsSource="{Binding FilteredCollaborators}"
                                     SelectedItem="{Binding SelectedItem, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                        <dxg:GridControl.View>
                            <dxg:TableView AllowEditing="False"
                                           AllowCascadeUpdate="False"
                                           EnableSelectedRowAppearance="True"
                                           ShowGroupPanel="False"
                                           AlternateRowBackground="Beige"
                                           AllowColumnMoving="False">
                                <dxg:TableView.FormatConditions>
                                    <dxg:FormatCondition FieldName="IsOwner" Value1="True"
                                                         ApplyToRow="True">
                                        <dx:Format Foreground="#1565C0"/>
                                    </dxg:FormatCondition>
                                </dxg:TableView.FormatConditions>
                            </dxg:TableView>
                        </dxg:GridControl.View>

                        <dxg:GridColumn Header="Nombre" HorizontalHeaderContentAlignment="Left" Width="*"
                                        VisibleIndex="0"
                                        Binding="{Binding FullName}"
                                        AllowSorting="False"/>

                        <dxg:GridColumn Header="Correo electrónico" HorizontalHeaderContentAlignment="Left" Width="*"
                                        VisibleIndex="1"
                                        Binding="{Binding Email}"
                                        AllowSorting="False"/>

                        <dxg:GridColumn Header="Profesión" HorizontalHeaderContentAlignment="Left" Width="Auto"
                                        VisibleIndex="2"
                                        Binding="{Binding Profession}"
                                        AllowSorting="False"/>

                        <dxg:GridColumn Header="Perfiles" HorizontalHeaderContentAlignment="Left" Width="*"
                                        VisibleIndex="3"
                                        Binding="{Binding ProfileNames}"
                                        AllowSorting="False"/>

                        <dxg:GridColumn Header="Invitado por" HorizontalHeaderContentAlignment="Left" Width="Auto"
                                        VisibleIndex="4"
                                        Binding="{Binding InvitedBy}"
                                        AllowSorting="False"/>

                        <dxg:GridColumn Header="Ingreso" HorizontalHeaderContentAlignment="Center" Width="90"
                                        VisibleIndex="5"
                                        AllowSorting="False">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RowData.Row.JoinedAtDisplay}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl>

                    <!-- Row 3: Action Buttons -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">

                        <!-- Invitar -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding IsBusy, Converter={dxmvvm:BooleanNegationConverter}}"
                                Command="{Binding InviteCollaboratorCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Actions/New_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Invitar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Editar -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding CanEditCollaborator}"
                                Command="{Binding EditCollaboratorCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Edit/Edit_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Editar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Eliminar -->
                        <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                                IsEnabled="{Binding CanDeleteCollaborator}"
                                Command="{Binding DeleteCollaboratorCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{dx:DXImage 'Images/Actions/DeleteList_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="Eliminar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                </Grid>

            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
