<UserControl x:Class="NetErp.Global.Collaborator.Views.CollaboratorDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="550"
             Background="#EEF1F5">

    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0"
                            IsBusyAtStartup="False">

        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}"
                Height="{Binding DialogHeight}">

            <Grid Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Header del colaborador (solo lectura) -->
                <Border Grid.Row="0" Background="#f8f9fa" CornerRadius="8"
                        Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0" Width="60" Height="60"
                                CornerRadius="30" Background="#007bff"
                                Margin="0,0,15,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FullName[0]}"
                                       FontSize="24" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FullName}"
                                       FontSize="16" FontWeight="SemiBold" Foreground="#2c3e50"/>
                            <TextBlock Text="{Binding Email}"
                                       FontSize="13" Foreground="#6c757d" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding Profession}"
                                       FontSize="12" Foreground="#868e96" FontStyle="Italic" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Row 1: Tabs -->
                <dx:DXTabControl Grid.Row="1" Padding="8"
                                 TabContentCacheMode="CacheTabsOnSelecting">

                    <dx:DXTabItem Header="Perfiles de acceso">
                        <dxg:GridControl ItemsSource="{Binding AvailableProfiles}" Margin="0,8,0,0">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowEditing="False"
                                               ShowGroupPanel="False"
                                               ShowIndicator="False"
                                               AlternateRowBackground="Beige"
                                               AllowColumnMoving="False"
                                               AutoWidth="False"
                                               RowMinHeight="30"
                                               AllowCellMerge="False"/>
                            </dxg:GridControl.View>
                            <dxg:GridColumn FieldName="IsSelected" Header="" Width="40"
                                            HorizontalHeaderContentAlignment="Center"
                                            AllowSorting="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:CheckEdit IsChecked="{Binding RowData.Row.IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="Name" Header="Nombre" Width="*"
                                            AllowEditing="False" AllowSorting="False"/>
                            <dxg:GridColumn FieldName="Description" Header="Descripción" Width="*"
                                            AllowEditing="False" AllowSorting="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RowData.Row.Description}"
                                                   TextWrapping="Wrap" Padding="4,6"/>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl>
                    </dx:DXTabItem>

                    <dx:DXTabItem Header="Correos corporativos">
                        <dxg:GridControl ItemsSource="{Binding AvailableEmails}" Margin="0,8,0,0">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowEditing="False"
                                               ShowGroupPanel="False"
                                               ShowIndicator="False"
                                               AlternateRowBackground="Beige"
                                               AllowColumnMoving="False"
                                               AutoWidth="False"/>
                            </dxg:GridControl.View>
                            <dxg:GridColumn FieldName="IsSelected" Header="" Width="40"
                                            HorizontalHeaderContentAlignment="Center"
                                            AllowSorting="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:CheckEdit IsChecked="{Binding RowData.Row.IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="Description" Header="Descripción" Width="*"
                                            AllowEditing="False" AllowSorting="False"/>
                            <dxg:GridColumn FieldName="Name" Header="Correo" Width="*"
                                            AllowEditing="False" AllowSorting="False"/>
                        </dxg:GridControl>
                    </dx:DXTabItem>

                    <dx:DXTabItem Header="Centros de costo">
                        <dxg:GridControl ItemsSource="{Binding AvailableCostCenters}" Margin="0,8,0,0">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowEditing="False"
                                               ShowGroupPanel="False"
                                               ShowIndicator="False"
                                               AlternateRowBackground="Beige"
                                               AllowColumnMoving="False"
                                               AutoWidth="False"/>
                            </dxg:GridControl.View>
                            <dxg:GridColumn FieldName="IsSelected" Header="" Width="40"
                                            HorizontalHeaderContentAlignment="Center"
                                            AllowSorting="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dxe:CheckEdit IsChecked="{Binding RowData.Row.IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="Name" Header="Nombre" Width="*"
                                            AllowEditing="False" AllowSorting="False"/>
                        </dxg:GridControl>
                    </dx:DXTabItem>

                </dx:DXTabControl>

                <!-- Row 2: Action Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">

                    <!-- Guardar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave}"
                            Command="{Binding SaveCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Cancelar -->
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True"
                            Command="{Binding CancelCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
