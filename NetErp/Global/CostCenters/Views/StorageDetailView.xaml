<UserControl x:Class="NetErp.Global.CostCenters.Views.StorageDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             xmlns:h="clr-namespace:NetErp.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="460" d:DesignWidth="540"
             Background="#EEF1F5">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="8,0,8,8"
                Width="{Binding DialogWidth}"
                Height="{Binding DialogHeight}">
            <Grid Margin="15,15,15,5" h:EnterKeyTraversal.IsEnabled="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Estado de la bodega (siempre visible) -->
                <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#D9DDE3" BorderThickness="1"
                        CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Estado de la bodega" FontSize="13" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton Content="Activa" IsChecked="{Binding IsStatusActive, Mode=TwoWay}" GroupName="StorageStatusTop">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                                <Setter Property="Foreground" Value="Blue"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Content="Solo lectura" IsChecked="{Binding IsStatusReadOnly, Mode=TwoWay}" Margin="15,0,0,0" GroupName="StorageStatusTop">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                                <Setter Property="Foreground" Value="#FF8C00"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Content="Inactiva" IsChecked="{Binding IsStatusInactive, Mode=TwoWay}" Margin="15,0,0,0" GroupName="StorageStatusTop">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11" FontStyle="Italic" Foreground="Gray"
                                   Visibility="{Binding IsStatusActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Run Foreground="Blue">Activa:</Run> la bodega puede ser usada sin restricción para registrar movimientos y consultar el inventario.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="11" FontStyle="Italic" Foreground="Gray"
                                   Visibility="{Binding IsStatusReadOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Run Foreground="#FF8C00">Solo lectura:</Run> permite consultar el inventario existente pero no permite registrar nuevos movimientos.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="11" FontStyle="Italic" Foreground="Gray"
                                   Visibility="{Binding IsStatusInactive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Run Foreground="Red">Inactiva:</Run> no permite consultar la bodega ni registrar movimientos. Se remueve completamente de las vistas.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1">
                    <!-- Nombre -->
                    <TextBlock Text="Nombre de la bodega" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit x:Name="Name"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  CharacterCasing="Upper"
                                  Padding="3"
                                  MaxLength="{Binding NameMaxLength}"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>

                    <!-- País -->
                    <TextBlock Text="País" FontSize="13" Margin="0,0,0,3"/>
                    <dxg:LookUpEdit Margin="0,0,0,8" Padding="3"
                                    AutoPopulateColumns="False"
                                    IsCaseSensitiveSearch="False"
                                    FilterCondition="Contains"
                                    ImmediatePopup="True"
                                    ClearSelectionOnBackspace="True"
                                    NullText="Seleccione un país..."
                                    ItemsSource="{Binding Countries}"
                                    DisplayMember="Name"
                                    EditValue="{Binding SelectedCountry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    BorderBrush="#C8CED6">
                        <dxg:LookUpEdit.PopupContentTemplate>
                            <ControlTemplate>
                                <dxg:GridControl Name="PART_GridControl">
                                    <dxg:GridControl.View><dxg:TableView AutoWidth="True"/></dxg:GridControl.View>
                                    <dxg:GridControl.Columns>
                                        <dxg:GridColumn Header="Nombre del país" FieldName="Name"/>
                                    </dxg:GridControl.Columns>
                                </dxg:GridControl>
                            </ControlTemplate>
                        </dxg:LookUpEdit.PopupContentTemplate>
                        <dxg:LookUpEdit.ItemsPanel>
                            <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                        </dxg:LookUpEdit.ItemsPanel>
                    </dxg:LookUpEdit>

                    <!-- Departamento -->
                    <TextBlock Text="Departamento" FontSize="13" Margin="0,0,0,3"/>
                    <dxg:LookUpEdit Margin="0,0,0,8" Padding="3"
                                    AutoPopulateColumns="False"
                                    IsCaseSensitiveSearch="False"
                                    FilterCondition="Contains"
                                    ImmediatePopup="True"
                                    ClearSelectionOnBackspace="True"
                                    NullText="Seleccione un departamento..."
                                    CharacterCasing="Upper"
                                    ItemsSource="{Binding SelectedCountry.Departments, Mode=OneWay}"
                                    DisplayMember="Name"
                                    EditValue="{Binding SelectedDepartment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    BorderBrush="#C8CED6">
                        <dxg:LookUpEdit.PopupContentTemplate>
                            <ControlTemplate>
                                <dxg:GridControl Name="PART_GridControl">
                                    <dxg:GridControl.View><dxg:TableView AutoWidth="True" ShowSearchPanelMode="Never"/></dxg:GridControl.View>
                                    <dxg:GridControl.Columns>
                                        <dxg:GridColumn Header="Nombre del departamento" FieldName="Name"/>
                                    </dxg:GridControl.Columns>
                                </dxg:GridControl>
                            </ControlTemplate>
                        </dxg:LookUpEdit.PopupContentTemplate>
                        <dxg:LookUpEdit.ItemsPanel>
                            <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                        </dxg:LookUpEdit.ItemsPanel>
                    </dxg:LookUpEdit>

                    <!-- Municipio -->
                    <TextBlock Text="Municipio" FontSize="13" Margin="0,0,0,3"/>
                    <dxg:LookUpEdit Margin="0,0,0,8" Padding="3"
                                    AutoPopulateColumns="False"
                                    IsCaseSensitiveSearch="False"
                                    FilterCondition="Contains"
                                    ImmediatePopup="True"
                                    ClearSelectionOnBackspace="True"
                                    NullText="Seleccione un municipio..."
                                    CharacterCasing="Upper"
                                    ItemsSource="{Binding SelectedDepartment.Cities, Mode=OneWay}"
                                    DisplayMember="Name"
                                    EditValue="{Binding SelectedCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    BorderBrush="#C8CED6">
                        <dxg:LookUpEdit.PopupContentTemplate>
                            <ControlTemplate>
                                <dxg:GridControl Name="PART_GridControl">
                                    <dxg:GridControl.View><dxg:TableView AutoWidth="True" ShowSearchPanelMode="Never"/></dxg:GridControl.View>
                                    <dxg:GridControl.Columns>
                                        <dxg:GridColumn Header="Nombre del municipio" FieldName="Name"/>
                                    </dxg:GridControl.Columns>
                                </dxg:GridControl>
                            </ControlTemplate>
                        </dxg:LookUpEdit.PopupContentTemplate>
                        <dxg:LookUpEdit.ItemsPanel>
                            <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                        </dxg:LookUpEdit.ItemsPanel>
                    </dxg:LookUpEdit>

                    <!-- Dirección -->
                    <TextBlock Text="Dirección" FontSize="13" Margin="0,0,0,3"/>
                    <dxe:TextEdit x:Name="Address"
                                  Style="{StaticResource FocusedHighlightStyle}"
                                  CharacterCasing="Upper"
                                  Padding="3"
                                  MaxLength="{Binding AddressMaxLength}"
                                  BorderBrush="#C8CED6"
                                  Margin="0,0,0,8"/>
                </StackPanel>

                <!-- Button bar -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsEnabled="{Binding CanSave, UpdateSourceTrigger=PropertyChanged}">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding SaveCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Save/Save_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Guardar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="15,5" Cursor="Hand"
                            IsCancel="True">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand Command="{Binding CancelCommand}" EventName="Click"/>
                        </dxmvvm:Interaction.Behaviors>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" Width="32" Height="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelar" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
