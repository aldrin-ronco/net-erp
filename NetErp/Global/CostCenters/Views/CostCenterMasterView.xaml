<UserControl x:Class="NetErp.Global.CostCenters.Views.CostCenterMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:model="clr-namespace:NetErp.Global.CostCenters.DTO"
             xmlns:h="clr-namespace:NetErp.Helpers"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:busyIndicator="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <h:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>

        <!-- Company node -->
        <HierarchicalDataTemplate DataType="{x:Type model:CompanyDTO}" ItemsSource="{Binding Locations, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0" VerticalAlignment="Center" Background="Transparent">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Editar empresa"
                                  Command="{Binding Data.EditCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Data.CanEditCompany, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Edit_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasCompanyEditPermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Crear nueva sede"
                                  Command="{Binding Data.NewCompanyLocationCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Data.CanCreateCompanyLocation, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Actions/AddItem_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasCompanyLocationCreatePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18" VerticalAlignment="Center">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Row.IsExpanded}" Value="False">
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderClose.svg'}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Row.IsExpanded}" Value="True">
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderOpen.svg'}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <TextBlock Text="{Binding Row.CompanyEntity.SearchName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- CompanyLocation node -->
        <HierarchicalDataTemplate DataType="{x:Type model:CompanyLocationDTO}" ItemsSource="{Binding DummyItems, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0" VerticalAlignment="Center" Background="Transparent">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Editar sede"
                                  Command="{Binding Data.EditCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Data.CanEditCompanyLocation, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Edit_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasCompanyLocationEditPermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding Data.DeleteCompanyLocationCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Data.CanDeleteCompanyLocation, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Eliminar sede: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Delete_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasCompanyLocationDeletePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18" VerticalAlignment="Center">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Row.IsExpanded}" Value="False">
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderClose.svg'}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Row.IsExpanded}" Value="True">
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderOpen.svg'}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <TextBlock Text="{Binding Row.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- CostCenterDummy node -->
        <HierarchicalDataTemplate DataType="{x:Type model:CostCenterDummyDTO}" ItemsSource="{Binding CostCenters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0" VerticalAlignment="Center" Background="Transparent">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Crear centro de costo"
                                  Command="{Binding Data.NewCostCenterCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Data.CanCreateCostCenter, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Actions/AddItem_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasCostCenterCreatePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18" VerticalAlignment="Center">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Row.IsExpanded}" Value="False">
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderClose.svg'}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Row.IsExpanded}" Value="True">
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderOpen.svg'}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <TextBlock Text="{Binding Row.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- StorageDummy node -->
        <HierarchicalDataTemplate DataType="{x:Type model:StorageDummyDTO}" ItemsSource="{Binding Storages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0" VerticalAlignment="Center" Background="Transparent">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Crear bodega"
                                  Command="{Binding Data.NewStorageCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Data.CanCreateStorage, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Actions/AddItem_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasStorageCreatePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18" VerticalAlignment="Center">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Row.IsExpanded}" Value="False">
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderClose.svg'}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Row.IsExpanded}" Value="True">
                                    <Setter Property="Source" Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_FolderOpen.svg'}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <TextBlock Text="{Binding Row.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- CostCenter leaf -->
        <DataTemplate DataType="{x:Type model:CostCenterDTO}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0" VerticalAlignment="Center" Background="Transparent">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Editar centro de costo"
                                  Command="{Binding Data.EditCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Data.CanEditCostCenter, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Edit_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasCostCenterEditPermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding Data.DeleteCostCenterCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Data.CanDeleteCostCenter, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Eliminar centro de costo: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Delete_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasCostCenterDeletePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18" Source="{dx:DXImage 'Images/Miscellaneous/HighlightActiveElements_16x16.png'}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Row.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <!-- Storage leaf -->
        <DataTemplate DataType="{x:Type model:StorageDTO}">
            <StackPanel Orientation="Horizontal" Margin="-1,0,0,0" VerticalAlignment="Center" Background="Transparent">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Editar bodega"
                                  Command="{Binding Data.EditCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Data.CanEditStorage, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Edit_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasStorageEditPermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding Data.DeleteStorageCommand, Source={StaticResource DataContextProxy}}"
                                  IsEnabled="{Binding Data.CanDeleteStorage, Source={StaticResource DataContextProxy}}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Eliminar bodega: "/>
                                    <TextBlock Text="{Binding Row.Name}"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem.Icon>
                                <Grid>
                                    <Image Source="{dx:DXImage 'Images/Edit/Delete_16x16.png'}"/>
                                    <Image Source="{dx:DXImage 'Images/XAF/BO_Security_Permission.png'}"
                                           Width="10" Height="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Margin="0,0,-3,-3">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.HasStorageDeletePermission, Source={StaticResource DataContextProxy}}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Width="18" Height="18" Source="{dx:DXImage 'Images/Miscellaneous/HighlightActiveElements_16x16.png'}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Row.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <busyIndicator:BusyMask x:Name="BusyIndicator"
                            IsBusy="{Binding IsBusy}"
                            IndicatorType="BouncingDot"
                            BusyContent="Por favor espere..."
                            BusyContentMargin="0,20,0,0"
                            IsBusyAtStartup="False">
        <Border Background="White" BorderBrush="#D9DDE3" BorderThickness="1"
                CornerRadius="8" Margin="5">
            <dxg:TreeViewControl Margin="10"
                                 ItemsSource="{Binding Companies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 h:TreeViewExtension.SelectItemOnRightClick="True"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 HighlightSelectedNodeIndent="False"
                                 BorderThickness="0"
                                 ShowExpandButtons="True"
                                 ShowBorder="False"
                                 ExpandStateBinding="{Binding IsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TreeDerivationMode="HierarchicalDataTemplate">
                <dxg:TreeViewControl.NodeStyle>
                    <Style TargetType="dxg:RowControl">
                        <Setter Property="Foreground" Value="Black"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.IsExpanded}" Value="True">
                                <Setter Property="Foreground" Value="Blue"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </dxg:TreeViewControl.NodeStyle>
            </dxg:TreeViewControl>
        </Border>
    </busyIndicator:BusyMask>
</UserControl>
