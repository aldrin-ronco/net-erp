<UserControl x:Class="NetErp.UserControls.ItemStockByStorageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="80" d:DesignWidth="600"
             FontFamily="Century Gothic">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- Loading state -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                    Visibility="{Binding IsLoading, ElementName=Root, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Cargando existencias..." FontSize="12" Foreground="#6c757d" FontStyle="Italic"/>
        </StackPanel>

        <!-- Empty state -->
        <TextBlock Text="Sin existencias en bodegas" FontSize="12" Foreground="#9aa3ad" FontStyle="Italic"
                   VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsLoading, ElementName=Root}" Value="False"/>
                                <Condition Binding="{Binding HasStocks, ElementName=Root}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Stocks list -->
        <ItemsControl ItemsSource="{Binding DisplayItems, ElementName=Root}"
                      Visibility="{Binding HasStocks, ElementName=Root, Converter={StaticResource BoolToVis}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="6"
                            Padding="10,6"
                            Margin="0,8,8,0"
                            MinWidth="120">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#D9DDE3"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                        <Setter Property="Background" Value="#EBF5FB"/>
                                        <Setter Property="BorderBrush" Value="#1565C0"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding StorageName}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#2c3e50"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="220"/>
                            <TextBlock Text="{Binding QuantityText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#1565C0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                <Setter Property="Foreground" Value="#0D47A1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Border Background="#EEF1F5"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    HorizontalAlignment="Left"
                                    Margin="0,3,0,0"
                                    Visibility="{Binding ShowDimension, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding DimensionLabel}"
                                           FontSize="10"
                                           Foreground="#6c757d"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
